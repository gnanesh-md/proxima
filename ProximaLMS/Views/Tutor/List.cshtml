@model List<TutorViewModel>

<style>
    :root {
        --primary: #4C1864;
        --secondary: #7B2CBF;
        --light-bg: #f4f6fb;
    }

    body {
        background: var(--light-bg);
    }

    .container-fluid {
        padding-left: 0px !important;
        padding-right: 0px !important;
    }
    /* ================= HEADER ================= */

    .tutor-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding: 25px 30px;
        background: #fff;
       /*  border-radius: 18px; */
        box-shadow: 0 8px 30px rgba(0,0,0,.05);
    }

    .header-left {
        display: flex;
        flex-direction: column;
    }

    .header-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--primary);
        margin: 0;
    }

    .header-subtitle {
        font-size: 13px;
        color: #777;
        margin-top: 3px;
    }

    .tutor-count {
        background: var(--secondary);
        color: #fff;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        margin-left: 8px;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    /* ================= SEARCH ================= */

    .search-wrapper {
        position: relative;
    }

        .search-wrapper input {
            width: 280px;
            padding: 10px 15px 10px 38px;
           /*  border-radius: 30px; */
            border: 1px solid #e2e2e2;
            outline: none;
            transition: .3s;
            font-size: 14px;
        }

            .search-wrapper input:focus {
                border-color: var(--secondary);
                box-shadow: 0 0 0 3px rgba(123,44,191,.15);
            }

    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 14px;
        color: #999;
    }

    /* ================= ADD BUTTON ================= */

    .btn-add {
        background: linear-gradient(90deg,var(--primary),var(--secondary));
        color: #fff;
        padding: 10px 20px;
       /*  border-radius: 30px; */
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: .3s;
        box-shadow: 0 6px 18px rgba(76,24,100,.2);
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(76,24,100,.35);
            color: #fff;
        }

    /* ================= CARDS ================= */

    .tutor-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: .3s;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        background: #fff;
    }

        .tutor-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 40px rgba(0,0,0,.12);
        }

    .tutor-img {
        height: 200px;
        object-fit: cover;
        width: 100%;
        border-bottom: 4px solid var(--secondary);
    }

    .tutor-body {
        padding: 22px;
        text-align: center;
    }

    .tutor-name {
        font-weight: 600;
        font-size: 18px;
        color: var(--primary);
    }

    .tutor-email {
        font-size: 14px;
        color: #777;
    }

    .status-badge {
        display: inline-block;
        font-size: 12px;
        padding: 6px 14px;
        border-radius: 30px;
        font-weight: 500;
        margin-top: 8px;
    }

    .active-badge {
        background: #e6f9f0;
        color: #198754;
    }

    .inactive-badge {
        background: #fde8e8;
        color: #dc3545;
    }

    /* ================= BUTTONS ================= */

    .btn-custom {
        border-radius: 12px;
        font-size: 14px;
        font-weight: 500;
        padding: 8px 12px;
        transition: .3s;
    }

    .btn-edit {
        background: var(--primary);
        color: #fff;
    }

        .btn-edit:hover {
            background: var(--secondary);
            color: #fff;
        }

    .btn-toggle {
        border: 1px solid var(--secondary);
        color: var(--secondary);
        background: #fff;
    }

        .btn-toggle:hover {
            background: var(--secondary);
            color: #fff;
        }

    .btn-toggle {
        border-radius: 12px;
        font-weight: 600;
        transition: all .3s;
    }

        .btn-toggle[data-status="true"] {
            background: #ffe5e5;
            color: #dc3545;
            border: 1px solid #dc3545;
        }

        .btn-toggle[data-status="false"] {
            background: #e6f9f0;
            color: #198754;
            border: 1px solid #198754;
        }

</style>

<div class="container mt-4">
    @Html.AntiForgeryToken()
    <!-- ================= HEADER ================= -->
    <div class="tutor-header">

        <div class="header-left">
            <h3 class="header-title">
                All Tutors
                <span class="tutor-count">@Model.Count</span>
            </h3>
            <span class="header-subtitle">
                Manage and monitor all registered tutors
            </span>
        </div>

        <div class="header-right">

            <div class="search-wrapper">
                <i class="fa fa-search search-icon"></i>
                <input type="text"
                       id="searchInput"
                       placeholder="Search by name, email or mobile..." />
            </div>

            <a asp-action="Create" class="btn-add">
                <i class="fa fa-plus me-1"></i>
                Add Tutor
            </a>

        </div>
    </div>

    <!-- ================= TUTOR GRID ================= -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4 tutor-item"
                 data-name="@item.FullName?.ToLower()"
                 data-email="@item.Email?.ToLower()"
                 data-mobile="@item.MobileNumber">

                <div class="card tutor-card">

                    <img src="~/uploads/tutors/@(string.IsNullOrEmpty(item.ProfilePhoto) ? "default-user.png" : item.ProfilePhoto)"
                         class="tutor-img" />

                    <div class="tutor-body">

                        <div class="tutor-name">@item.FullName</div>
                        <div class="tutor-email">@item.Email</div>
                        <div class="tutor-email">@item.MobileNumber</div>

                        <span class="status-badge @(item.IsActive ? "active-badge" : "inactive-badge")"
                              id="status-badge-@item.TutorID">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>

                        <div class="d-flex gap-2 mt-3">
                            <a asp-action="Edit"
                               asp-route-id="@item.TutorID"
                               class="btn btn-custom btn-edit w-100">
                                Edit
                            </a>

                            <button class="btn btn-custom btn-toggle toggle-status w-100"
                                    data-id="@item.TutorID"
                                    data-status="@item.IsActive">
                                @(item.IsActive ? "Deactivate" : "Activate")
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        }

    </div>
</div>

<script>
    // ================= SEARCH FILTER =================
    document.getElementById("searchInput")
        .addEventListener("keyup", function () {

            const value = this.value.toLowerCase();
            const tutors = document.querySelectorAll(".tutor-item");

            tutors.forEach(function (card) {

                const name = card.getAttribute("data-name") || "";
                const email = card.getAttribute("data-email") || "";
                const mobile = card.getAttribute("data-mobile") || "";

                if (name.includes(value) ||
                    email.includes(value) ||
                    mobile.includes(value)) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            });
        });


 
</script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).on("click", ".toggle-status", function () {

        const button = $(this);
        const id = parseInt(button.data("id"));
        const currentStatus = button.data("status") === true || button.data("status") === "True";
        const newStatus = !currentStatus;

        const token = $('input[name="__RequestVerificationToken"]').val();

        $.ajax({
            url: '/Tutor/ToggleStatus',
            type: 'POST',
            headers: {
                "RequestVerificationToken": token
            },
            contentType: 'application/json',
            data: JSON.stringify({
                TutorID: id,
                IsActive: newStatus
            }),
            success: function () {

                button.data("status", newStatus);
                button.text(newStatus ? "Deactivate" : "Activate");

                const badge = $("#status-badge-" + id);

                if (newStatus) {
                    badge.removeClass("inactive-badge")
                        .addClass("active-badge")
                        .text("Active");

                    button.attr("data-status", "true");
                } else {
                    badge.removeClass("active-badge")
                        .addClass("inactive-badge")
                        .text("Inactive");

                    button.attr("data-status", "false");
                }
            },
            error: function (err) {
                console.log(err);
                alert("Toggle failed. Check console.");
            }
        });
    });

</script>