@model ProximaLMS.Models.InstructorRevenueViewModel
@{
    ViewData["Title"] = "Revenue";
    Layout = "_Layout";
    Func<decimal, string> inr = v => "₹" + v.ToString("N0");
}

<style>
    :root { --grape:#4C1864; --grape-2:#7B2CBF; --ink:#1f1d2b; --muted:#6b7280; --border:#e7e5ee; --ok:#16a34a; --amber:#d97706; }
    .rv-wrap { max-width:1080px; margin:0 auto; }
    .rv-head { display:flex; align-items:center; gap:12px; margin-bottom:20px;
        background:linear-gradient(120deg,var(--grape),var(--grape-2)); color:#fff; border-radius:14px; padding:16px 22px; }
    .rv-head h1 { font-size:1.2rem; font-weight:800; margin:0; }
    .rv-head .sub { opacity:.9; font-size:.83rem; }
    .rv-back { color:#fff; text-decoration:none; font-weight:700; font-size:.82rem; opacity:.9; margin-left:auto; }
    .rv-back:hover { opacity:1; color:#fff; }

    .rv-tiles { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:24px; }
    @@media (max-width:800px){ .rv-tiles { grid-template-columns:repeat(2,1fr); } }
    .rv-tile { background:#fff; border:1px solid var(--border); border-radius:14px; padding:16px 18px; box-shadow:0 6px 18px rgba(10,20,40,.04); }
    .rv-tile .n { font-size:1.55rem; font-weight:800; line-height:1; }
    .rv-tile .l { color:var(--muted); font-size:.8rem; margin-top:6px; }
    .rv-tile.net .n { color:var(--ok); } .rv-tile.gross .n { color:var(--grape); }
    .rv-tile.disc .n { color:var(--amber); } .rv-tile.ord .n { color:var(--ink); }

    .rv-panel { background:#fff; border:1px solid var(--border); border-radius:16px; box-shadow:0 8px 24px rgba(10,20,40,.05); overflow:hidden; }
    table.rv-table { width:100%; border-collapse:collapse; }
    .rv-table th { text-align:left; font-size:.74rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); padding:13px 18px; border-bottom:1px solid var(--border); background:#faf9fc; }
    .rv-table th.num, .rv-table td.num { text-align:right; }
    .rv-table td { padding:13px 18px; border-bottom:1px solid #f1eef7; font-size:.9rem; color:var(--ink); }
    .rv-table tr:last-child td { border-bottom:none; }
    .rv-course { font-weight:700; cursor:pointer; color:var(--grape); }
    .rv-course .chev { font-size:.7rem; margin-right:6px; transition:transform .15s; display:inline-block; }
    .rv-course.open .chev { transform:rotate(90deg); }
    .rv-net { font-weight:800; color:var(--ok); }
    .detail-row td { background:#faf9fc; padding:0; }
    .detail-inner { padding:10px 18px 14px 38px; }
    .detail-inner table { width:100%; border-collapse:collapse; }
    .detail-inner th { font-size:.7rem; color:var(--muted); text-transform:uppercase; padding:6px 10px; text-align:left; }
    .detail-inner td { font-size:.84rem; padding:6px 10px; border-top:1px solid #eee7f5; }
    .detail-inner td.num, .detail-inner th.num { text-align:right; }
    .rv-empty { padding:50px; text-align:center; color:var(--muted); }
    .confirm-note { font-size:.78rem; color:var(--amber); background:#fffaf0; border:1px solid #fde9c8; border-radius:10px; padding:10px 14px; margin-bottom:16px; }
</style>

<div class="rv-wrap">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="rv-head">
        <div>
            <h1><i class="fa-solid fa-indian-rupee-sign"></i> Revenue</h1>
            <div class="sub">@Model.TutorName · paid enrollments across your courses</div>
        </div>
        <a href="@Url.Action("Index","Instructor")" class="rv-back"><i class="fa-solid fa-arrow-left"></i> Back to panel</a>
    </div>

    <div class="rv-tiles">
        <div class="rv-tile net"><div class="n">@inr(Model.TotalNet)</div><div class="l">Net Revenue</div></div>
        <div class="rv-tile gross"><div class="n">@inr(Model.TotalGross)</div><div class="l">Gross (pre-discount)</div></div>
        <div class="rv-tile disc"><div class="n">@inr(Model.TotalDiscount)</div><div class="l">Discounts Given</div></div>
        <div class="rv-tile ord"><div class="n">@Model.TotalOrders</div><div class="l">Paid Orders</div></div>
    </div>

    <div class="rv-panel">
        @if (Model.Courses != null && Model.Courses.Any())
        {
            <table class="rv-table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th class="num">Orders</th>
                        <th class="num">Gross</th>
                        <th class="num">Discount</th>
                        <th class="num">Net</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Courses)
                    {
                        <tr>
                            <td>
                                <span class="rv-course" data-course-id="@c.CourseID" onclick="toggleDetail(this, @c.CourseID)">
                                    <span class="chev">▶</span>@c.CourseTitle
                                </span>
                            </td>
                            <td class="num">@c.PaidOrders</td>
                            <td class="num">@inr(c.GrossAmount)</td>
                            <td class="num">@inr(c.TotalDiscount)</td>
                            <td class="num rv-net">@inr(c.NetRevenue)</td>
                        </tr>
                        <tr class="detail-row" id="detail_@c.CourseID" style="display:none;">
                            <td colspan="5"><div class="detail-inner" id="detailInner_@c.CourseID">Loading…</div></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="rv-empty">
                <i class="fa-solid fa-receipt" style="font-size:36px;color:#d6cfe6;"></i>
                <h5 style="color:var(--ink);font-weight:800;margin-top:12px;">No paid orders yet</h5>
                <p>Revenue from paid enrollments will appear here.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const REV_URL = '@Url.Action("CourseOrders","Instructor")'; // see note below
        const inr = v => '₹' + (Number(v)||0).toLocaleString('en-IN');
        const esc = s => (s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
        const fmtDate = d => d ? new Date(d).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : '';
        const loaded = {};

        async function toggleDetail(el, courseId) {
            const row = document.getElementById('detail_' + courseId);
            const open = row.style.display !== 'none';
            if (open) { row.style.display = 'none'; el.classList.remove('open'); return; }
            row.style.display = ''; el.classList.add('open');

            if (loaded[courseId]) return;
            const inner = document.getElementById('detailInner_' + courseId);
            try {
                const rows = await fetch(REV_URL + '?courseId=' + courseId).then(r=>r.json());
                if (!Array.isArray(rows) || rows.length === 0) {
                    inner.innerHTML = '<div style="color:#98a2b3;padding:6px 0;">No order details.</div>';
                } else {
                    inner.innerHTML = `
                        <table>
                            <thead><tr><th>Student</th><th>Date</th><th class="num">Gross</th><th class="num">Discount</th><th class="num">Net</th></tr></thead>
                            <tbody>
                                ${rows.map(o=>`<tr>
                                    <td>${esc(o.studentEmail||('#'+o.studentID))}</td>
                                    <td>${fmtDate(o.paidOn)}</td>
                                    <td class="num">${inr(o.grossAmount)}</td>
                                    <td class="num">${inr(o.discountAmount)}</td>
                                    <td class="num">${inr(o.netAmount)}</td>
                                </tr>`).join('')}
                            </tbody>
                        </table>`;
                }
                loaded[courseId] = true;
            } catch (e) {
                inner.innerHTML = '<div style="color:#dc3545;">Could not load details.</div>';
            }
        }
    </script>
}
