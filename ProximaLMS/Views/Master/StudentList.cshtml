@model List<ProximaLMS.Models.StudentViewModel>
@{
    ViewData["Title"] = "Student List";
    Layout = "_Layout";

    string[] avatarColors = { "#4C1864", "#7B2CBF", "#2563eb", "#059669", "#d97706", "#dc2626", "#0891b2", "#7c3aed" };
    string GetInitial(string name) => string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[0].ToString().ToUpper();
    string GetColor(int i) => avatarColors[i % avatarColors.Length];

    int activeCount   = Model?.Count(s => s.IsActive) ?? 0;
    int inactiveCount = (Model?.Count ?? 0) - activeCount;
}

<style>
    :root {
        --grape:  #4C1864;
        --violet: #7B2CBF;
        --bg:     #f0ebfa;
        --border: #ede9f8;
        --text-h: #1a1035;
        --text-s: #6b7280;
    }
    body { background: var(--bg) !important; }
    .container-fluid { padding: 0 !important; }

    /* ── HERO ── */
    .sl-hero {
        background: linear-gradient(135deg, #2d0f4e 0%, var(--grape) 45%, var(--violet) 100%);
        padding: 30px 36px 88px; position: relative; overflow: hidden;
    }
    .sl-hero::before {
        content: ''; position: absolute;
        width: 360px; height: 360px;
        background: radial-gradient(circle, rgba(123,44,191,.35) 0%, transparent 68%);
        top: -80px; right: -60px; border-radius: 50%;
    }
    .sl-hero-inner {
        display: flex; align-items: center; justify-content: space-between;
        position: relative; z-index: 2; flex-wrap: wrap; gap: 14px;
    }
    .hero-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 2.5px; color: rgba(255,255,255,.45); margin-bottom: 6px; }
    .hero-title { font-size: 24px; font-weight: 800; color: #fff; margin: 0 0 4px; }
    .hero-sub   { font-size: 13px; color: rgba(255,255,255,.55); margin: 0; }

    .hero-actions { display: flex; gap: 10px; align-items: center; }
    .btn-hero-back {
        background: rgba(255,255,255,.12); color: #fff;
        border: 1px solid rgba(255,255,255,.25); padding: 10px 18px;
        border-radius: 11px; font-size: 13px; font-weight: 600;
        text-decoration: none; display: flex; align-items: center; gap: 7px;
        transition: background .2s;
    }
    .btn-hero-back:hover { background: rgba(255,255,255,.2); color: #fff; }
    .btn-hero-export {
        background: #fff; color: var(--grape); border: none;
        padding: 10px 20px; border-radius: 11px; font-size: 13px;
        font-weight: 700; text-decoration: none;
        display: flex; align-items: center; gap: 7px;
        box-shadow: 0 4px 16px rgba(0,0,0,.2); transition: transform .15s;
    }
    .btn-hero-export:hover { transform: translateY(-2px); color: var(--grape); }

    /* ── BODY ── */
    .sl-body { padding: 0 36px 48px; margin-top: -60px; position: relative; z-index: 10; }

    /* ── STAT MINI CARDS ── */
    .mini-stats {
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: 14px; margin-bottom: 22px;
    }
    @@media (max-width: 700px) { .mini-stats { grid-template-columns: 1fr; } }
    .msc {
        background: #fff; border-radius: 16px; border: 1.5px solid var(--border);
        box-shadow: 0 4px 18px rgba(76,24,100,.09);
        padding: 16px 20px; display: flex; align-items: center; gap: 14px;
        transition: transform .2s;
    }
    .msc:hover { transform: translateY(-3px); }
    .msc-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
    }
    .msc-p { background: #ede9f8; color: var(--grape); }
    .msc-g { background: #d1fae5; color: #059669; }
    .msc-r { background: #fee2e2; color: #dc2626; }
    .msc-val { font-size: 26px; font-weight: 900; color: var(--text-h); line-height: 1; }
    .msc-lbl { font-size: 11px; font-weight: 700; color: var(--text-s); text-transform: uppercase; letter-spacing: .5px; margin-top: 2px; }

    /* ── PANEL ── */
    .panel {
        background: #fff; border-radius: 18px;
        border: 1.5px solid var(--border);
        box-shadow: 0 6px 24px rgba(76,24,100,.07);
        overflow: hidden;
    }
    .panel-head {
        padding: 18px 22px 14px;
        display: flex; align-items: center; justify-content: space-between;
        border-bottom: 1px solid var(--border); flex-wrap: wrap; gap: 10px;
    }
    .panel-title {
        font-size: 15px; font-weight: 800; color: var(--text-h);
        display: flex; align-items: center; gap: 9px;
    }
    .panel-title-icon {
        width: 32px; height: 32px; border-radius: 9px; background: #ede9f8;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; color: var(--grape);
    }

    /* search */
    .search-wrap { position: relative; }
    .search-wrap i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 13px; pointer-events: none; }
    .srch {
        border: 1.5px solid var(--border); border-radius: 10px;
        padding: 9px 12px 9px 34px; width: 260px; font-size: 13px;
        background: #faf8ff; outline: none;
        transition: border-color .2s, box-shadow .2s;
    }
    .srch:focus { border-color: var(--violet); box-shadow: 0 0 0 3px rgba(123,44,191,.1); }

    /* ── TABLE ── */
    .sl-table-wrap { overflow-x: auto; }
    .sl-table { width: 100%; border-collapse: collapse; }
    .sl-table thead tr {
        background: linear-gradient(90deg, var(--grape), var(--violet));
    }
    .sl-table th {
        padding: 13px 16px; font-size: 11px; font-weight: 700;
        color: rgba(255,255,255,.85); text-transform: uppercase;
        letter-spacing: .6px; border: none; white-space: nowrap; text-align: left;
    }
    .sl-table tbody tr {
        border-bottom: 1px solid #f3f4f6; transition: background .15s;
    }
    .sl-table tbody tr:hover { background: #faf8ff; }
    .sl-table td { padding: 12px 16px; font-size: 13px; color: var(--text-h); vertical-align: middle; }

    /* avatar cell */
    .stu-cell { display: flex; align-items: center; gap: 10px; }
    .stu-av {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 800; color: #fff; flex-shrink: 0;
    }
    .stu-name  { font-weight: 700; color: var(--text-h); font-size: 13px; }
    .stu-email { font-size: 11px; color: var(--text-s); }

    /* status pill */
    .status-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 12px; border-radius: 20px;
        font-size: 11px; font-weight: 700;
    }
    .pill-a { background: #d1fae5; color: #059669; }
    .pill-i { background: #fee2e2; color: #dc2626; }
    .pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    /* toggle switch */
    .tgl { position: relative; display: inline-block; width: 44px; height: 24px; }
    .tgl input { display: none; }
    .tgl-sl {
        position: absolute; inset: 0; cursor: pointer;
        background: #d1d5db; border-radius: 24px; transition: .3s;
    }
    .tgl-sl::before {
        content: ''; position: absolute;
        width: 18px; height: 18px; left: 3px; bottom: 3px;
        background: #fff; border-radius: 50%; transition: .3s;
        box-shadow: 0 1px 3px rgba(0,0,0,.25);
    }
    .tgl input:checked + .tgl-sl { background: #10b981; }
    .tgl input:checked + .tgl-sl::before { transform: translateX(20px); }

    /* empty state */
    .empty-state { padding: 64px 24px; text-align: center; }
    .empty-state i { font-size: 52px; color: #d4b8f0; display: block; margin-bottom: 14px; }
    .empty-state h5 { color: var(--text-h); font-weight: 700; }
    .empty-state p  { color: var(--text-s); font-size: 13px; }

    /* toast */
    #toast {
        position: fixed; bottom: 28px; right: 28px; z-index: 9999;
        background: var(--grape); color: #fff;
        padding: 12px 22px; border-radius: 12px;
        font-size: 14px; font-weight: 600;
        box-shadow: 0 8px 24px rgba(76,24,100,.35);
        display: none; align-items: center; gap: 8px;
        animation: slideUp .3s ease;
    }
    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
</style>

<div class="container-fluid">

    <!-- ── HERO ── -->
    <div class="sl-hero">
        <div class="sl-hero-inner">
            <div>
                <div class="hero-label">Administration</div>
                <h1 class="hero-title"><i class="fas fa-users me-2" style="opacity:.7;"></i>Student List</h1>
                <p class="hero-sub">Manage all registered students and their access status.</p>
            </div>
            <div class="hero-actions">
                <a asp-controller="Dashboard" asp-action="Index" class="btn-hero-back">
                    <i class="fas fa-arrow-left"></i> Dashboard
                </a>
                <a href="/Master/DownloadStudentsExcel" class="btn-hero-export">
                    <i class="fas fa-file-excel"></i> Export Excel
                </a>
            </div>
        </div>
    </div>

    <!-- ── BODY ── -->
    <div class="sl-body">

        <!-- Stat mini cards -->
        <div class="mini-stats">
            <div class="msc">
                <div class="msc-icon msc-p"><i class="fas fa-users"></i></div>
                <div><div class="msc-val">@(Model?.Count ?? 0)</div><div class="msc-lbl">Total Students</div></div>
            </div>
            <div class="msc">
                <div class="msc-icon msc-g"><i class="fas fa-circle-check"></i></div>
                <div><div class="msc-val">@activeCount</div><div class="msc-lbl">Active</div></div>
            </div>
            <div class="msc">
                <div class="msc-icon msc-r"><i class="fas fa-circle-xmark"></i></div>
                <div><div class="msc-val">@inactiveCount</div><div class="msc-lbl">Inactive</div></div>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div style="background:#fee2e2;color:#dc2626;padding:12px 18px;border-radius:10px;margin-bottom:16px;font-size:14px;font-weight:600;">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            </div>
        }

        <!-- Table panel -->
        <div class="panel">
            <div class="panel-head">
                <div class="panel-title">
                    <div class="panel-title-icon"><i class="fas fa-table"></i></div>
                    All Students
                    <span style="background:#ede9f8;color:var(--grape);font-size:11px;font-weight:700;padding:2px 9px;border-radius:12px;" id="visibleCount">@(Model?.Count ?? 0)</span>
                </div>
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" id="stuSearch" class="srch" placeholder="Search name, email, mobile…" />
                </div>
            </div>

            <div class="sl-table-wrap">
                <table class="sl-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student</th>
                            <th>Gender</th>
                            <th>Mobile</th>
                            <th>Reg. Date</th>
                            <th>Status</th>
                            <th style="text-align:center;">Active/Deactivate</th>
                        </tr>
                    </thead>
                    <tbody id="stuTableBody">
                        @if (Model != null && Model.Any())
                        {
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                var s      = Model[i];
                                var initl  = string.IsNullOrWhiteSpace(s.Name) ? "?" : s.Name.Trim()[0].ToString().ToUpper();
                                var color  = avatarColors[i % avatarColors.Length];
                                <tr class="stu-row"
                                    data-name="@(s.Name?.ToLower())"
                                    data-email="@(s.Email?.ToLower())"
                                    data-mobile="@(s.MobileNumber?.ToLower())">
                                    <td style="font-size:12px;color:var(--text-s);font-weight:600;">@(i + 1)</td>
                                    <td>
                                        <div class="stu-cell">
                                            <div class="stu-av" style="background:@color;">@initl</div>
                                            <div>
                                                <div class="stu-name">@s.Name</div>
                                                <div class="stu-email">@s.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td style="font-size:12px;color:var(--text-s);">@(s.Gender ?? "—")</td>
                                    <td style="font-size:12px;">@(s.MobileNumber ?? "—")</td>
                                    <td style="font-size:12px;color:var(--text-s);">@(s.CreatedDate ?? "—")</td>
                                    <td>
                                        <span class="status-pill @(s.IsActive ? "pill-a" : "pill-i") status-badge" data-id="@s.ID">
                                            <span class="pill-dot"></span>
                                            @(s.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td style="text-align:center;">
                                        <label class="tgl">
                                            <input type="checkbox"
                                                   class="status-toggle"
                                                   data-id="@s.ID"
                                                   @(s.IsActive ? "checked" : "") />
                                            <span class="tgl-sl"></span>
                                        </label>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7">
                                    <div class="empty-state">
                                        <i class="fas fa-users"></i>
                                        <h5>No Students Found</h5>
                                        <p>No students are registered in the system yet.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div><!-- /panel -->

    </div><!-- /sl-body -->
</div>

<!-- Toast -->
<div id="toast"><i class="fas fa-check-circle"></i><span id="toastMsg"></span></div>

<script>
    // ── SEARCH ─────────────────────────────────────────────────
    const searchInput  = document.getElementById('stuSearch');
    const visibleCount = document.getElementById('visibleCount');

    searchInput.addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        let visible = 0;
        document.querySelectorAll('.stu-row').forEach(row => {
            const match = !q
                || row.dataset.name?.includes(q)
                || row.dataset.email?.includes(q)
                || row.dataset.mobile?.includes(q);
            row.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        visibleCount.textContent = visible;
    });

    // ── STATUS TOGGLE ──────────────────────────────────────────
    // FIX: calls the MVC controller which proxies to API
    document.querySelectorAll('.status-toggle').forEach(chk => {
        chk.addEventListener('change', async function () {
            const studentId = this.dataset.id;
            const isActive  = this.checked;
            const row       = this.closest('tr');
            const badge     = row.querySelector('.status-badge');

            try {
                // Call the MVC proxy endpoint (which internally calls the API)
                const resp = await fetch('/Master/UpdateStudentStatus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '' },
                    body: JSON.stringify({ id: studentId, isActive: isActive })
                });

                const data = await resp.json();

                if (data.success || data.Success) {
                    // Update badge
                    badge.classList.remove('pill-a', 'pill-i');
                    badge.classList.add(isActive ? 'pill-a' : 'pill-i');
                    badge.innerHTML = `<span class="pill-dot"></span>${isActive ? 'Active' : 'Inactive'}`;
                    showToast(isActive ? '✅ Student activated' : '🔴 Student deactivated');
                } else {
                    this.checked = !isActive;
                    showToast('❌ ' + (data.message || data.Message || 'Update failed'), true);
                }
            } catch (e) {
                this.checked = !isActive;
                showToast('❌ Server error: ' + e.message, true);
            }
        });
    });

    // ── TOAST ──────────────────────────────────────────────────
    function showToast(msg, isError) {
        const toast = document.getElementById('toast');
        const msgEl = document.getElementById('toastMsg');
        toast.style.background = isError ? '#dc2626' : '#4C1864';
        msgEl.textContent = msg;
        toast.style.display = 'flex';
        setTimeout(() => { toast.style.display = 'none'; }, 3000);
    }
</script>
