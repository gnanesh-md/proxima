@using Newtonsoft.Json.Linq
@{
    ViewData["Title"] = "Analytics";
    Layout = "_Layout";

    var h       = ViewBag.Health        as JObject ?? new JObject();
    var rev     = ViewBag.Revenue       as JArray  ?? new JArray();
    var top     = ViewBag.TopCourses    as JArray  ?? new JArray();
    var coupons = ViewBag.Coupons       as JArray  ?? new JArray();
    var cs      = ViewBag.CouponSummary as JObject ?? new JObject();

    decimal totalRev = (decimal?)h["TotalRevenue"]     ?? 0;
    decimal revMonth = (decimal?)h["RevenueThisMonth"] ?? 0;
    int students = (int?)h["TotalStudents"]    ?? 0;
    int tutors   = (int?)h["TotalTutors"]      ?? 0;
    int courses  = (int?)h["TotalCourses"]     ?? 0;
    int enroll   = (int?)h["TotalEnrollments"] ?? 0;
    int ordersM  = (int?)h["OrdersThisMonth"]  ?? 0;

    // ── derived metrics ──
    int totalOrders = rev.Sum(r => (int?)r["Orders"] ?? 0);
    decimal avgOrder = totalOrders > 0 ? totalRev / totalOrders : 0;
    int enrollPerStudent = students > 0 ? (int)System.Math.Round(enroll * 100.0 / students) : 0;
    int paidConversion = enroll > 0 ? (int)System.Math.Round(totalOrders * 100.0 / enroll) : 0;
    decimal discount = (decimal?)cs["TotalDiscountGiven"] ?? 0;
    int couponOrders = (int?)cs["CouponOrders"] ?? 0;

    // ── chart data ──
    var revLabels  = rev.Select(r => (string)r["Label"]).ToList();
    var revData    = rev.Select(r => (decimal?)r["Revenue"] ?? 0).ToList();
    var revOrders  = rev.Select(r => (int?)r["Orders"] ?? 0).ToList();

    var topActive  = top.Where(c => ((int?)c["Enrollments"] ?? 0) > 0)
                        .OrderByDescending(c => (int?)c["Enrollments"] ?? 0).Take(8).ToList();
    var topLabels  = topActive.Select(c => (string)c["CourseTitle"]).ToList();
    var topEnroll  = topActive.Select(c => (int?)c["Enrollments"] ?? 0).ToList();
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    :root{
        --g1:#3D1054; --g2:#7C3AED; --g3:#A855F7; --g4:#C084FC;
        --ink:#1e1633; --sub:#64748b; --muted:#94a3b8;
        --bd:#ece7f8; --bg:#f7f5fd; --card:#fff;
        --sh:0 4px 18px rgba(76,24,100,.06); --sh-md:0 10px 32px rgba(76,24,100,.12);
        --ok:#16a34a; --warn:#d97706; --info:#2563eb; --rose:#e11d48;
    }
    .anx{font-family:'Plus Jakarta Sans',system-ui,sans-serif;display:flex;flex-direction:column;gap:20px;}

    /* hero */
    .anx-hero{
        position:relative;overflow:hidden;border-radius:22px;padding:28px 32px;color:#fff;
        background:linear-gradient(125deg,#2d0a50 0%,#3D1054 35%,#7C3AED 75%,#A855F7 100%);
        box-shadow:0 14px 40px rgba(76,24,100,.28);
        display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;
    }
    .anx-hero::before{content:'';position:absolute;top:-90px;right:-60px;width:320px;height:320px;border-radius:50%;background:rgba(255,255,255,.06);}
    .anx-hero::after{content:'';position:absolute;bottom:-80px;left:30%;width:200px;height:200px;border-radius:50%;background:rgba(232,121,249,.12);}
    .anx-hero-l{position:relative;z-index:1;}
    .anx-eyebrow{font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;opacity:.7;margin:0 0 6px;}
    .anx-hero h1{font-size:1.9rem;font-weight:800;margin:0;line-height:1.1;}
    .anx-hero p{font-size:.88rem;opacity:.82;margin:6px 0 0;}
    .anx-hero-r{position:relative;z-index:1;display:flex;gap:10px;flex-wrap:wrap;}
    .anx-btn{display:inline-flex;align-items:center;gap:7px;padding:10px 16px;border-radius:11px;font-size:.82rem;font-weight:700;border:none;cursor:pointer;text-decoration:none;transition:.15s;}
    .anx-btn--white{background:#fff;color:var(--g2);box-shadow:0 4px 14px rgba(0,0,0,.14);}
    .anx-btn--white:hover{background:#f3e8ff;color:var(--g1);}
    .anx-btn--ghost{background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.28);}
    .anx-btn--ghost:hover{background:rgba(255,255,255,.26);color:#fff;}

    /* KPI grid */
    .anx-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
    @@media(max-width:1100px){.anx-kpis{grid-template-columns:repeat(2,1fr);}}
    @@media(max-width:560px){.anx-kpis{grid-template-columns:1fr 1fr;}}
    .kpi{background:var(--card);border:1px solid var(--bd);border-radius:16px;padding:18px;box-shadow:var(--sh);transition:transform .18s,box-shadow .18s;position:relative;overflow:hidden;}
    .kpi:hover{transform:translateY(-3px);box-shadow:var(--sh-md);}
    .kpi::after{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--g2);}
    .kpi.c-green::after{background:var(--ok);} .kpi.c-blue::after{background:var(--info);}
    .kpi.c-amber::after{background:var(--warn);} .kpi.c-rose::after{background:var(--rose);}
    .kpi.c-grape::after{background:var(--g3);}
    .kpi-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
    .kpi-ic{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:17px;}
    .ic-grape{background:#f3e8ff;color:var(--g2);} .ic-green{background:#dcfce7;color:var(--ok);}
    .ic-blue{background:#dbeafe;color:var(--info);} .ic-amber{background:#fef3c7;color:var(--warn);}
    .ic-rose{background:#ffe4e6;color:var(--rose);} .ic-cyan{background:#cffafe;color:#0891b2;}
    .kpi-chip{font-size:.66rem;font-weight:700;padding:3px 8px;border-radius:20px;background:#f1f5f9;color:var(--sub);}
    .kpi-val{font-size:1.7rem;font-weight:800;color:var(--ink);line-height:1;}
    .kpi-lbl{font-size:.74rem;color:var(--muted);font-weight:600;margin-top:5px;}

    /* layout cards */
    .anx-row{display:grid;gap:18px;}
    .anx-row.r-2-1{grid-template-columns:2fr 1fr;}
    .anx-row.r-1-1{grid-template-columns:1fr 1fr;}
    @@media(max-width:950px){.anx-row.r-2-1,.anx-row.r-1-1{grid-template-columns:1fr;}}
    .card{background:var(--card);border:1px solid var(--bd);border-radius:18px;box-shadow:var(--sh);display:flex;flex-direction:column;overflow:hidden;}
    .card-hd{display:flex;justify-content:space-between;align-items:center;padding:16px 20px;border-bottom:1px solid #f5f3fb;}
    .card-hd h5{margin:0;font-size:.95rem;font-weight:800;color:var(--ink);display:flex;align-items:center;gap:8px;}
    .card-hd h5 i{color:var(--g2);}
    .card-bd{padding:18px 20px;flex:1;}
    .csv-btn{display:inline-flex;align-items:center;gap:6px;background:#f3f0fa;color:var(--g2);border:none;padding:7px 13px;border-radius:9px;font-size:.74rem;font-weight:700;cursor:pointer;text-decoration:none;transition:.15s;}
    .csv-btn:hover{background:var(--g2);color:#fff;}

    /* funnel */
    .funnel{display:flex;flex-direction:column;gap:12px;}
    .fn-row{display:flex;align-items:center;gap:12px;}
    .fn-bar{height:38px;border-radius:10px;display:flex;align-items:center;padding:0 14px;color:#fff;font-weight:800;font-size:.9rem;min-width:54px;box-shadow:0 4px 12px rgba(124,58,237,.18);}
    .fn-meta{flex:1;}
    .fn-meta .t{font-size:.8rem;font-weight:700;color:var(--ink);}
    .fn-meta .s{font-size:.7rem;color:var(--muted);}

    /* table */
    .tbl{width:100%;border-collapse:collapse;}
    .tbl th{text-align:left;padding:10px 12px;font-size:.7rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);border-bottom:2px solid #f0eef7;}
    .tbl td{padding:11px 12px;font-size:.84rem;color:var(--ink);border-bottom:1px solid #f6f5fa;}
    .tbl tr:last-child td{border-bottom:none;}
    .tbl tr:hover td{background:#faf8ff;}
    .rank{width:24px;height:24px;border-radius:7px;background:#f3e8ff;color:var(--g2);font-weight:800;font-size:.74rem;display:inline-flex;align-items:center;justify-content:center;}
    .pbar{height:6px;background:#ede9fe;border-radius:99px;overflow:hidden;min-width:80px;}
    .pbar > i{display:block;height:100%;border-radius:99px;background:linear-gradient(90deg,var(--g2),var(--g3));}
    .badge{font-size:.68rem;font-weight:700;padding:3px 9px;border-radius:20px;}
    .b-ok{background:#dcfce7;color:var(--ok);} .b-mut{background:#f1f5f9;color:var(--sub);}

    .empty{text-align:center;padding:34px 16px;color:var(--muted);}
    .empty i{font-size:30px;opacity:.35;display:block;margin-bottom:10px;}
    .chart-wrap{position:relative;height:230px;}
    .chart-wrap.sm{height:200px;}
</style>

<div class="anx">

    <!-- HERO -->
    <div class="anx-hero">
        <div class="anx-hero-l">
            <p class="anx-eyebrow">Business Intelligence</p>
            <h1><i class="fa-solid fa-chart-line"></i> Platform Analytics</h1>
            <p>Revenue, growth and engagement across ProximaLMS &middot; @DateTime.Now.ToString("dddd, dd MMM yyyy")</p>
        </div>
        <div class="anx-hero-r">
            <button class="anx-btn anx-btn--ghost" onclick="location.reload()"><i class="fa-solid fa-rotate"></i> Refresh</button>
            <a class="anx-btn anx-btn--white" asp-action="Export" asp-route-report="revenue_monthly"><i class="fa-solid fa-file-csv"></i> Export Revenue</a>
        </div>
    </div>

    <!-- KPIs -->
    <div class="anx-kpis">
        <div class="kpi c-grape">
            <div class="kpi-top"><div class="kpi-ic ic-grape"><i class="fa-solid fa-indian-rupee-sign"></i></div><span class="kpi-chip">All time</span></div>
            <div class="kpi-val">&#8377;@totalRev.ToString("N0")</div><div class="kpi-lbl">Total Revenue</div>
        </div>
        <div class="kpi c-green">
            <div class="kpi-top"><div class="kpi-ic ic-green"><i class="fa-solid fa-sack-dollar"></i></div><span class="kpi-chip">This month</span></div>
            <div class="kpi-val">&#8377;@revMonth.ToString("N0")</div><div class="kpi-lbl">Revenue This Month</div>
        </div>
        <div class="kpi c-blue">
            <div class="kpi-top"><div class="kpi-ic ic-blue"><i class="fa-solid fa-cart-shopping"></i></div><span class="kpi-chip">This month</span></div>
            <div class="kpi-val">@ordersM</div><div class="kpi-lbl">Orders This Month</div>
        </div>
        <div class="kpi c-amber">
            <div class="kpi-top"><div class="kpi-ic ic-amber"><i class="fa-solid fa-receipt"></i></div><span class="kpi-chip">Avg</span></div>
            <div class="kpi-val">&#8377;@avgOrder.ToString("N0")</div><div class="kpi-lbl">Avg Order Value</div>
        </div>
        <div class="kpi c-grape">
            <div class="kpi-top"><div class="kpi-ic ic-grape"><i class="fa-solid fa-user-graduate"></i></div><span class="kpi-chip">Total</span></div>
            <div class="kpi-val">@students</div><div class="kpi-lbl">Students</div>
        </div>
        <div class="kpi c-cyan" style="--g2:#0891b2;">
            <div class="kpi-top"><div class="kpi-ic ic-cyan"><i class="fa-solid fa-chalkboard-user"></i></div><span class="kpi-chip">Total</span></div>
            <div class="kpi-val">@tutors</div><div class="kpi-lbl">Tutors</div>
        </div>
        <div class="kpi c-blue">
            <div class="kpi-top"><div class="kpi-ic ic-blue"><i class="fa-solid fa-book-open"></i></div><span class="kpi-chip">Active</span></div>
            <div class="kpi-val">@courses</div><div class="kpi-lbl">Active Courses</div>
        </div>
        <div class="kpi c-green">
            <div class="kpi-top"><div class="kpi-ic ic-green"><i class="fa-solid fa-graduation-cap"></i></div><span class="kpi-chip">Total</span></div>
            <div class="kpi-val">@enroll</div><div class="kpi-lbl">Enrollments</div>
        </div>
    </div>

    <!-- REVENUE + FUNNEL -->
    <div class="anx-row r-2-1">
        <div class="card">
            <div class="card-hd">
                <h5><i class="fa-solid fa-chart-area"></i> Revenue &amp; Orders — Last 12 Months</h5>
                <a class="csv-btn" asp-action="Export" asp-route-report="revenue_monthly"><i class="fa-solid fa-download"></i> CSV</a>
            </div>
            <div class="card-bd">
                @if (revData.Any())
                {
                    <div class="chart-wrap"><canvas id="revChart"></canvas></div>
                }
                else
                {
                    <div class="empty"><i class="fa-solid fa-chart-area"></i><p>No revenue recorded yet.</p></div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-hd"><h5><i class="fa-solid fa-filter"></i> Conversion Funnel</h5></div>
            <div class="card-bd">
                @{
                    int fnMax = System.Math.Max(students, 1);
                    int wStu = 100;
                    int wEnr = (int)System.Math.Max(18, enroll * 100.0 / fnMax);
                    int wOrd = (int)System.Math.Max(14, totalOrders * 100.0 / fnMax);
                }
                <div class="funnel">
                    <div class="fn-row">
                        <div class="fn-bar" style="width:@(wStu)%;background:linear-gradient(90deg,#3D1054,#7C3AED);">@students</div>
                        <div class="fn-meta"><div class="t">Students</div><div class="s">Registered users</div></div>
                    </div>
                    <div class="fn-row">
                        <div class="fn-bar" style="width:@(wEnr)%;background:linear-gradient(90deg,#7C3AED,#A855F7);">@enroll</div>
                        <div class="fn-meta"><div class="t">Enrollments</div><div class="s">@enrollPerStudent% of students</div></div>
                    </div>
                    <div class="fn-row">
                        <div class="fn-bar" style="width:@(wOrd)%;background:linear-gradient(90deg,#A855F7,#C084FC);">@totalOrders</div>
                        <div class="fn-meta"><div class="t">Paid Orders</div><div class="s">@paidConversion% of enrollments</div></div>
                    </div>
                </div>
                <div style="margin-top:18px;padding-top:16px;border-top:1px dashed var(--bd);display:flex;justify-content:space-between;">
                    <div><div style="font-size:1.2rem;font-weight:800;color:var(--ink);">@enrollPerStudent%</div><div style="font-size:.7rem;color:var(--muted);">Enroll rate</div></div>
                    <div><div style="font-size:1.2rem;font-weight:800;color:var(--ink);">@paidConversion%</div><div style="font-size:.7rem;color:var(--muted);">Paid rate</div></div>
                    <div><div style="font-size:1.2rem;font-weight:800;color:var(--ink);">&#8377;@avgOrder.ToString("N0")</div><div style="font-size:.7rem;color:var(--muted);">Avg value</div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- TOP COURSES CHART + DOUGHNUT -->
    <div class="anx-row r-1-1">
        <div class="card">
            <div class="card-hd"><h5><i class="fa-solid fa-ranking-star"></i> Top Courses by Enrollment</h5></div>
            <div class="card-bd">
                @if (topEnroll.Any())
                { <div class="chart-wrap sm"><canvas id="topBar"></canvas></div> }
                else
                { <div class="empty"><i class="fa-solid fa-book"></i><p>No enrollment data yet.</p></div> }
            </div>
        </div>
        <div class="card">
            <div class="card-hd"><h5><i class="fa-solid fa-chart-pie"></i> Enrollment Distribution</h5></div>
            <div class="card-bd">
                @if (topEnroll.Any())
                { <div class="chart-wrap sm"><canvas id="topDonut"></canvas></div> }
                else
                { <div class="empty"><i class="fa-solid fa-chart-pie"></i><p>No data to chart.</p></div> }
            </div>
        </div>
    </div>

    <!-- TOP COURSES TABLE -->
    <div class="card">
        <div class="card-hd">
            <h5><i class="fa-solid fa-trophy"></i> Course Performance</h5>
            <a class="csv-btn" asp-action="Export" asp-route-report="top_courses"><i class="fa-solid fa-download"></i> CSV</a>
        </div>
        <div class="card-bd" style="padding:6px 8px;">
            @if (top.Any())
            {
                int maxEnr = top.Max(c => (int?)c["Enrollments"] ?? 0); if (maxEnr == 0) maxEnr = 1;
                <table class="tbl">
                    <thead><tr><th>#</th><th>Course</th><th>Enrollments</th><th style="width:160px;">Share</th><th>Revenue</th><th>Status</th></tr></thead>
                    <tbody>
                    @{ int rk = 0; }
                    @foreach (var c in top.OrderByDescending(x => (int?)x["Enrollments"] ?? 0))
                    {
                        rk++;
                        int en = (int?)c["Enrollments"] ?? 0;
                        decimal cr = (decimal?)c["Revenue"] ?? 0;
                        int pct = (int)System.Math.Round(en * 100.0 / maxEnr);
                        <tr>
                            <td><span class="rank">@rk</span></td>
                            <td style="font-weight:600;">@(((string)c["CourseTitle"] ?? "").Trim())</td>
                            <td style="font-weight:700;color:var(--g2);">@en</td>
                            <td><div class="pbar"><i style="width:@(pct)%;"></i></div></td>
                            <td>&#8377;@cr.ToString("N0")</td>
                            <td><span class="badge @(en > 0 ? "b-ok" : "b-mut")">@(en > 0 ? "Active" : "No enrolls")</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else { <div class="empty"><i class="fa-solid fa-book"></i><p>No course data yet.</p></div> }
        </div>
    </div>

    <!-- COUPON ANALYTICS -->
    <div class="card">
        <div class="card-hd">
            <h5><i class="fa-solid fa-ticket"></i> Coupon Analytics</h5>
            <a class="csv-btn" asp-action="Export" asp-route-report="coupon_usage"><i class="fa-solid fa-download"></i> CSV</a>
        </div>
        <div class="card-bd">
            <div style="display:flex;gap:24px;flex-wrap:wrap;margin-bottom:16px;">
                <div><div style="font-size:1.5rem;font-weight:800;color:var(--ink);">&#8377;@discount.ToString("N0")</div><div style="font-size:.74rem;color:var(--muted);">Total Discount Given</div></div>
                <div><div style="font-size:1.5rem;font-weight:800;color:var(--ink);">@couponOrders</div><div style="font-size:.74rem;color:var(--muted);">Coupon Orders</div></div>
                <div><div style="font-size:1.5rem;font-weight:800;color:var(--ink);">@coupons.Count</div><div style="font-size:.74rem;color:var(--muted);">Active Coupons</div></div>
            </div>
            @if (coupons.Any())
            {
                <table class="tbl">
                    <thead><tr><th>Coupon</th><th>Times Used</th><th>Discount</th></tr></thead>
                    <tbody>
                    @foreach (var c in coupons)
                    {
                        <tr><td style="font-weight:600;">@c["CouponCode"]</td><td>@c["TimesUsed"]</td><td>&#8377;@(((decimal?)c["TotalDiscount"] ?? 0).ToString("N0"))</td></tr>
                    }
                    </tbody>
                </table>
            }
            else { <div class="empty"><i class="fa-solid fa-ticket"></i><p>No coupons have been redeemed yet.</p></div> }
        </div>
    </div>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
(function(){
    const PURPLE = '#7C3AED', LPURPLE = '#A855F7';
    const palette = ['#7C3AED','#A855F7','#C084FC','#2563eb','#0891b2','#16a34a','#d97706','#e11d48'];
    const fontFam = "'Plus Jakarta Sans',sans-serif";
    if (window.Chart) { Chart.defaults.font.family = fontFam; Chart.defaults.color = '#94a3b8'; }

    // ── Revenue + Orders combo ──
    const revLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(revLabels));
    const revData   = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(revData));
    const revOrders = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(revOrders));
    const revEl = document.getElementById('revChart');
    if (revEl && revLabels.length) {
        const ctx = revEl.getContext('2d');
        const grad = ctx.createLinearGradient(0,0,0,230);
        grad.addColorStop(0,'rgba(124,58,237,.35)'); grad.addColorStop(1,'rgba(124,58,237,.02)');
        new Chart(revEl,{
            data:{labels:revLabels,datasets:[
                {type:'line',label:'Revenue (₹)',data:revData,borderColor:PURPLE,backgroundColor:grad,
                 borderWidth:3,fill:true,tension:.4,pointBackgroundColor:'#fff',pointBorderColor:PURPLE,pointBorderWidth:2,pointRadius:5,yAxisID:'y'},
                {type:'bar',label:'Orders',data:revOrders,backgroundColor:'rgba(168,85,247,.30)',borderRadius:6,barThickness:18,yAxisID:'y1'}
            ]},
            options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
                plugins:{legend:{display:true,position:'top',labels:{usePointStyle:true,boxWidth:8,padding:16,font:{size:11}}},
                    tooltip:{backgroundColor:'#1e1633',padding:11,cornerRadius:8,titleFont:{size:12},bodyFont:{size:12}}},
                scales:{
                    x:{grid:{display:false},ticks:{font:{size:11}}},
                    y:{position:'left',beginAtZero:true,grid:{color:'#f1eef7'},ticks:{font:{size:11},callback:v=>'₹'+v}},
                    y1:{position:'right',beginAtZero:true,grid:{display:false},ticks:{font:{size:11},stepSize:1}}
                }}
        });
    }

    // ── Top courses horizontal bar ──
    const topLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(topLabels));
    const topEnroll = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(topEnroll));
    const tb = document.getElementById('topBar');
    if (tb && topEnroll.length) {
        new Chart(tb,{type:'bar',
            data:{labels:topLabels,datasets:[{label:'Enrollments',data:topEnroll,
                backgroundColor:topLabels.map((_,i)=>palette[i%palette.length]),borderRadius:7,barThickness:16}]},
            options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
                plugins:{legend:{display:false},tooltip:{backgroundColor:'#1e1633',padding:10,cornerRadius:8}},
                scales:{x:{beginAtZero:true,grid:{color:'#f1eef7'},ticks:{stepSize:1,font:{size:11}}},
                        y:{grid:{display:false},ticks:{font:{size:11}}}}}
        });
    }

    // ── Enrollment doughnut ──
    const td = document.getElementById('topDonut');
    if (td && topEnroll.length) {
        new Chart(td,{type:'doughnut',
            data:{labels:topLabels,datasets:[{data:topEnroll,backgroundColor:palette,borderWidth:2,borderColor:'#fff'}]},
            options:{responsive:true,maintainAspectRatio:false,cutout:'62%',
                plugins:{legend:{position:'right',labels:{usePointStyle:true,boxWidth:8,padding:10,font:{size:10}}},
                    tooltip:{backgroundColor:'#1e1633',padding:10,cornerRadius:8}}}
        });
    }
})();
</script>
}
