@model ProximaLMS.Models.ExamBuilderPageViewModel
@{
    ViewData["Title"] = "Announcements";
    Layout = "_Layout";
}

<style>
    :root { --grape:#4C1864; --grape-2:#7B2CBF; --ink:#1f1d2b; --muted:#6b7280; --border:#e7e5ee; --amber:#d97706; }
    .an-wrap { max-width:820px; margin:0 auto; }
    .an-head { display:flex; align-items:center; gap:12px; margin-bottom:18px;
        background:linear-gradient(120deg,var(--grape),var(--grape-2)); color:#fff; border-radius:14px; padding:16px 22px; }
    .an-head h1 { font-size:1.2rem; font-weight:800; margin:0; }
    .an-head .sub { opacity:.9; font-size:.83rem; }
    .an-back { color:#fff; text-decoration:none; font-weight:700; font-size:.82rem; opacity:.9; margin-left:auto; }
    .an-back:hover { opacity:1; color:#fff; }

    .btn-g { background:linear-gradient(90deg,var(--grape),var(--grape-2)); color:#fff; border:none; padding:9px 18px; border-radius:8px; font-weight:700; cursor:pointer; font-size:.85rem; }
    .btn-o { background:#fff; border:1px solid var(--border); color:var(--ink); padding:8px 14px; border-radius:8px; font-weight:700; cursor:pointer; font-size:.82rem; }
    .btn-o:hover { border-color:var(--grape-2); color:var(--grape); }

    .an-card { background:#fff; border:1px solid var(--border); border-radius:13px; padding:16px 18px; margin-bottom:12px; box-shadow:0 4px 14px rgba(10,20,40,.04); position:relative; }
    .an-card.pinned { border-color:#f1d9a8; background:#fffdf6; }
    .an-pinflag { font-size:.7rem; font-weight:700; color:var(--amber); margin-bottom:6px; }
    .an-title { font-weight:800; color:var(--ink); font-size:1.02rem; margin-bottom:6px; }
    .an-body { color:#475467; font-size:.9rem; white-space:pre-wrap; line-height:1.5; }
    .an-meta { color:#98a2b3; font-size:.74rem; margin-top:10px; }
    .an-actions { position:absolute; top:14px; right:16px; display:flex; gap:6px; }
    .icon-btn { border:none; background:#f4f1fa; color:var(--grape); width:30px; height:30px; border-radius:8px; cursor:pointer; }
    .icon-btn.pin.on { background:#fef3d7; color:var(--amber); }
    .icon-btn.del { background:#fbe9ec; color:#dc3545; }
    .an-empty { text-align:center; color:var(--muted); padding:40px; background:#fff; border:1px dashed var(--border); border-radius:13px; }

    label.fl { font-weight:600; font-size:.82rem; color:#344054; margin-bottom:4px; display:block; }
    .fc { width:100%; padding:9px 11px; border:1px solid #d6d9e0; border-radius:8px; font-size:.9rem; }
    .fc:focus { outline:none; border-color:var(--grape-2); box-shadow:0 0 0 3px rgba(123,44,191,.12); }

    .ovl { position:fixed; inset:0; background:rgba(31,29,43,.5); display:none; align-items:flex-start; justify-content:center; z-index:1050; padding:50px 16px; }
    .ovl.show { display:flex; }
    .modal-card { background:#fff; border-radius:14px; width:100%; max-width:560px; box-shadow:0 20px 60px rgba(0,0,0,.25); }
    .modal-h { padding:16px 20px; border-bottom:1px solid var(--border); font-weight:800; color:var(--ink); }
    .modal-b { padding:18px 20px; } .modal-f { padding:14px 20px; border-top:1px solid var(--border); display:flex; gap:10px; justify-content:flex-end; }
</style>

<div class="an-wrap">
    <div class="an-head">
        <div>
            <h1><i class="fa-solid fa-bullhorn"></i> Announcements</h1>
            <div class="sub">@Model.CourseTitle</div>
        </div>
        <a href="@Url.Action("Index","Instructor")" class="an-back"><i class="fa-solid fa-arrow-left"></i> Back to panel</a>
    </div>

    <button class="btn-g" style="margin-bottom:16px;" onclick="openEditor()"><i class="fa-solid fa-plus"></i> New Announcement</button>

    <div id="anList"><div class="an-empty">Loading…</div></div>
</div>

<div class="ovl" id="anModal">
    <div class="modal-card">
        <div class="modal-h"><span id="anModalTitle">New Announcement</span></div>
        <div class="modal-b">
            <input type="hidden" id="anId" value="0" />
            <div style="margin-bottom:12px;">
                <label class="fl">Title *</label>
                <input id="anTitle" class="fc" placeholder="e.g. Live session this Friday" />
            </div>
            <div style="margin-bottom:12px;">
                <label class="fl">Message *</label>
                <textarea id="anBody" class="fc" rows="5" placeholder="Write your announcement…"></textarea>
            </div>
            <label style="display:flex;align-items:center;gap:8px;font-size:.85rem;">
                <input type="checkbox" id="anPin" /> Pin to top
            </label>
        </div>
        <div class="modal-f">
            <button class="btn-o" onclick="closeEditor()">Cancel</button>
            <button class="btn-g" onclick="save()"><i class="fa-solid fa-check"></i> Publish</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const COURSE_ID = @Model.CourseID;
        const U = {
            list:'@Url.Action("List","Announcement")', save:'@Url.Action("Save","Announcement")',
            del:'@Url.Action("Delete","Announcement")', pin:'@Url.Action("TogglePin","Announcement")'
        };
        const esc = s => (s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
        const truthy = v => v===true||v===1||v==='1';
        const postJson=(u,b)=>fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(r=>r.json());
        const ok = r => r.status==='Success'||r.Status==='Success';
        const toast=(i,t)=>Swal.mixin({toast:true,position:'top-end',showConfirmButton:false,timer:1700}).fire({icon:i,title:t});
        const fmtDate = d => d ? new Date(d).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '';

        let ITEMS = [];

        async function load() {
            const res = await fetch(U.list + '?courseId=' + COURSE_ID).then(r=>r.json());
            ITEMS = Array.isArray(res) ? res : [];
            const box = document.getElementById('anList');
            if (ITEMS.length === 0) { box.innerHTML = '<div class="an-empty"><i class="fa-solid fa-bullhorn" style="font-size:32px;color:#d6cfe6;"></i><p style="margin-top:10px;">No announcements yet.</p></div>'; return; }
            box.innerHTML = ITEMS.map(a => `
                <div class="an-card ${truthy(a.isPinned)?'pinned':''}">
                    ${truthy(a.isPinned)?'<div class="an-pinflag"><i class="fa-solid fa-thumbtack"></i> Pinned</div>':''}
                    <div class="an-title">${esc(a.title)}</div>
                    <div class="an-body">${esc(a.body)}</div>
                    <div class="an-meta">${a.createdBy?esc(a.createdBy)+' · ':''}${fmtDate(a.createdDate)}</div>
                    <div class="an-actions">
                        <button class="icon-btn pin ${truthy(a.isPinned)?'on':''}" title="Pin/unpin" onclick="togglePin(${a.announcementID}, ${truthy(a.isPinned)?0:1})"><i class="fa-solid fa-thumbtack"></i></button>
                        <button class="icon-btn" title="Edit" onclick="openEditor(${a.announcementID})"><i class="fa-solid fa-pen"></i></button>
                        <button class="icon-btn del" title="Delete" onclick="del(${a.announcementID})"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </div>`).join('');
        }

        function openEditor(id) {
            const a = id ? ITEMS.find(x=>x.announcementID===id) : null;
            document.getElementById('anId').value = a ? a.announcementID : 0;
            document.getElementById('anTitle').value = a ? a.title : '';
            document.getElementById('anBody').value = a ? a.body : '';
            document.getElementById('anPin').checked = a ? truthy(a.isPinned) : false;
            document.getElementById('anModalTitle').textContent = a ? 'Edit Announcement' : 'New Announcement';
            document.getElementById('anModal').classList.add('show');
        }
        function closeEditor(){ document.getElementById('anModal').classList.remove('show'); }

        async function save() {
            const title = document.getElementById('anTitle').value.trim();
            const body  = document.getElementById('anBody').value.trim();
            if (!title || !body) { toast('info','Title and message are required'); return; }
            const res = await postJson(U.save, {
                AnnouncementID: parseInt(document.getElementById('anId').value,10)||0,
                CourseID: COURSE_ID, Title: title, Body: body,
                IsPinned: document.getElementById('anPin').checked
            });
            if (ok(res)) { closeEditor(); toast('success','Saved'); load(); }
            else toast('error', res.message||res.Message||'Save failed');
        }

        async function togglePin(id, pin) {
            const res = await postJson(U.pin, { AnnouncementID:id, IsPinned: pin===1 });
            if (ok(res)) load(); else toast('error','Could not update');
        }

        async function del(id) {
            const c = await Swal.fire({icon:'warning',title:'Delete this announcement?',showCancelButton:true,confirmButtonColor:'#dc3545',confirmButtonText:'Delete'});
            if (!c.isConfirmed) return;
            const res = await postJson(U.del, { AnnouncementID:id });
            if (ok(res)) { toast('success','Deleted'); load(); } else toast('error','Delete failed');
        }

        document.getElementById('anModal').addEventListener('click', function(e){ if(e.target===this) closeEditor(); });
        load();
    </script>
}
