    .prx-co-header-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.65); margin: 0 0 3px; }
    .prx-co-course-name {
        font-size: .98rem; font-weight: 800; color: #fff;
