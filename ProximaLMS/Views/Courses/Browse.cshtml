<div class="br-shell">

    <!-- ╔═══════════════ HERO ═══════════════╗ -->
    <div class="br-hero">
        <div style="position:relative; z-index:1;">
            <h1>Discover your next course, @firstName 🚀</h1>
            <p>Free courses enroll instantly. Paid courses checkout through secure Razorpay — instant access.</p>
        </div>
        <span class="br-hero-badge">
            <i class="fas fa-shield-alt"></i> Secure checkout
        </span>
    </div>

    @if (TempData["Error"] != null)
    {
        <div style="background:#fee2e2;color:#dc2626;padding:12px 18px;border-radius:12px;font-size:14px;font-weight:600;margin-bottom:18px;">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    <!-- ╔═══════════════ STATS ═══════════════╗ -->
    <div class="br-stats">
        <div class="br-stat">
            <div class="br-stat-ico g"><i class="fas fa-circle-check"></i></div>
            <div>
                <div class="br-stat-val">@Model.AssignedCourses.Count</div>
                <div class="br-stat-lbl">My Courses</div>
            </div>
        </div>
        <div class="br-stat">
            <div class="br-stat-ico p"><i class="fas fa-store"></i></div>
            <div>
                <div class="br-stat-val">@Model.AllCourses.Count</div>
                <div class="br-stat-lbl">Available to enroll</div>
            </div>
        </div>
        <div class="br-stat">
            <div class="br-stat-ico r"><i class="fas fa-heart"></i></div>
            <div>
                <div class="br-stat-val" id="brWishStat">@wishCount</div>
                <div class="br-stat-lbl">In your wishlist</div>
            </div>
        </div>
        <div class="br-stat">
            <div class="br-stat-ico o"><i class="fas fa-layer-group"></i></div>
            <div>
                <div class="br-stat-val">@(Model.AllCourses.Count + Model.AssignedCourses.Count)</div>
                <div class="br-stat-lbl">Total in catalog</div>
            </div>
        </div>
    </div>

    <!-- ╔═══════════════ SEARCH ═══════════════╗ -->
    <div class="br-search-wrap">
        <i class="fas fa-search"></i>
        <input type="text" id="brSearch" placeholder="Search courses by title, tutor, level, language…" autocomplete="off" />
        <button class="br-search-clear" id="brSearchClear" type="button">
            <i class="fas fa-times me-1"></i> Clear
        </button>
    </div>

    <!-- ╔═══════════════ MY COURSES ═══════════════╗ -->
    <div class="br-sec" id="secAssigned">
        <div class="br-sec-head">
            <div class="br-sec-title">My Courses</div>
            <span class="br-sec-count" id="cntAssigned">@Model.AssignedCourses.Count enrolled</span>
        </div>

        @if (Model.AssignedCourses.Any())
        {
            <div class="br-grid" id="gridAssigned">
                @foreach (var c in Model.AssignedCourses)
                {
                    <div class="br-card js-card"
                         data-keys="@($"{c.CourseTitle} {c.TutorName} {Level(c.CourseLevelName)} {Lang(c.Language)}".ToLower())">
                        <div class="br-thumb">
                            <img src="@(string.IsNullOrEmpty(c.CoverImage) ? "/assets/images/noimage.png" : Url.Content("~/uploads/" + c.CoverImage))"
                                 alt="@c.CourseTitle"
                                 onerror="this.src='/assets/images/noimage.png';" />
                            <div class="br-thumb-overlay"></div>
                            <span class="br-owned-badge"><i class="fas fa-check"></i> Enrolled</span>
                        </div>
                        <div class="br-card-body">
                            <div class="br-card-title">@c.CourseTitle</div>
                            <div class="br-tutor"><i class="fas fa-user-tie"></i> @(string.IsNullOrEmpty(c.TutorName) ? "Instructor" : c.TutorName)</div>
                            <div class="br-chips">
                                <span class="br-chip lvl"><i class="fas fa-layer-group" style="font-size:9px;"></i>@Level(c.CourseLevelName)</span>
                                <span class="br-chip lang"><i class="fas fa-globe" style="font-size:9px;"></i>@Lang(c.Language)</span>
                            </div>
                            @if (c.ReviewCount > 0)
                            {
                                <div class="br-rating">
                                    <span class="br-stars">@Html.Raw(Stars(c.AvgRating))</span>
                                    <span class="br-rating-num">@c.AvgRating.ToString("0.0")</span>
                                    <span>(@c.ReviewCount)</span>
                                </div>
                            }
                            else
                            {
                                <div class="br-rating none">No reviews yet</div>
                            }
                            <div class="br-actions">
                                <a class="br-btn br-btn-continue"
                                   href="@Url.Action("Details", "Courses", new { id = c.CourseID })">
                                    <i class="fas fa-play"></i> Continue Learning
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="br-empty">
                <div class="br-empty-ico">📚</div>
                <h4>You haven't enrolled in any course yet</h4>
                <p>Browse the catalog below and unlock your first course in one click.</p>
            </div>
        }

        <div class="br-empty" id="emptyAssignedFilter" style="display:none;">
            <div class="br-empty-ico">🔎</div>
            <h4>No matches in your courses</h4>
            <p>Try a different search term — or look in the catalog below.</p>
        </div>
    </div>

    <!-- ╔═══════════════ ALL COURSES ═══════════════╗ -->
    <div class="br-sec" id="secCatalog" style="margin-top:18px;">
        <div class="br-sec-head">
            <div class="br-sec-title">All Courses</div>
            <span class="br-sec-count" id="cntCatalog">@Model.AllCourses.Count available</span>
        </div>

        @if (Model.AllCourses.Any())
        {
            @* ── FILTER BAR (Module 03) ────────────────────────────────────── *@
            <div class="bf-bar" role="group" aria-label="Catalog filters">
                <div class="bf-group">
                    <label class="bf-label" for="bfLevel">Level</label>
                    <select id="bfLevel" class="bf-select">
                        <option value="">All levels</option>
                        <option value="beginner">Beginner</option>
                        <option value="intermediate">Intermediate</option>
                        <option value="advanced">Advanced</option>
                    </select>
                </div>

                <div class="bf-group">
                    <label class="bf-label" for="bfLang">Language</label>
                    <select id="bfLang" class="bf-select">
                        <option value="">All languages</option>
                        <option value="english">English</option>
                        <option value="telugu">Telugu</option>
                        <option value="hindi">Hindi</option>
                    </select>
                </div>

                <div class="bf-group">
                    <label class="bf-label" for="bfPrice">Price</label>
                    <select id="bfPrice" class="bf-select">
                        <option value="">Any price</option>
                        <option value="free">Free only</option>
                        <option value="paid">Paid only</option>
                        <option value="lt500">Under &#8377;500</option>
                        <option value="500-2000">&#8377;500 &ndash; &#8377;2,000</option>
                        <option value="gt2000">Over &#8377;2,000</option>
                    </select>
                </div>

                <div class="bf-group">
                    <label class="bf-label" for="bfRating">Rating</label>
                    <select id="bfRating" class="bf-select">
                        <option value="">Any rating</option>
                        <option value="4">4&#9733; &amp; up</option>
                        <option value="3">3&#9733; &amp; up</option>
                        <option value="2">2&#9733; &amp; up</option>
                    </select>
                </div>

                <div class="bf-group">
                    <label class="bf-label" for="bfSort">Sort by</label>
                    <select id="bfSort" class="bf-select">
                        <option value="featured">Featured</option>
                        <option value="title-asc">Title (A &ndash; Z)</option>
                        <option value="title-desc">Title (Z &ndash; A)</option>
                        <option value="price-asc">Price (low &rarr; high)</option>
                        <option value="price-desc">Price (high &rarr; low)</option>
                        <option value="rating-desc">Highest rated</option>
                        <option value="reviews-desc">Most reviewed</option>
                    </select>
                </div>

                <div class="bf-actions">
                    <button type="button" class="bf-reset" id="bfReset" disabled title="Clear all filters">
                        <i class="fas fa-rotate-left" style="font-size:11px;"></i> Reset
                    </button>
                </div>
            </div>

            <div class="bf-status">
                Showing <strong id="bfShown">0</strong> of <strong id="bfTotal">0</strong> courses
                <span class="bf-chip" id="bfChip" style="display:none;">
                    <i class="fas fa-filter"></i> <span id="bfChipText">0 filters active</span>
                </span>
                <span class="bf-sort-tag" id="bfSortTag" style="display:none;">
                    Sorted by <b id="bfSortLabel"></b>
                </span>
            </div>

            <div class="br-grid" id="gridCatalog">
                @foreach (var c in Model.AllCourses)
                {
                    var isFree = c.Price <= 0;
                    var levelKey = Level(c.CourseLevelName).ToLower();
                    var langKey = Lang(c.Language).ToLower();
                    var priceStr = c.Price.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                    var ratingStr = c.AvgRating.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                    <div class="br-card js-card js-catalog"
                         data-keys="@($"{c.CourseTitle} {c.TutorName} {Level(c.CourseLevelName)} {Lang(c.Language)}".ToLower())"
                         data-title="@c.CourseTitle"
                         data-level="@levelKey"
                         data-lang="@langKey"
                         data-price="@priceStr"
                         data-rating="@ratingStr"
                         data-reviews="@c.ReviewCount">
                        <div class="br-thumb">
                            <img src="@(string.IsNullOrEmpty(c.CoverImage) ? "/assets/images/noimage.png" : Url.Content("~/uploads/" + c.CoverImage))"
                                 alt="@c.CourseTitle"
                                 onerror="this.src='/assets/images/noimage.png';" />
                            <div class="br-thumb-overlay"></div>

                            @* ── wishlist heart ── *@
                            <button type="button"
                                    class="br-heart js-wishlist @(c.IsWishlisted ? "is-wished" : "")"
                                    data-id="@c.CourseID"
                                    title="@(c.IsWishlisted ? "Remove from wishlist" : "Add to wishlist")">
                                <i class="@(c.IsWishlisted ? "fas" : "far") fa-heart"></i>
                            </button>

                            @if (isFree)
                            {
                                <span class="br-price-badge free"><i class="fas fa-gift" style="font-size:10px;"></i> FREE</span>
                            }
                            else
                            {
                                <span class="br-price-badge">&#8377;@c.Price.ToString("0.##")</span>
                            }
                        </div>
                        <div class="br-card-body">
                            <div class="br-card-title">@c.CourseTitle</div>
                            <div class="br-tutor"><i class="fas fa-user-tie"></i> @(string.IsNullOrEmpty(c.TutorName) ? "Instructor" : c.TutorName)</div>
                            <div class="br-chips">
                                <span class="br-chip lvl"><i class="fas fa-layer-group" style="font-size:9px;"></i>@Level(c.CourseLevelName)</span>
                                <span class="br-chip lang"><i class="fas fa-globe" style="font-size:9px;"></i>@Lang(c.Language)</span>
                            </div>
                            @if (c.ReviewCount > 0)
                            {
                                <div class="br-rating">
                                    <span class="br-stars">@Html.Raw(Stars(c.AvgRating))</span>
                                    <span class="br-rating-num">@c.AvgRating.ToString("0.0")</span>
                                    <span>(@c.ReviewCount)</span>
                                </div>
                            }
                            else
                            {
                                <div class="br-rating none">No reviews yet</div>
                            }
                            <div class="br-actions">
                                <a class="br-btn br-btn-ghost"
                                   href="@Url.Action("Preview", "Courses", new { id = c.CourseID })">
                                    <i class="fas fa-eye"></i> Preview
                                </a>

                                @if (isFree)
                                {
                                    <button type="button"
                                            class="br-btn br-btn-free js-enroll-free"
                                            data-id="@c.CourseID"
                                            data-title="@c.CourseTitle">
                                        <i class="fas fa-gift"></i> Enroll Free
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="br-btn br-btn-buy js-buy"
                                            data-id="@c.CourseID"
                                            data-price="@c.Price"
                                            data-title="@c.CourseTitle">
                                        <i class="fas fa-bolt"></i> Buy &#8377;@c.Price.ToString("0.##")
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="br-empty">
                <div class="br-empty-ico">🎉</div>
                <h4>You've enrolled in everything!</h4>
                <p>There are no more courses available in the catalog right now.</p>
            </div>
        }

        <div class="br-empty" id="emptyCatalogFilter" style="display:none;">
            <div class="br-empty-ico">🔎</div>
            <h4>No catalog matches</h4>
            <p>We couldn't find any course matching your filters. Try clearing some, or use the Reset button above.</p>
        </div>
    </div>

</div>

@* wishlist toast *@
<div class="br-toast" id="brToast"><i class="fas fa-heart"></i> <span id="brToastMsg"></span></div>


@* ────────── SweetAlert + Razorpay ────────── *@
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
    (function () {

        // ─── Razor-rendered URLs (avoids hardcoded paths) ────────────────────
        var URL_WISHLIST = '@Url.Action("ToggleWishlist", "Courses")';
        var URL_ENROLL = '@Url.Action("EnrollFree", "Courses")';
        var URL_ORDER = '@Url.Action("CreatePaymentOrder", "Courses")';
        var URL_VERIFY = '@Url.Action("VerifyPayment", "Courses")';
        var URL_MYCOURSES = '@Url.Action("List", "Courses")';
        var URL_COUPON = '@Url.Action("Validate", "Coupon")';
        var STUDENT_NAME = '@firstName';

        // ─── Checkout state ──────────────────────────────────────────────────
        var _ck = {};

        // ─── Helpers ─────────────────────────────────────────────────────────
        function busy(btn, label) {
            btn.disabled = true;
            // Only save original HTML on the FIRST busy call (don't overwrite with a
            // "Loading..." intermediate state — that's what caused the stuck button).
            if (!btn.dataset.origHtml) btn.dataset.origHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ' + label;
        }
        function unbusy(btn) {
            btn.disabled = false;
            if (btn.dataset.origHtml) {
                btn.innerHTML = btn.dataset.origHtml;
                delete btn.dataset.origHtml;
            }
        }

        function fmtPrice(n) { return '\u20B9' + parseFloat(n).toFixed(2); }

        function escHtml(s) {
            var d = document.createElement('div');
            d.textContent = s;
            return d.innerHTML;
        }

        // ─── Wishlist toast ───────────────────────────────────────────────────
        var toastEl = document.getElementById('brToast');
        var toastMsg = document.getElementById('brToastMsg');
        var toastTimer = null;
        function showToast(msg) {
            toastMsg.textContent = msg;
            toastEl.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(function () { toastEl.classList.remove('show'); }, 2400);
        }

        // ─── Live search (My Courses section only — catalog is owned by
        //                 the filter engine further down) ────────────────────
        var input = document.getElementById('brSearch');
        var clearBtn = document.getElementById('brSearchClear');
        var assignedCards = document.querySelectorAll('.js-card:not(.js-catalog)');
        var emptyA = document.getElementById('emptyAssignedFilter');
        var gridAssigned = document.getElementById('gridAssigned');
        var cntAssigned = document.getElementById('cntAssigned');

        function applyFilter() {
            var q = (input.value || '').toLowerCase().trim();
            clearBtn.style.display = q ? 'inline-flex' : 'none';

            var aVis = 0;
            assignedCards.forEach(function (card) {
                var match = !q || (card.dataset.keys || '').includes(q);
                card.style.display = match ? '' : 'none';
                if (match) aVis++;
            });

            if (gridAssigned) gridAssigned.style.display = aVis ? '' : 'none';
            if (emptyA) emptyA.style.display = (q && aVis === 0 && gridAssigned) ? 'block' : 'none';

            if (cntAssigned) cntAssigned.textContent = q
                ? aVis + ' match' + (aVis === 1 ? '' : 'es')
                : '@Model.AssignedCourses.Count enrolled';
        }

        if (input) input.addEventListener('input', applyFilter);
        if (clearBtn) clearBtn.addEventListener('click', function () {
            input.value = '';
            // Dispatch input so EVERY listener (assigned search + catalog filter
            // engine below) clears together.
            input.dispatchEvent(new Event('input', { bubbles: true }));
            input.focus();
        });

        // ─── Wishlist heart toggle ─────────────────────────────────────────────
        var wishStat = document.getElementById('brWishStat');
        function refreshWishStat() {
            if (wishStat) wishStat.textContent = document.querySelectorAll('.js-wishlist.is-wished').length;
        }

        document.querySelectorAll('.js-wishlist').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                var courseId = parseInt(this.dataset.id, 10);
                var icon = this.querySelector('i');
                var thisBtn = this;
                thisBtn.disabled = true;

                try {
                    var r = await fetch(URL_WISHLIST, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ CourseID: courseId })
                    });
                    var d = await r.json();

                    if (d.success) {
                        if (d.wishlisted) {
                            thisBtn.classList.add('is-wished');
                            icon.classList.remove('far'); icon.classList.add('fas');
                            thisBtn.title = 'Remove from wishlist';
                            showToast('Added to your wishlist');
                        } else {
                            thisBtn.classList.remove('is-wished');
                            icon.classList.remove('fas'); icon.classList.add('far');
                            thisBtn.title = 'Add to wishlist';
                            showToast('Removed from your wishlist');
                        }
                        refreshWishStat();
                    } else {
                        Swal.fire({ icon: 'error', title: 'Wishlist error', text: d.message || 'Please try again.', confirmButtonColor: '#4C1864' });
                    }
                } catch (err) {
                    Swal.fire({ icon: 'error', title: 'Network error', text: err.message, confirmButtonColor: '#4C1864' });
                } finally {
                    thisBtn.disabled = false;
                }
            });
        });

        // ─── FREE: instant enroll ─────────────────────────────────────────────
        document.querySelectorAll('.js-enroll-free').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                var courseId = parseInt(this.dataset.id, 10);
                var thisBtn = this;
                busy(thisBtn, 'Enrolling\u2026');

                try {
                    var r = await fetch(URL_ENROLL, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ CourseID: courseId })
                    });
                    var d = await r.json();

                    if (d.success) {
                        Swal.fire({
                            icon: 'success',
                            title: '\uD83C\uDF89 Enrolled!',
                            text: d.message || 'Course added to your library.',
                            confirmButtonColor: '#4C1864',
                            confirmButtonText: 'Open My Courses'
                        }).then(function () { window.location.href = URL_MYCOURSES; });
                    } else {
                        Swal.fire({ icon: 'error', title: 'Could not enroll', text: d.message || 'Please try again.', confirmButtonColor: '#4C1864' });
                        unbusy(thisBtn);
                    }
                } catch (err) {
                    Swal.fire({ icon: 'error', title: 'Network error', text: err.message, confirmButtonColor: '#4C1864' });
                    unbusy(thisBtn);
                }
            });
        });

        // ─── Checkout modal HTML builder ──────────────────────────────────────
        function buildCheckoutHtml(title, price) {
            return '<div class="prx-co-wrap">' +

                // ── Header banner ──
                '<div class="prx-co-header">' +
                  '<div class="prx-co-header-inner">' +
                    '<div class="prx-co-icon">🎓</div>' +
                    '<div>' +
                      '<p class="prx-co-header-label">Complete your purchase</p>' +
                      '<div class="prx-co-course-name">' + escHtml(title) + '</div>' +
                    '</div>' +
                  '</div>' +
                '</div>' +

                // ── Body ──
                '<div class="prx-co-body">' +

                  // Price breakdown
                  '<div class="prx-co-prices">' +
                    '<div class="prx-co-row">' +
                      '<span class="lbl"><i class="fa-solid fa-tag"></i> Course price</span>' +
                      '<span>' + fmtPrice(price) + '</span>' +
                    '</div>' +
                    '<div class="prx-co-row disc-row" id="prxDiscRow">' +
                      '<span class="lbl"><i class="fa-solid fa-circle-check"></i> Discount applied</span>' +
                      '<span class="prx-co-discount" id="prxDisc"></span>' +
                    '</div>' +
                    '<div class="prx-co-row final">' +
                      '<span class="lbl"><i class="fa-solid fa-receipt"></i> Total payable</span>' +
                      '<span id="prxTotal">' + fmtPrice(price) + '</span>' +
                    '</div>' +
                  '</div>' +

                  // Coupon
                  '<div class="prx-co-coupon-section">' +
                    '<p class="prx-co-coupon-label">Coupon / Referral Code</p>' +
                    '<div class="prx-co-coupon-row">' +
                      '<input type="text" id="prxCode" class="prx-co-coupon-input" placeholder="e.g. SAVE20 or PRX0042AB9" autocomplete="off" autocapitalize="characters" />' +
                      '<button type="button" class="prx-co-apply-btn" id="prxApply">Apply</button>' +
                    '</div>' +
                    '<div class="prx-co-msg" id="prxMsg"></div>' +
                  '</div>' +

                  // Secure badge
                  '<div class="prx-co-secure">' +
                    '<i class="fa-solid fa-lock"></i> 100% secure · Powered by Razorpay' +
                  '</div>' +

                '</div>' + // end .prx-co-body
            '</div>';
        }

        // ─── Apply coupon (called from inside Swal modal) ─────────────────────
        async function applyCoupon(courseId, originalPrice) {
            var code = (document.getElementById('prxCode').value || '').trim().toUpperCase();
            var msgEl = document.getElementById('prxMsg');

            if (!code) {
                msgEl.style.color = '#dc2626';
                msgEl.textContent = 'Please enter a coupon or referral code.';
                return;
            }

            var applyBtn = document.getElementById('prxApply');
            applyBtn.disabled = true;
            msgEl.style.color = '#6B7280';
            msgEl.textContent = 'Checking\u2026';

            try {
                var r = await fetch(URL_COUPON, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ Code: code, CourseID: courseId, OrderAmount: originalPrice })
                });
                var d = await r.json();

                if (d.success) {
                    _ck.couponCode = code;
                    _ck.couponId = d.couponId || 0;
                    _ck.discountAmount = d.discountAmount || 0;
                    _ck.finalAmount = d.finalAmount || originalPrice;

                    document.getElementById('prxDiscRow').classList.add('visible');
                    document.getElementById('prxDisc').textContent = '-' + fmtPrice(_ck.discountAmount);
                    document.getElementById('prxTotal').textContent = fmtPrice(_ck.finalAmount);
                    Swal.getConfirmButton().innerHTML = '<i class="fa-solid fa-lock" style="margin-right:6px;font-size:12px;"></i> Pay ' + fmtPrice(_ck.finalAmount);

                    msgEl.style.color = '#16A34A';
                    msgEl.innerHTML = '<i class="fa-solid fa-circle-check"></i> ' + (d.message || 'Coupon applied successfully!');
                } else {
                    // Reset to original price
                    _ck.couponCode = ''; _ck.couponId = 0;
                    _ck.discountAmount = 0; _ck.finalAmount = originalPrice;

                    document.getElementById('prxDiscRow').classList.remove('visible');
                    document.getElementById('prxTotal').textContent = fmtPrice(originalPrice);
                    Swal.getConfirmButton().innerHTML = '<i class="fa-solid fa-lock" style="margin-right:6px;font-size:12px;"></i> Pay ' + fmtPrice(originalPrice);

                    msgEl.style.color = '#dc2626';
                    msgEl.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> ' + (d.message || 'Invalid or expired coupon.');
                }
            } catch (e) {
                msgEl.style.color = '#dc2626';
                msgEl.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> Could not validate code. Try again.';
            } finally {
                applyBtn.disabled = false;
            }
        }

        // ─── Full checkout + Razorpay flow ────────────────────────────────────
        async function launchCheckout(thisBtn, courseId, courseTitle, coursePrice) {
            // Reset checkout state for this session
            _ck = {
                couponCode: '', couponId: 0,
                discountAmount: 0, finalAmount: coursePrice
            };

            // Step 1: Show checkout modal
            var result = await Swal.fire({
                width: 480,
                padding: 0,
                html: buildCheckoutHtml(courseTitle, coursePrice),
                confirmButtonText: '<i class="fa-solid fa-lock" style="margin-right:6px;font-size:12px;"></i> Pay ' + fmtPrice(coursePrice),
                showCancelButton: true,
                cancelButtonText: 'Cancel',
                focusConfirm: false,
                customClass: { popup: 'swal2-prx-checkout', confirmButton: '', cancelButton: '' },
                buttonsStyling: true,
                didOpen: function () {
                    var applyBtn = document.getElementById('prxApply');
                    var codeInput = document.getElementById('prxCode');
                    if (applyBtn) applyBtn.addEventListener('click', function () { applyCoupon(courseId, coursePrice); });
                    if (codeInput) codeInput.addEventListener('keydown', function (e) {
                        if (e.key === 'Enter') { e.preventDefault(); applyCoupon(courseId, coursePrice); }
                    });
                },
                preConfirm: function () { return { ..._ck }; }
            });

            if (!result.isConfirmed || !result.value) {
                unbusy(thisBtn);
                return;
            }

            var ck = result.value;
            busy(thisBtn, 'Preparing payment\u2026');

            // Step 2: Create Razorpay order (server validates coupon again)
            try {
                var r1 = await fetch(URL_ORDER, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        CourseID: courseId,
                        CouponCode: ck.couponCode || null
                    })
                });
                var d1 = await r1.json();

                if (!d1.success) {
                    Swal.fire({ icon: 'error', title: 'Cannot start payment', text: d1.message || 'Please try again.', confirmButtonColor: '#4C1864' });
                    unbusy(thisBtn);
                    return;
                }

                // Use authoritative values from the API (server re-validated the coupon)
                var apiCouponId = d1.couponId || 0;
                var apiDiscount = d1.discountAmount || 0;
                var apiOriginal = d1.originalAmount || coursePrice;

                // Step 3: Open Razorpay for the discounted amount
                var rzp = new Razorpay({
                    key: d1.keyId,
                    amount: d1.amount,       // paise — already discounted by API
                    currency: d1.currency || 'INR',
                    name: 'ProximaLMS',
                    description: d1.courseName || courseTitle,
                    order_id: d1.orderId,
                    prefill: { name: STUDENT_NAME },
                    theme: { color: '#4C1864' },

                    // Step 4: On success, verify + enroll
                    handler: async function (resp) {
                        var r2 = await fetch(URL_VERIFY, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                CourseID: courseId,
                                RazorpayOrderId: resp.razorpay_order_id,
                                RazorpayPaymentId: resp.razorpay_payment_id,
                                RazorpaySignature: resp.razorpay_signature,
                                CouponID: apiCouponId,
                                DiscountAmount: apiDiscount,
                                OriginalAmount: apiOriginal
                            })
                        });
                        var d2 = await r2.json();

                        if (d2.success) {
                            var successText = 'Your course has been added to \u201CMy Courses\u201D.';
                            if (apiDiscount > 0)
                                successText += ' You saved ' + fmtPrice(apiDiscount) + '!';

                            Swal.fire({
                                icon: 'success',
                                title: '\uD83C\uDF89 Course unlocked!',
                                text: successText,
                                confirmButtonColor: '#4C1864',
                                confirmButtonText: 'Open My Courses'
                            }).then(function () { window.location.href = URL_MYCOURSES; });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Verification failed', text: d2.message || 'We could not verify your payment.', confirmButtonColor: '#4C1864' });
                            unbusy(thisBtn);
                        }
                    },

                    modal: { ondismiss: function () { unbusy(thisBtn); } }
                });

                rzp.on('payment.failed', function (resp) {
                    Swal.fire({ icon: 'error', title: 'Payment failed', text: resp?.error?.description || 'Please try again.', confirmButtonColor: '#4C1864' });
                    unbusy(thisBtn);
                });

                rzp.open();
            }
            catch (err) {
                Swal.fire({ icon: 'error', title: 'Network error', text: err.message, confirmButtonColor: '#4C1864' });
                unbusy(thisBtn);
            }
        }

        // ─── PAID: attach checkout flow to every Buy button ───────────────────
        document.querySelectorAll('.js-buy').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var courseId = parseInt(this.dataset.id, 10);
                var courseTitle = this.dataset.title || 'Course';
                var price = parseFloat(this.dataset.price) || 0;
                var thisBtn = this;

                busy(thisBtn, 'Loading\u2026');
                launchCheckout(thisBtn, courseId, courseTitle, price);
            });
        });

        // ════════════════════════════════════════════════════════════════════
        // CATALOG FILTER + SORT ENGINE  (Module 03)
        // ────────────────────────────────────────────────────────────────────
        // Owns the catalog grid entirely. Hooks the same #brSearch input as
        // the My-Courses filter above — both fire on the input event, but
        // they operate on different card sets so they don't conflict.
        // ════════════════════════════════════════════════════════════════════
        (function () {
            var grid = document.getElementById('gridCatalog');
            if (!grid) return;          // catalog empty → nothing to filter

            var fSearch = document.getElementById('brSearch');     // existing keyword input
            var fLevel = document.getElementById('bfLevel');
            var fLang = document.getElementById('bfLang');
            var fPrice = document.getElementById('bfPrice');
            var fRating = document.getElementById('bfRating');
            var fSort = document.getElementById('bfSort');
            var bReset = document.getElementById('bfReset');

            var elShown = document.getElementById('bfShown');
            var elTotal = document.getElementById('bfTotal');
            var elChip = document.getElementById('bfChip');
            var elChipTxt = document.getElementById('bfChipText');
            var elSortTag = document.getElementById('bfSortTag');
            var elSortLbl = document.getElementById('bfSortLabel');

            var cntCatalog = document.getElementById('cntCatalog');
            var emptyC = document.getElementById('emptyCatalogFilter');

            // Cache cards in their original (server) order
            var allCards = Array.prototype.slice.call(grid.querySelectorAll('.js-card.js-catalog'));
            var originalOrder = allCards.slice();
            var totalCount = allCards.length;
            elTotal.textContent = totalCount;

            function priceBucket(p) {
                if (isNaN(p)) return 'free';
                if (p <= 0) return 'free';
                if (p < 500) return 'lt500';
                if (p <= 2000) return '500-2000';
                return 'gt2000';
            }

            function priceMatches(card, mode) {
                if (!mode) return true;
                var p = parseFloat(card.dataset.price || '0');
                if (mode === 'paid') return p > 0;
                if (mode === 'free') return p <= 0;
                return priceBucket(p) === mode;
            }

            function matches(card) {
                var q = (fSearch && fSearch.value || '').toLowerCase().trim();
                if (q && (card.dataset.keys || '').indexOf(q) === -1) return false;

                if (fLevel.value && card.dataset.level !== fLevel.value) return false;
                if (fLang.value && card.dataset.lang !== fLang.value) return false;
                if (!priceMatches(card, fPrice.value)) return false;

                var minR = parseFloat(fRating.value || '0');
                if (minR && parseFloat(card.dataset.rating || '0') < minR) return false;

                return true;
            }

            function compare(a, b) {
                switch (fSort.value) {
                    case 'title-asc':
                        return (a.dataset.title || '').localeCompare(b.dataset.title || '');
                    case 'title-desc':
                        return (b.dataset.title || '').localeCompare(a.dataset.title || '');
                    case 'price-asc':
                        return parseFloat(a.dataset.price || '0') - parseFloat(b.dataset.price || '0');
                    case 'price-desc':
                        return parseFloat(b.dataset.price || '0') - parseFloat(a.dataset.price || '0');
                    case 'rating-desc':
                        return parseFloat(b.dataset.rating || '0') - parseFloat(a.dataset.rating || '0');
                    case 'reviews-desc':
                        return parseInt(b.dataset.reviews || '0', 10) - parseInt(a.dataset.reviews || '0', 10);
                }
                return 0;
            }

            var SORT_LABEL = {
                'title-asc': 'title (A\u2013Z)',
                'title-desc': 'title (Z\u2013A)',
                'price-asc': 'price, low to high',
                'price-desc': 'price, high to low',
                'rating-desc': 'highest rated',
                'reviews-desc': 'most reviewed'
            };

            function activeFilterCount() {
                var n = 0;
                if ((fSearch && fSearch.value || '').trim()) n++;
                if (fLevel.value) n++;
                if (fLang.value) n++;
                if (fPrice.value) n++;
                if (fRating.value) n++;
                return n;
            }

            function markActiveSelects() {
                [fLevel, fLang, fPrice, fRating].forEach(function (sel) {
                    sel.classList.toggle('is-active', !!sel.value);
                });
                fSort.classList.toggle('is-active', fSort.value && fSort.value !== 'featured');
            }

            function applyCatalog() {
                // 1. Filter
                var visible = allCards.filter(matches);

                // 2. Sort (or restore original order)
                var ordered = (fSort.value && fSort.value !== 'featured')
                    ? visible.slice().sort(compare)
                    : originalOrder.filter(function (c) { return visible.indexOf(c) !== -1; });

                // 3. Apply to DOM — set display + reorder via appendChild
                allCards.forEach(function (c) { c.style.display = 'none'; });
                var frag = document.createDocumentFragment();
                ordered.forEach(function (c) {
                    c.style.display = '';
                    frag.appendChild(c);
                });
                grid.appendChild(frag);

                // 4. Status / chip / counts
                elShown.textContent = ordered.length;

                var n = activeFilterCount();
                if (n > 0) {
                    elChipTxt.textContent = n + (n === 1 ? ' filter active' : ' filters active');
                    elChip.style.display = 'inline-flex';
                    bReset.disabled = false;
                } else {
                    elChip.style.display = 'none';
                    bReset.disabled = !fSort.value || fSort.value === 'featured';
                }

                if (fSort.value && fSort.value !== 'featured') {
                    elSortLbl.textContent = SORT_LABEL[fSort.value] || fSort.value;
                    elSortTag.style.display = '';
                    bReset.disabled = false;
                } else {
                    elSortTag.style.display = 'none';
                }

                // 5. External counter (the pill on the section header)
                if (cntCatalog) {
                    cntCatalog.textContent = (n > 0 || (fSort.value && fSort.value !== 'featured'))
                        ? (ordered.length + ' of ' + totalCount + ' shown')
                        : (totalCount + ' available');
                }

                // 6. Empty state
                if (emptyC) emptyC.style.display = (ordered.length === 0 && n > 0) ? 'block' : 'none';
                grid.style.display = ordered.length ? '' : 'none';

                markActiveSelects();
            }

            // Wiring
            [fLevel, fLang, fPrice, fRating, fSort].forEach(function (el) {
                el.addEventListener('change', applyCatalog);
            });
            // Same #brSearch input drives BOTH the My-Courses filter and this one
            if (fSearch) fSearch.addEventListener('input', applyCatalog);

            bReset.addEventListener('click', function () {
                fLevel.value = '';
                fLang.value = '';
                fPrice.value = '';
                fRating.value = '';
                fSort.value = 'featured';
                if (fSearch) {
                    fSearch.value = '';
                    // Triggers the assigned-search applyFilter() too
                    fSearch.dispatchEvent(new Event('input', { bubbles: true }));
                }
                applyCatalog();
            });

            // Initial pass (sets total, paints status row)
            applyCatalog();
        })();

    })();
</script>
