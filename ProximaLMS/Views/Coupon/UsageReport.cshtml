@model IEnumerable<ProximaLMS.Controllers.CouponUsageReportViewModel>
@{
    ViewData["Title"] = "Coupon Usage & Analytics";
    Layout = "_Layout";

    var rows            = Model?.ToList() ?? new List<ProximaLMS.Controllers.CouponUsageReportViewModel>();
    var totalRedeemed   = rows.Sum(r => r.TimesRedeemed);
    var totalUsers      = rows.Sum(r => r.UniqueUsers);
    var totalDiscount   = rows.Sum(r => r.TotalDiscountGiven);
    var totalGross      = rows.Sum(r => r.GrossOrderValue);
    var totalNet        = rows.Sum(r => r.NetRevenue);
}

<style>
    :root {
        --primary: #4C1864;
        --secondary: #7B2CBF;
        --bg: #f4f6fb;
    }

    .ur-wrap { padding: 10px; background: var(--bg); }

    .ur-header {
        background: #fff;
        padding: 20px 25px;
        box-shadow: 0 8px 30px rgba(0,0,0,.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .ur-title { font-size: 22px; font-weight: 700; color: var(--primary); margin: 0; }
    .ur-sub   { font-size: 13px; color: #8a8f9c; margin-top: 3px; }

    .btn-ghost {
        border: 1px solid var(--primary);
        color: var(--primary) !important;
        background: #fff;
        padding: 9px 18px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .ur-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 22px;
    }

    .ur-stat {
        background: #fff;
        border-radius: 14px;
        padding: 18px 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        border-left: 4px solid var(--secondary);
    }
    .ur-stat .lbl { font-size: 12px; color: #8a8f9c; text-transform: uppercase; letter-spacing: .05em; font-weight: 600; }
    .ur-stat .val { font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 6px; }

    .ur-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .ur-toolbar { padding: 16px 20px; border-bottom: 1px solid #eef0f5; }
    .ur-search {
        width: 280px; max-width: 100%;
        padding: 9px 14px;
        border: 1px solid #dde1ea;
        border-radius: 8px;
        font-size: 14px;
    }

    table.ur-table { width: 100%; border-collapse: collapse; }
    table.ur-table thead th {
        background: #faf7fc;
        color: var(--primary);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: .04em;
        padding: 13px 14px;
        text-align: left;
        border-bottom: 2px solid #eef0f5;
        white-space: nowrap;
    }
    table.ur-table tbody td {
        padding: 13px 14px;
        font-size: 14px;
        border-bottom: 1px solid #f1f2f6;
        color: #3b3f4a;
    }
    table.ur-table tbody tr:hover { background: #faf9fc; }
    table.ur-table tfoot td {
        padding: 13px 14px;
        font-size: 14px;
        font-weight: 700;
        color: var(--primary);
        background: #faf7fc;
        border-top: 2px solid #eef0f5;
    }

    .num { text-align: right; font-variant-numeric: tabular-nums; }

    .code-pill {
        font-family: 'Courier New', monospace;
        font-weight: 700;
        background: #f1eaf6;
        color: var(--primary);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 13px;
    }

    .tag {
        font-size: 11px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: .03em;
    }
    .tag-percent  { background: #e7f1ff; color: #1d4ed8; }
    .tag-flat     { background: #e8f8ee; color: #137a3e; }
    .tag-admin    { background: #f1eaf6; color: #6b21a8; }
    .tag-referral { background: #fff3e0; color: #b45309; }

    .ur-empty { padding: 50px 20px; text-align: center; color: #9aa0ac; }
    .ur-empty i { font-size: 40px; margin-bottom: 12px; color: #d8dbe3; }
</style>

<div class="ur-wrap">

    <div class="ur-header">
        <div>
            <h2 class="ur-title"><i class="fas fa-chart-line"></i> Coupon Usage &amp; Analytics</h2>
            <div class="ur-sub">Redemption and revenue impact across all coupons</div>
        </div>
        <a class="btn-ghost" asp-controller="Coupon" asp-action="List">
            <i class="fas fa-arrow-left"></i> Back to Coupons
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="ur-stats">
        <div class="ur-stat">
            <div class="lbl">Total Redemptions</div>
            <div class="val">@totalRedeemed</div>
        </div>
        <div class="ur-stat">
            <div class="lbl">Unique Users</div>
            <div class="val">@totalUsers</div>
        </div>
        <div class="ur-stat">
            <div class="lbl">Discount Given</div>
            <div class="val">&#8377;@totalDiscount.ToString("N0")</div>
        </div>
        <div class="ur-stat">
            <div class="lbl">Gross Order Value</div>
            <div class="val">&#8377;@totalGross.ToString("N0")</div>
        </div>
        <div class="ur-stat">
            <div class="lbl">Net Revenue</div>
            <div class="val">&#8377;@totalNet.ToString("N0")</div>
        </div>
    </div>

    <div class="ur-card">
        <div class="ur-toolbar">
            <input type="text" id="urSearch" class="ur-search"
                   placeholder="Search by coupon code..." onkeyup="filterRows()" />
        </div>

        @if (!rows.Any())
        {
            <div class="ur-empty">
                <i class="fas fa-chart-pie"></i>
                <div>No coupon usage recorded yet.</div>
            </div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="ur-table" id="urTable">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Type</th>
                            <th>Source</th>
                            <th class="num">Times Redeemed</th>
                            <th class="num">Unique Users</th>
                            <th class="num">Usage Limit</th>
                            <th class="num">Discount Given</th>
                            <th class="num">Gross Value</th>
                            <th class="num">Net Revenue</th>
                            <th>Last Used</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in rows)
                        {
                            var typeClass = string.Equals(r.DiscountType, "PERCENT", StringComparison.OrdinalIgnoreCase)
                                            ? "tag-percent" : "tag-flat";
                            var srcClass  = string.Equals(r.Source, "REFERRAL", StringComparison.OrdinalIgnoreCase)
                                            ? "tag-referral" : "tag-admin";
                            var limitText = r.MaxUses > 0 ? r.MaxUses.ToString() : "Unlimited";
                            <tr>
                                <td><span class="code-pill">@r.Code</span></td>
                                <td>
                                    <span class="tag @typeClass">
                                        @r.DiscountType
                                        @(string.Equals(r.DiscountType, "PERCENT", StringComparison.OrdinalIgnoreCase)
                                            ? $" {r.DiscountValue:0.##}%"
                                            : $" \u20B9{r.DiscountValue:0.##}")
                                    </span>
                                </td>
                                <td><span class="tag @srcClass">@r.Source</span></td>
                                <td class="num">@r.TimesRedeemed</td>
                                <td class="num">@r.UniqueUsers</td>
                                <td class="num">@limitText</td>
                                <td class="num">&#8377;@r.TotalDiscountGiven.ToString("N0")</td>
                                <td class="num">&#8377;@r.GrossOrderValue.ToString("N0")</td>
                                <td class="num">&#8377;@r.NetRevenue.ToString("N0")</td>
                                <td>@(r.LastUsedDate.HasValue ? r.LastUsedDate.Value.ToString("dd MMM yyyy") : "—")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3">Total (@rows.Count coupons)</td>
                            <td class="num">@totalRedeemed</td>
                            <td class="num">@totalUsers</td>
                            <td class="num">—</td>
                            <td class="num">&#8377;@totalDiscount.ToString("N0")</td>
                            <td class="num">&#8377;@totalGross.ToString("N0")</td>
                            <td class="num">&#8377;@totalNet.ToString("N0")</td>
                            <td>—</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function filterRows() {
            const q = document.getElementById('urSearch').value.toLowerCase();
            document.querySelectorAll('#urTable tbody tr').forEach(function (tr) {
                tr.style.display = tr.innerText.toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
}
