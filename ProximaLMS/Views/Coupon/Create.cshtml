@model ProximaLMS.Controllers.CouponFormViewModel
@{
    var isEdit = Model.CouponID > 0;
    ViewData["Title"] = isEdit ? "Edit Coupon" : "Create Coupon";
    Layout = "_Layout";
}

<style>
    :root {
        --primary: #4C1864;
        --secondary: #7B2CBF;
        --bg: #f4f6fb;
    }

    .cf-wrap { padding: 10px; background: var(--bg); }

    .cf-header {
        background: #fff;
        padding: 20px 25px;
        box-shadow: 0 8px 30px rgba(0,0,0,.05);
        margin-bottom: 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .cf-title { font-size: 22px; font-weight: 700; color: var(--primary); margin: 0; }

    .cf-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        padding: 28px 30px;
        max-width: 880px;
    }

    .cf-section-title {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--secondary);
        margin: 22px 0 14px;
        padding-bottom: 6px;
        border-bottom: 2px solid #f0e8f8;
    }
    .cf-section-title:first-child { margin-top: 0; }

    .cf-label { font-weight: 600; font-size: 13px; color: #344054; margin-bottom: 5px; }
    .cf-hint  { font-size: 11.5px; color: #98a2b3; margin-top: 3px; }

    .cf-input, .cf-select {
        width: 100%;
        padding: 9px 12px;
        border: 1px solid #d6d9e0;
        border-radius: 8px;
        font-size: 14px;
    }
    .cf-input:focus, .cf-select:focus {
        outline: none;
        border-color: var(--secondary);
        box-shadow: 0 0 0 3px rgba(123,44,191,.12);
    }

    .field-error { color: #dc3545; font-size: 12px; margin-top: 3px; display: block; }

    .cf-actions {
        margin-top: 26px;
        padding-top: 18px;
        border-top: 1px solid #eef0f5;
        display: flex;
        gap: 12px;
    }

    .btn-grad {
        background: linear-gradient(90deg,var(--primary),var(--secondary));
        color: #fff;
        border: none;
        padding: 10px 24px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
    }
    .btn-cancel {
        background: #fff;
        border: 1px solid #d6d9e0;
        color: #475467;
        padding: 10px 24px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
    }

    .switch-row { display: flex; align-items: center; gap: 10px; margin-top: 6px; }
</style>

<div class="cf-wrap">

    <div class="cf-header">
        <h4 class="cf-title">
            <i class="fa-solid fa-ticket me-2"></i>@(isEdit ? "Edit Coupon" : "Create Coupon")
        </h4>
        <a href="@Url.Action("List","Coupon")" class="btn-cancel">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to list
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="cf-card">
        <form asp-action="Create" asp-controller="Coupon" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CouponID" />

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <div class="cf-section-title">Coupon Basics</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="cf-label">Coupon Code</label>
                    <input asp-for="Code" class="cf-input" placeholder="e.g. WELCOME20"
                           style="text-transform:uppercase;" autocomplete="off" />
                    <span asp-validation-for="Code" class="field-error"></span>
                    <div class="cf-hint">Letters and numbers. Shown to students at checkout.</div>
                </div>
                <div class="col-md-6">
                    <label class="cf-label">Applies To</label>
                    <select asp-for="CourseID" class="cf-select">
                        <option value="">All courses (global)</option>
                        @foreach (var course in Model.Courses)
                        {
                            <option value="@course.CourseID">@course.CourseTitle</option>
                        }
                    </select>
                    <div class="cf-hint">Leave as "All courses" for a platform-wide coupon.</div>
                </div>
            </div>

            <div class="cf-section-title">Discount</div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="cf-label">Discount Type</label>
                    <select asp-for="DiscountType" class="cf-select" id="discountType">
                        <option value="PERCENT">Percentage (%)</option>
                        <option value="FLAT">Flat amount (₹)</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="cf-label" id="discValueLabel">Discount Value</label>
                    <input asp-for="DiscountValue" type="number" step="0.01" min="0" class="cf-input" />
                    <span asp-validation-for="DiscountValue" class="field-error"></span>
                </div>
                <div class="col-md-4" id="maxDiscWrap">
                    <label class="cf-label">Max Discount Cap (₹)</label>
                    <input asp-for="MaxDiscountAmount" type="number" step="0.01" min="0" class="cf-input"
                           placeholder="Optional" />
                    <div class="cf-hint">Caps a percentage discount. Ignored for flat coupons.</div>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <label class="cf-label">Minimum Order Amount (₹)</label>
                    <input asp-for="MinOrderAmount" type="number" step="0.01" min="0" class="cf-input" />
                    <span asp-validation-for="MinOrderAmount" class="field-error"></span>
                    <div class="cf-hint">0 means no minimum.</div>
                </div>
            </div>

            <div class="cf-section-title">Validity & Limits</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="cf-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="cf-input" />
                    <span asp-validation-for="StartDate" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="cf-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="cf-input" />
                    <span asp-validation-for="EndDate" class="field-error"></span>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label class="cf-label">Total Usage Limit</label>
                    <input asp-for="MaxUses" type="number" min="0" class="cf-input" />
                    <span asp-validation-for="MaxUses" class="field-error"></span>
                    <div class="cf-hint">0 means unlimited redemptions.</div>
                </div>
                <div class="col-md-6">
                    <label class="cf-label">Per-User Limit</label>
                    <input asp-for="MaxUsesPerUser" type="number" min="1" class="cf-input" />
                    <span asp-validation-for="MaxUsesPerUser" class="field-error"></span>
                    <div class="cf-hint">How many times a single user can use this coupon.</div>
                </div>
            </div>

            <div class="cf-section-title">Status</div>
            <div class="switch-row">
                <div class="form-check form-switch">
                    <input asp-for="IsActive" class="form-check-input" role="switch" />
                </div>
                <label asp-for="IsActive" class="cf-label mb-0">Coupon is active</label>
            </div>

            <div class="cf-actions">
                <button type="submit" class="btn-grad">
                    <i class="fa-solid fa-floppy-disk me-1"></i>
                    @(isEdit ? "Update Coupon" : "Create Coupon")
                </button>
                <a href="@Url.Action("List","Coupon")" class="btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // toggle max-discount field + label by discount type
        function syncDiscountUI() {
            const type = document.getElementById("discountType").value;
            const maxWrap = document.getElementById("maxDiscWrap");
            const label = document.getElementById("discValueLabel");
            if (type === "PERCENT") {
                maxWrap.style.display = "";
                label.textContent = "Discount Value (%)";
            } else {
                maxWrap.style.display = "none";
                label.textContent = "Discount Value (₹)";
            }
        }
        document.getElementById("discountType").addEventListener("change", syncDiscountUI);
        syncDiscountUI();
    </script>
}
