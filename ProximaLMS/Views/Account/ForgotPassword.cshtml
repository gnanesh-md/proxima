@model ProximaLMS.Models.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Forgot Password - Proxima LMS</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f4f6fb;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: Inter, sans-serif;
        }

        .box {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 30px 60px rgba(0,0,0,.12);
            display: flex;
            max-width: 900px;
            width: 100%;
            overflow: hidden;
        }

        .left {
            width: 45%;
            background: linear-gradient(135deg,#ffffff, #a379c8);
            color: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 40px;
        }

        .right {
            width: 55%;
            padding: 50px;
        }

        .btn-main {
            background: #4c1864;
            color: #fff;
            height: 48px;
            border-radius: 10px;
            border: none;
        }

        .otp-box {
            width: 55px;
            height: 55px;
            text-align: center;
            font-size: 22px;
            border-radius: 8px;
            border: 2px solid #4c1864;
        }
    </style>
</head>

<body>

    <div class="box">

        <div class="left">
            <div>
                <h2>Forgot Password?</h2>
                <p>We’ll help you reset it securely</p>
            </div>
        </div>

        <div class="right">

            <!-- ================= EMAIL ================= -->
            @if (ViewBag.ShowOtpPanel != true && ViewBag.ShowResetPanel != true)
            {
                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()

                    <h4 class="mb-3">Reset Password</h4>

                    <input asp-for="Email"
                           class="form-control mb-3"
                           placeholder="Registered Email" />

                    <span asp-validation-for="Email" class="text-danger small"></span>

                    <button class="btn btn-main w-100">Send OTP</button>

                    <div class="text-center mt-3">
                        <a href="/Login/Index" style="color:#4c1864;">← Back to Login</a>
                    </div>
                </form>
            }

            <!-- ================= OTP ================= -->
            @if (ViewBag.ShowOtpPanel == true)
            {
                <form asp-action="VerifyOtp" method="post" id="otpForm">
                    @Html.AntiForgeryToken()

                    <p class="text-center">
                        OTP sent to <b>@TempData.Peek("Email")</b>
                    </p>

                    <div class="d-flex justify-content-center gap-2 mb-3">
                        @for (int i = 0; i < 6; i++)
                        {
                            <input type="text"
                                   maxlength="1"
                                   inputmode="numeric"
                                   class="otp-box" />
                        }
                    </div>

                    <input type="hidden" id="otpInput" name="otpInput" />
                    <div id="otpError" class="text-danger text-center mb-2">
                        @TempData["ForgotError"]
                    </div>

                    <button class="btn btn-main w-100">Verify OTP</button>
                </form>

                <div class="text-center mt-3">
                    <small id="countdownText"></small><br />
                    <form asp-action="ResendOtp" method="post" id="resendForm" class="d-none">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-link">Resend OTP</button>
                    </form>
                </div>
            }

            <!-- ================= RESET PASSWORD ================= -->
            @if (ViewBag.ShowResetPanel == true)
            {
                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()

                    <h5 class="mb-3">Create New Password</h5>

                    <input name="NewPassword" type="password"
                           class="form-control mb-3"
                           placeholder="New Password" required />

                    <input name="ConfirmPassword" type="password"
                           class="form-control mb-3"
                           placeholder="Confirm Password" required />

                    <button class="btn btn-main w-100">Update Password</button>
                </form>
            }

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        /* ================= OTP AUTO MOVE + TIMER ================= */
        let seconds = 60;
        let timer;

        function startTimer() {
            seconds = 60;
            document.getElementById("resendForm")?.classList.add("d-none");

            timer = setInterval(() => {
                document.getElementById("countdownText").innerText =
                    `Resend OTP in ${seconds--}s`;

                if (seconds < 0) {
                    clearInterval(timer);
                    document.getElementById("countdownText").innerText =
                        "Didn’t receive OTP?";
                    document.getElementById("resendForm")?.classList.remove("d-none");
                }
            }, 1000);
        }

        function initOtpBoxes() {
            const boxes = document.querySelectorAll(".otp-box");

            boxes.forEach((box, index) => {

                box.addEventListener("input", () => {
                    box.value = box.value.replace(/\D/g, "");
                    if (box.value && index < boxes.length - 1)
                        boxes[index + 1].focus();
                });

                box.addEventListener("keydown", e => {
                    if (e.key === "Backspace" && !box.value && index > 0)
                        boxes[index - 1].focus();
                });

                box.addEventListener("paste", e => {
                    e.preventDefault();
                    const paste = e.clipboardData.getData("text").replace(/\D/g, "");
                    paste.split("").forEach((c, i) => boxes[i].value = c);
                    boxes[Math.min(paste.length, 6) - 1]?.focus();
                });
            });

            boxes[0]?.focus();
        }

        document.getElementById("otpForm")?.addEventListener("submit", e => {
            let otp = "";
            document.querySelectorAll(".otp-box").forEach(b => otp += b.value);

            if (otp.length !== 6) {
                e.preventDefault();
                document.getElementById("otpError").innerText =
                    "Please enter 6 digit OTP";
                return;
            }
            document.getElementById("otpInput").value = otp;
        });

        document.addEventListener("DOMContentLoaded", function () {

            initOtpBoxes();
            startTimer();

            const success = "@TempData["ForgotSuccess"]";
            const error = "@TempData["ForgotError"]";
            const redirect = "@(ViewBag.RedirectToLogin ?? false)".toLowerCase();

            if (success) {
                Swal.fire({
                    icon: "success",
                    title: "Success",
                    text: success,
                    confirmButtonColor: "#4c1864"
                }).then(() => {
                    if (redirect === "true") {
                        window.location.href = "/Login/Index";
                    }
                });
            }

            if (error) {
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: error,
                    confirmButtonColor: "#4c1864"
                });
            }
        });
    </script>
  

</body>
</html>
