@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Change Password - Proxima LMS</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet" />

    <style>
        body {
            background: #f4f6fb;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: Inter, sans-serif;
        }

        .box {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 30px 60px rgba(0,0,0,.12);
            display: flex;
            max-width: 900px;
            width: 100%;
            overflow: hidden;
        }

        .left {
            width: 45%;
            background: linear-gradient(135deg,#ffffff, #a379c8);
            color: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 40px;
        }

        .right {
            width: 55%;
            padding: 50px;
        }

        .btn-main {
            background: #4c1864;
            color: #fff;
            height: 48px;
            border-radius: 10px;
            border: none;
        }

        .pwd-wrap { position: relative; }
        .pwd-eye {
            position: absolute; right: 14px; top: 12px;
            cursor: pointer; color: #98a2b3;
        }
    </style>
</head>

<body>

    <div class="box">

        <div class="left">
            <div>
                <h2>Change Password</h2>
                <p>Keep your account secure with a fresh password</p>
            </div>
        </div>

        <div class="right">

            <form asp-controller="Account" asp-action="ChangePassword" method="post" id="cpForm" autocomplete="off">
                @Html.AntiForgeryToken()

                <h4 class="mb-3">Update Password</h4>

                <div class="pwd-wrap mb-3">
                    <input name="CurrentPassword" id="curPwd" type="password"
                           class="form-control" placeholder="Current Password" required />
                    <i class="fa-solid fa-eye pwd-eye" onclick="toggleEye('curPwd', this)"></i>
                </div>

                <div class="pwd-wrap mb-1">
                    <input name="NewPassword" id="newPwd" type="password"
                           class="form-control" placeholder="New Password" minlength="8" required />
                    <i class="fa-solid fa-eye pwd-eye" onclick="toggleEye('newPwd', this)"></i>
                </div>
                <small class="text-muted d-block mb-3">At least 8 characters.</small>

                <div class="pwd-wrap mb-3">
                    <input name="ConfirmPassword" id="confPwd" type="password"
                           class="form-control" placeholder="Confirm New Password" minlength="8" required />
                    <i class="fa-solid fa-eye pwd-eye" onclick="toggleEye('confPwd', this)"></i>
                </div>

                <button class="btn btn-main w-100">Update Password</button>

                <div class="text-center mt-3">
                    <a href="javascript:history.back()" style="color:#4c1864;">← Back</a>
                </div>
            </form>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function toggleEye(id, el) {
            const inp = document.getElementById(id);
            if (inp.type === "password") { inp.type = "text"; el.classList.replace("fa-eye", "fa-eye-slash"); }
            else { inp.type = "password"; el.classList.replace("fa-eye-slash", "fa-eye"); }
        }

        document.getElementById("cpForm").addEventListener("submit", function (e) {
            const n = document.getElementById("newPwd").value;
            const c = document.getElementById("confPwd").value;
            if (n !== c) {
                e.preventDefault();
                Swal.fire({ icon: "warning", title: "Mismatch", text: "New password and confirmation do not match.", confirmButtonColor: "#4c1864" });
            }
        });

        document.addEventListener("DOMContentLoaded", function () {
            const success = "@TempData["CpSuccess"]";
            const error = "@TempData["CpError"]";

            if (success) {
                Swal.fire({ icon: "success", title: "Done", text: success, confirmButtonColor: "#4c1864" });
            }
            if (error) {
                Swal.fire({ icon: "error", title: "Error", text: error, confirmButtonColor: "#4c1864" });
            }
        });
    </script>

</body>
</html>
