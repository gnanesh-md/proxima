@*
    Notification bell partial — drop into _Layout.cshtml header.
    Usage:  @await Html.PartialAsync("_NotificationBell")
    Requires: Font Awesome (already loaded), ApiBaseUrl exposed to JS (see below),
              and the SignalR client script. Falls back to polling if SignalR
              is unavailable. Reads UserID from session.
*@
@{
    var uid = Context.Session.GetString("UserID");
    var apiBase = (ViewBag.ApiBaseUrl as string) ?? "";
}

@if (!string.IsNullOrEmpty(uid))
{
    <div class="notif-wrap" id="notifWrap">
        <button class="notif-bell" id="notifBell" type="button" title="Notifications">
            <i class="fa-solid fa-bell"></i>
            <span class="notif-badge" id="notifBadge" style="display:none">0</span>
        </button>

        <div class="notif-panel" id="notifPanel">
            <div class="notif-head">
                <span>Notifications</span>
                <a href="javascript:void(0)" id="notifReadAll">Mark all read</a>
            </div>
            <div class="notif-list" id="notifList">
                <div class="notif-empty">Loading…</div>
            </div>
            <div class="notif-foot">
                <a asp-controller="Notifications" asp-action="Index">View all</a>
            </div>
        </div>
    </div>

    <style>
        .notif-wrap { position:relative; display:inline-block; }
        .notif-bell { background:none; border:none; cursor:pointer; position:relative; font-size:18px; color:#475569; padding:6px; }
        .notif-badge { position:absolute; top:0; right:0; background:#ef4444; color:#fff; font-size:10px;
                       min-width:16px; height:16px; border-radius:8px; display:flex; align-items:center;
                       justify-content:center; padding:0 4px; font-weight:700; }
        .notif-panel { position:absolute; right:0; top:42px; width:340px; max-height:440px; background:#fff;
                       border-radius:12px; box-shadow:0 18px 50px rgba(76,24,100,.18); overflow:hidden;
                       display:none; z-index:1200; }
        .notif-panel.open { display:block; }
        .notif-head { display:flex; justify-content:space-between; align-items:center; padding:13px 16px;
                      border-bottom:1px solid #f0f0f4; font-weight:700; color:#4C1864; font-size:14px; }
        .notif-head a { font-size:12px; color:#7B2CBF; font-weight:600; }
        .notif-list { max-height:330px; overflow-y:auto; }
        .notif-item { display:flex; gap:11px; padding:12px 16px; border-bottom:1px solid #f6f6fa;
                      cursor:pointer; text-decoration:none; color:inherit; }
        .notif-item:hover { background:#faf8fe; }
        .notif-item.unread { background:#f6f1fc; }
        .notif-item i { font-size:16px; color:#7B2CBF; margin-top:2px; }
        .notif-item .nt { font-weight:600; font-size:13px; color:#222; }
        .notif-item .nb { font-size:12px; color:#667; margin-top:1px; }
        .notif-item .nd { font-size:10.5px; color:#aaa; margin-top:3px; }
        .notif-empty { text-align:center; color:#999; padding:28px 16px; font-size:13px; }
        .notif-foot { text-align:center; padding:10px; border-top:1px solid #f0f0f4; }
        .notif-foot a { color:#4C1864; font-size:12.5px; font-weight:600; }
    </style>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
    (function () {
        const USER_ID = '@uid';
        const API = '@apiBase'.replace(/\/+$/, '');   // API base (empty => same origin)
        const bell = document.getElementById('notifBell');
        const panel = document.getElementById('notifPanel');
        const badge = document.getElementById('notifBadge');
        const list  = document.getElementById('notifList');

        function setBadge(n) {
            if (n === -1) { refreshCount(); return; }
            if (n > 0) { badge.style.display='flex'; badge.textContent = n > 99 ? '99+' : n; }
            else { badge.style.display='none'; }
        }

        function refreshCount() {
            fetch(`${API}/api/Notification/unread/${USER_ID}`)
                .then(r => r.json()).then(d => setBadge(d.unread || 0)).catch(()=>{});
        }

        function timeAgo(iso) {
            const d = new Date(iso), s = (Date.now() - d) / 1000;
            if (s < 60) return 'just now';
            if (s < 3600) return Math.floor(s/60) + 'm ago';
            if (s < 86400) return Math.floor(s/3600) + 'h ago';
            return d.toLocaleDateString();
        }

        function loadList() {
            fetch(`${API}/api/Notification/list/${USER_ID}?limit=15`)
                .then(r => r.json()).then(d => {
                    const rows = d.data || [];
                    if (!rows.length) { list.innerHTML = '<div class="notif-empty">No notifications yet</div>'; return; }
                    list.innerHTML = rows.map(n => {
                        const unread = (n.IsRead === 0 || n.IsRead === false) ? 'unread' : '';
                        const link = n.LinkUrl || 'javascript:void(0)';
                        return `<a class="notif-item ${unread}" href="${link}" data-id="${n.NotificationID}">
                            <i class="${n.Icon || 'fa-solid fa-bell'}"></i>
                            <div><div class="nt">${esc(n.Title)}</div>
                            ${n.Body ? `<div class="nb">${esc(n.Body)}</div>` : ''}
                            <div class="nd">${timeAgo(n.CreatedDate)}</div></div></a>`;
                    }).join('');
                    list.querySelectorAll('.notif-item').forEach(a => {
                        a.addEventListener('click', () => markRead(a.getAttribute('data-id')));
                    });
                }).catch(()=>{ list.innerHTML = '<div class="notif-empty">Could not load</div>'; });
        }

        function esc(s){ const d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }

        function markRead(id) {
            fetch(`${API}/api/Notification/read`, {
                method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ NotificationID: parseInt(id), UserID: parseInt(USER_ID) })
            }).then(()=>refreshCount()).catch(()=>{});
        }

        bell.addEventListener('click', e => {
            e.stopPropagation();
            panel.classList.toggle('open');
            if (panel.classList.contains('open')) loadList();
        });
        document.addEventListener('click', e => { if (!document.getElementById('notifWrap').contains(e.target)) panel.classList.remove('open'); });
        document.getElementById('notifReadAll').addEventListener('click', () => {
            fetch(`${API}/api/Notification/read-all/${USER_ID}`, { method:'POST' })
                .then(()=>{ refreshCount(); loadList(); }).catch(()=>{});
        });

        // ── SignalR (instant) with polling fallback ──
        let usingSignalR = false;
        try {
            const conn = new signalR.HubConnectionBuilder()
                .withUrl(`${API}/hubs/notifications`)
                .withAutomaticReconnect()
                .build();
            conn.on('notify', payload => {
                setBadge(payload.unread);
                if (panel.classList.contains('open')) loadList();
            });
            conn.start()
                .then(() => { usingSignalR = true; return conn.invoke('Register', USER_ID); })
                .catch(() => { usingSignalR = false; });
        } catch (e) { usingSignalR = false; }

        // initial + polling fallback (every 30s if SignalR isn't live)
        refreshCount();
        setInterval(() => { if (!usingSignalR) refreshCount(); }, 30000);
    })();
    </script>
}
