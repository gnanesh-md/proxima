                        <button class="nav-group-btn" onclick="toggleGroup(this)">
                            <div class="nav-group-icon" style="background:#dbeafe">
                                <i class="fa-solid fa-briefcase" style="color:#2563eb;font-size:12px"></i>
                            </div>
                            <span class="nav-group-label">Management</span>
                            <span class="nav-group-chevron">▶</span>
                        </button>
                        <div class="nav-items">
                            @if (showCourseCreate)
                            {
                                <a asp-controller="Courses" asp-action="Create"
                                   class="nav-item @(currentController=="Courses" && currentAction=="Create" ? "active" : "")">
                                    <i class="fa-solid fa-book-medical"></i>
                                    <span>Course Registration</span>
                                </a>
                            }
                            @if (showTutorCreate)
                            {
                                <a asp-controller="Tutor" asp-action="Create"
                                   class="nav-item @(currentController=="Tutor" && currentAction=="Create" ? "active" : "")">
                                    <i class="fa-solid fa-chalkboard-user"></i>
                                    <span>Tutor Registration</span>
                                </a>
                            }
                            @if (showEmpCreate)
                            {
                                <a asp-controller="Employee" asp-action="Register"
                                   class="nav-item @(currentController=="Employee" && currentAction=="Register" ? "active" : "")">
                                    <i class="fa-solid fa-id-card"></i>
                                    <span>Employee Registration</span>
                                </a>
                            }
                            @if (showTutorList)
                            {
                                <a asp-controller="Tutor" asp-action="List"
                                   class="nav-item @(currentController=="Tutor" && currentAction=="List" ? "active" : "")">
                                    <i class="fa-solid fa-users"></i>
                                    <span>Tutor List</span>
                                </a>
                            }
                            @if (showCourseList)
                            {
                                <a asp-controller="Master" asp-action="CourseList"
                                   class="nav-item @(currentController=="Master" && currentAction=="CourseList" ? "active" : "")">
                                    <i class="fa-solid fa-layer-group"></i>
                                    <span>Courses List</span>
                                </a>
                            }
                            @if (showStudentList)
                            {
                                <a asp-controller="Master" asp-action="StudentList"
                                   class="nav-item @(currentController=="Master" && currentAction=="StudentList" ? "active" : "")">
                                    <i class="fa-solid fa-user-graduate"></i>
                                    <span>Student List</span>
                                </a>
                            }
                            @if (showEmpList)
                            {
                                <a asp-controller="Employee" asp-action="List"
                                   class="nav-item @(currentController=="Employee" && currentAction=="List" ? "active" : "")">
                                    <i class="fa-solid fa-address-card"></i>
                                    <span>Employee List</span>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (showMaster)
                {
                    <div class="nav-group @grp("masterdata")" data-group="masterdata">
                        <button class="nav-group-btn" onclick="toggleGroup(this)">
                            <div class="nav-group-icon" style="background:#f1f5f9">
                                <i class="fa-solid fa-database" style="color:#475569;font-size:12px"></i>
                            </div>
                            <span class="nav-group-label">Master Data</span>
                            <span class="nav-group-chevron">▶</span>
                        </button>
                        <div class="nav-items">
                            @if (showCategory)
                            {
                                <a asp-controller="Category" asp-action="Index"
                                   class="nav-item @(currentController=="Category" ? "active" : "")">
                                    <i class="fa-solid fa-folder-tree"></i>
                                    <span>Categories</span>
                                </a>
                            }
                            @if (showTag)
                            {
                                <a asp-controller="Tag" asp-action="Index"
                                   class="nav-item @(currentController=="Tag" ? "active" : "")">
                                    <i class="fa-solid fa-tags"></i>
                                    <span>Tags</span>
                                </a>
                            }
                            @if (showSkillLevel)
                            {
                                <a asp-controller="SkillLevel" asp-action="Index"
                                   class="nav-item @(currentController=="SkillLevel" ? "active" : "")">
                                    <i class="fa-solid fa-signal"></i>
                                    <span>Skill Levels</span>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (showCourseDetails)
                {
                    <div class="nav-group open" data-group="learning">
                        <button class="nav-group-btn" onclick="toggleGroup(this)">
                            <div class="nav-group-icon" style="background:#ede9fe">
                                <i class="fa-solid fa-play-circle" style="color:#7c3aed;font-size:12px"></i>
                            </div>
                            <span class="nav-group-label">Learning</span>
                            <span class="nav-group-chevron">▶</span>
                        </button>
                        <div class="nav-items">
                            <a asp-controller="Courses" asp-action="List"
                               class="nav-item @(currentController=="Courses" && currentAction=="List" ? "active" : "")">
                                <i class="fa-solid fa-play-circle"></i>
                                <span>Course View</span>
                            </a>
                        </div>
                    </div>
                }
            }

        </nav>

        <!-- Logout -->
        <div class="sb-footer">
            <a asp-controller="Account" asp-action="Logout" class="sb-logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Log Out</span>
            </a>
        </div>

    </div>

    <!-- Mobile overlay -->
    <div class="ttr-overlay" id="sidebarOverlay"></div>

    <!-- ══════════════════════════════════════
         MAIN CONTENT
    ══════════════════════════════════════ -->
    <main class="ttr-wrapper">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- Scripts -->
    <script src="/assets/js/jquery.min.js"></script>
    <script src="/assets/vendors/bootstrap/js/popper.min.js"></script>
    <script src="/assets/vendors/bootstrap/js/bootstrap.min.js"></script>
    <script src="/assets/vendors/bootstrap-select/bootstrap-select.min.js"></script>
    <script src="/assets/vendors/bootstrap-touchspin/jquery.bootstrap-touchspin.js"></script>
    <script src="/assets/vendors/magnific-popup/magnific-popup.js"></script>
    <script src="/assets/vendors/counter/waypoints-min.js"></script>
    <script src="/assets/vendors/counter/counterup.min.js"></script>
    <script src="/assets/vendors/imagesloaded/imagesloaded.js"></script>
    <script src="/assets/vendors/masonry/masonry.js"></script>
    <script src="/assets/vendors/masonry/filter.js"></script>
    <script src="/assets/vendors/owl-carousel/owl.carousel.js"></script>
    <script src='/assets/vendors/scroll/scrollbar.min.js'></script>
    <script src="/assets/js/admin.js"></script>
    <script src='/assets/vendors/calendar/moment.min.js'></script>
    <script src='/assets/vendors/calendar/fullcalendar.js'></script>

    <script>
        /* ── Accordion toggle ── */
        function toggleGroup(btn) {
            var grp = btn.closest('.nav-group');
            grp.classList.toggle('open');
        }

        /* ── Sidebar toggle (desktop collapse + mobile open) ── */
        var sbToggle = document.getElementById('sbToggle');
        var body = document.getElementById('pageBody');
        var overlay = document.getElementById('sidebarOverlay');
        var isMobile = window.innerWidth <= 991;

        sbToggle.addEventListener('click', function () {
            if (isMobile) {
                body.classList.toggle('sb-open');
                overlay.style.display = body.classList.contains('sb-open') ? 'block' : 'none';
            } else {
                body.classList.toggle('sb-collapsed');
            }
        });

        overlay.addEventListener('click', function () {
            body.classList.remove('sb-open');
            overlay.style.display = 'none';
        });

        window.addEventListener('resize', function () {
            isMobile = window.innerWidth <= 991;
        });

        /* ── Topbar user pill dropdown toggle ── */
        var userPill = document.getElementById('userPill');
        userPill.addEventListener('click', function (e) {
            e.stopPropagation();
            userPill.classList.toggle('open');
        });
        document.addEventListener('click', function () {
            userPill.classList.remove('open');
        });

        /* ── Wishlist badge (learner: student / employee) ── */
        @if (showLearnerNav)
        {
            <text>
                (function () {
                    fetch('@Url.Action("WishlistCount", "Courses")')
                        .then(function (r) { return r.json(); })
                        .then(function (d) {
                            if (d && d.success && d.count > 0) {
                                var b = document.getElementById('wishCountBadge');
                                if (b) { b.textContent = d.count; b.style.display = 'flex'; }
                            }
                        })
                        .catch(function () { });
                })();
            </text>
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
