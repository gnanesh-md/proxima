@{
    Layout = null;
    var r = ViewBag.Result as Newtonsoft.Json.Linq.JObject ?? new Newtonsoft.Json.Linq.JObject();
    bool valid   = (bool?)r["valid"] ?? false;
    bool revoked = (bool?)r["revoked"] ?? false;
    var no     = (string?)r["certificateNo"] ?? "";
    var name   = (string?)r["studentName"] ?? "";
    var course = (string?)r["courseTitle"] ?? "";
    var src    = (string?)r["source"] ?? "";
    var issued = (DateTime?)r["issuedDate"];
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Verify Certificate - Proxima LMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <style>
        body { background:#f4f6fb; display:flex; align-items:center; justify-content:center;
               min-height:100vh; font-family:Inter,sans-serif; margin:0; padding:20px; }
        .vcard { background:#fff; border-radius:18px; max-width:520px; width:100%;
                 box-shadow:0 30px 60px rgba(0,0,0,.10); overflow:hidden; }
        .vhead { padding:34px; text-align:center; color:#fff; }
        .vhead.ok  { background:linear-gradient(135deg,#16a34a,#22c55e); }
        .vhead.bad { background:linear-gradient(135deg,#b42318,#ef4444); }
        .vhead i { font-size:54px; }
        .vhead h4 { margin:14px 0 0; font-weight:700; }
        .vbody { padding:30px 34px; }
        .vrow { display:flex; justify-content:space-between; padding:11px 0; border-bottom:1px solid #f0f0f4; font-size:14px; }
        .vrow:last-child { border-bottom:none; }
        .vrow .k { color:#667; } .vrow .v { font-weight:600; color:#222; text-align:right; }
        .vfoot { text-align:center; padding:0 34px 28px; color:#98a2b3; font-size:12px; }
        .brand { text-align:center; padding:18px; font-weight:700; color:#4C1864; letter-spacing:.05em; }
    </style>
</head>
<body>
    <div class="vcard">
        <div class="brand">PROXIMA&nbsp;LMS</div>
        @if (valid)
        {
            <div class="vhead ok">
                <i class="fa-solid fa-circle-check"></i>
                <h4>Certificate Verified</h4>
            </div>
            <div class="vbody">
                <div class="vrow"><span class="k">Certificate No</span><span class="v">@no</span></div>
                <div class="vrow"><span class="k">Awarded To</span><span class="v">@name</span></div>
                <div class="vrow"><span class="k">Course</span><span class="v">@course</span></div>
                <div class="vrow"><span class="k">Basis</span><span class="v">@(src == "EXAM" ? "Exam Passed" : src == "MANUAL" ? "Awarded" : "Course Completed")</span></div>
                <div class="vrow"><span class="k">Issued On</span><span class="v">@(issued?.ToString("dd MMM yyyy"))</span></div>
            </div>
        }
        else
        {
            <div class="vhead bad">
                <i class="fa-solid fa-circle-xmark"></i>
                <h4>@(revoked ? "Certificate Revoked" : "Not Verified")</h4>
            </div>
            <div class="vbody text-center">
                <p class="text-muted mb-0">
                    @(revoked
                        ? "This certificate has been revoked and is no longer valid."
                        : "We couldn't find a valid certificate for this code. Please check the link or QR code.")
                </p>
            </div>
        }
        <div class="vfoot">Verified via the official ProximaLMS certificate registry.</div>
    </div>
</body>
</html>
