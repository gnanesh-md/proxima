@model ProximaLMS.Controllers.ReferralDashboardViewModel
@{
    ViewData["Title"] = "Refer & Earn";
    Layout = "_Layout";

    var policy = Model.Policy;
    string refereeReward = "a welcome discount";
    if (policy != null)
    {
        refereeReward = string.Equals(policy.RefereeDiscountType, "PERCENT", StringComparison.OrdinalIgnoreCase)
            ? $"{policy.RefereeDiscountValue:0.##}% off their first course"
            : $"\u20B9{policy.RefereeDiscountValue:0.##} off their first course";
    }

    // When the code is missing (e.g. session error) we want to disable
    // the share buttons so the user doesn't think they're broken.
    bool hasCode = !string.IsNullOrEmpty(Model.ReferralCode);
}

<style>
    :root {
        --primary: #4C1864;
        --secondary: #7B2CBF;
        --bg: #f4f6fb;
    }

    .rf-wrap {
        padding: 10px;
        background: var(--bg);
    }

    .rf-header {
        background: #fff;
        padding: 20px 25px;
        box-shadow: 0 8px 30px rgba(0,0,0,.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
        flex-wrap: wrap;
        gap: 12px;
        border-radius: 12px;
    }

    .rf-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--primary);
        margin: 0;
    }

    .rf-sub {
        font-size: 13px;
        color: #8a8f9c;
        margin-top: 3px;
    }

    .btn-ghost {
        border: 1px solid var(--primary);
        color: var(--primary) !important;
        background: #fff;
        padding: 9px 18px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    /* hero / share card */
    .rf-hero {
        background: linear-gradient(120deg, var(--primary), var(--secondary));
        border-radius: 16px;
        padding: 30px 32px;
        color: #fff;
        margin-bottom: 22px;
        box-shadow: 0 12px 35px rgba(76,24,100,.25);
    }

        .rf-hero h3 {
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 6px;
        }

        .rf-hero p {
            font-size: 14px;
            opacity: .9;
            margin: 0 0 20px;
        }

    .rf-code-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    .rf-code-box {
        background: rgba(255,255,255,.18);
        border: 2px dashed rgba(255,255,255,.65);
        border-radius: 10px;
        padding: 14px 22px;
        font-family: 'Courier New', monospace;
        font-size: 26px;
        font-weight: 700;
        letter-spacing: .08em;
        color: #fff; /* explicit — was inheriting before */
        min-width: 200px;
        text-align: center;
    }

        .rf-code-box.is-empty {
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: normal;
            color: rgba(255,255,255,.85);
        }

    .btn-copy, .btn-share {
        padding: 12px 20px;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 14px;
        border: none;
        text-decoration: none;
        transition: opacity .15s, transform .15s;
    }

    .btn-copy {
        background: #fff;
        color: var(--primary) !important;
    }

    .btn-share {
        background: rgba(255,255,255,.18);
        color: #fff !important;
        border: 1px solid rgba(255,255,255,.5);
    }

        /* Disabled state when there's no code */
        .btn-copy[disabled], .btn-share.is-disabled {
            opacity: .45;
            cursor: not-allowed;
            pointer-events: none;
        }

    .rf-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 16px;
        margin-bottom: 22px;
    }

    .rf-stat {
        background: #fff;
        border-radius: 14px;
        padding: 18px 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        text-align: center;
    }

        .rf-stat .ico {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            background: #f1eaf6;
            color: var(--primary);
            font-size: 18px;
        }

        .rf-stat .val {
            font-size: 26px;
            font-weight: 700;
            color: var(--primary);
        }

        .rf-stat .lbl {
            font-size: 12px;
            color: #8a8f9c;
            text-transform: uppercase;
            letter-spacing: .04em;
            font-weight: 600;
            margin-top: 3px;
        }

    .rf-grid {
        display: grid;
        grid-template-columns: 1.6fr 1fr;
        gap: 20px;
    }

    @@media (max-width: 900px) {
        .rf-grid {
            grid-template-columns: 1fr;
        }
    }

    .rf-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .rf-card-head {
        padding: 16px 20px;
        border-bottom: 1px solid #eef0f5;
        font-weight: 700;
        color: var(--primary);
        font-size: 15px;
    }

    table.rf-table {
        width: 100%;
        border-collapse: collapse;
    }

        table.rf-table thead th {
            background: #faf7fc;
            color: var(--primary);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .04em;
            padding: 12px 16px;
            text-align: left;
        }

        table.rf-table tbody td {
            padding: 12px 16px;
            font-size: 14px;
            border-bottom: 1px solid #f1f2f6;
            color: #3b3f4a;
        }

        table.rf-table tbody tr:hover {
            background: #faf9fc;
        }

    .pill {
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .pill-pending {
        background: #fff3e0;
        color: #b45309;
    }

    .pill-rewarded {
        background: #e8f8ee;
        color: #137a3e;
    }

    .pill-expired {
        background: #f1f2f6;
        color: #6b7280;
    }

    .rf-how li {
        margin-bottom: 14px;
        font-size: 14px;
        color: #4b4f5a;
        line-height: 1.5;
    }

    .rf-how .step-no {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: var(--primary);
        color: #fff;
        font-weight: 700;
        font-size: 13px;
        margin-right: 8px;
    }

    .rf-reward-note {
        background: #faf7fc;
        border: 1px solid #ece3f3;
        border-radius: 10px;
        padding: 14px 16px;
        font-size: 13px;
        color: #5b5f6a;
        margin: 16px 20px;
        line-height: 1.6;
    }

        .rf-reward-note b {
            color: var(--primary);
        }

    .rf-empty {
        padding: 36px 20px;
        text-align: center;
        color: #9aa0ac;
    }

        .rf-empty i {
            font-size: 34px;
            color: #d8dbe3;
            margin-bottom: 10px;
        }
</style>

<div class="rf-wrap">

    <div class="rf-header">
        <div>
            <h2 class="rf-title"><i class="fas fa-gift"></i> Refer &amp; Earn</h2>
            <div class="rf-sub">Invite friends and earn rewards when they join</div>
        </div>
        <a class="btn-ghost" asp-controller="Referral" asp-action="Leaderboard">
            <i class="fas fa-trophy"></i> Leaderboard
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="rf-hero">
        <h3>Your personal referral code</h3>
        <p>Share this code with friends. When they sign up and buy their first course, you both win.</p>
        <div class="rf-code-row">
            @if (hasCode)
            {
                <div class="rf-code-box" id="refCode">@Model.ReferralCode</div>
                <button type="button" class="btn-copy" onclick="copyCode()">
                    <i class="fas fa-copy"></i> <span id="copyLabel">Copy Code</span>
                </button>
                <a class="btn-share" id="waShare" target="_blank" rel="noopener">
                    <i class="fab fa-whatsapp"></i> Share on WhatsApp
                </a>
            }
            else
            {
                <div class="rf-code-box is-empty" id="refCode">
                    <i class="fas fa-circle-exclamation"></i> Code unavailable — please refresh or sign in again
                </div>
                <button type="button" class="btn-copy" disabled>
                    <i class="fas fa-copy"></i> Copy Code
                </button>
                <a class="btn-share is-disabled" aria-disabled="true">
                    <i class="fab fa-whatsapp"></i> Share on WhatsApp
                </a>
            }
        </div>
    </div>

    <div class="rf-stats">
        <div class="rf-stat">
            <div class="ico"><i class="fas fa-user-plus"></i></div>
            <div class="val">@Model.TotalInvites</div>
            <div class="lbl">Friends Invited</div>
        </div>
        <div class="rf-stat">
            <div class="ico"><i class="fas fa-hourglass-half"></i></div>
            <div class="val">@Model.PendingInvites</div>
            <div class="lbl">Pending</div>
        </div>
        <div class="rf-stat">
            <div class="ico"><i class="fas fa-circle-check"></i></div>
            <div class="val">@Model.TotalReferrals</div>
            <div class="lbl">Successful</div>
        </div>
        <div class="rf-stat">
            <div class="ico"><i class="fas fa-star"></i></div>
            <div class="val">@Model.TotalRewardPoints</div>
            <div class="lbl">Reward Points</div>
        </div>
    </div>

    <div class="rf-grid">

        <div class="rf-card">
            <div class="rf-card-head">Your Referrals</div>
            @if (Model.Referrals == null || !Model.Referrals.Any())
            {
                <div class="rf-empty">
                    <i class="fas fa-users"></i>
                    <div>No referrals yet. Share your code to get started!</div>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="rf-table">
                        <thead>
                            <tr>
                                <th>Friend</th>
                                <th>Joined</th>
                                <th>Status</th>
                                <th>Points Earned</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Referrals)
                            {
                                var st = (r.Status ?? "").ToUpper();
                                var pillClass = st == "REWARDED" ? "pill-rewarded"
                                : st == "EXPIRED" ? "pill-expired"
                                : "pill-pending";
                                <tr>
                                    <td>
                                        <div style="font-weight:600;">@r.RefereeName</div>
                                        <div style="font-size:12px;color:#9aa0ac;">@r.RefereeEmail</div>
                                    </td>
                                    <td>@r.CreatedDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="pill @pillClass">@(string.IsNullOrEmpty(r.Status) ? "PENDING" : r.Status)</span></td>
                                    <td>@(st == "REWARDED" ? $"+{r.ReferrerRewardPoints}" : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="rf-card">
            <div class="rf-card-head">How It Works</div>
            <ol class="rf-how" style="list-style:none;padding:18px 20px;margin:0;">
                <li><span class="step-no">1</span> Share your code with a friend.</li>
                <li><span class="step-no">2</span> They sign up using your code and get <b>@refereeReward</b>.</li>
                <li>
                    <span class="step-no">3</span> When they buy their first course, you earn
                    <b>@(policy?.ReferrerPoints ?? 100) reward points</b>.
                </li>
            </ol>
            <div class="rf-reward-note">
                <b>Friend's reward:</b> @refereeReward.
                @if (policy != null)
                {
                    <text> The welcome coupon is valid for @policy.RefereeCouponValidityDays days after sign-up.</text>
                }
                <br />
                <b>Your reward:</b> @(policy?.ReferrerPoints ?? 100) points per successful referral.
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        var REF_CODE = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ReferralCode ?? ""));

        function buildShareText() {
            return "Join ProximaLMS and start learning! Use my referral code " + REF_CODE +
                " when you sign up to get a discount on your first course.";
        }

        document.addEventListener('DOMContentLoaded', function () {
            var wa = document.getElementById('waShare');
            if (wa && REF_CODE) {
                wa.href = "https://wa.me/?text=" + encodeURIComponent(buildShareText());
            }
        });

        function copyCode() {
            if (!REF_CODE) { return; }
            navigator.clipboard.writeText(REF_CODE).then(function () {
                document.getElementById('copyLabel').innerText = 'Copied!';
                setTimeout(function () {
                    document.getElementById('copyLabel').innerText = 'Copy Code';
                }, 2000);
                if (window.Swal) {
                    Swal.fire({
                        toast: true, position: 'top-end', icon: 'success',
                        title: 'Referral code copied', showConfirmButton: false, timer: 1800
                    });
                }
            });
        }
    </script>
}
