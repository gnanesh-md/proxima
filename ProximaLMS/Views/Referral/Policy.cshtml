@model ProximaLMS.Controllers.ReferralPolicyViewModel
@{
    ViewData["Title"] = "Referral Settings";
    Layout = "_Layout";
}

<style>
    :root {
        --primary: #4C1864;
        --secondary: #7B2CBF;
        --bg: #f4f6fb;
    }

    .rp-wrap { padding: 10px; background: var(--bg); }

    .rp-header {
        background: #fff;
        padding: 20px 25px;
        box-shadow: 0 8px 30px rgba(0,0,0,.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .rp-title { font-size: 22px; font-weight: 700; color: var(--primary); margin: 0; }
    .rp-sub   { font-size: 13px; color: #8a8f9c; margin-top: 3px; }

    .btn-ghost {
        border: 1px solid var(--primary);
        color: var(--primary) !important;
        background: #fff;
        padding: 9px 18px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .rp-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        padding: 28px 30px;
        max-width: 820px;
    }

    .rp-section-title {
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--secondary);
        margin: 0 0 6px;
    }
    .rp-section-desc { font-size: 13px; color: #9aa0ac; margin-bottom: 16px; }
    .rp-divider { height: 1px; background: #eef0f5; margin: 26px 0; }

    .rp-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }
    @@media (max-width: 680px) { .rp-row { grid-template-columns: 1fr; } }

    .rp-field { margin-bottom: 16px; }
    .rp-field label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #3b3f4a;
        margin-bottom: 6px;
    }
    .rp-field .hint { font-size: 12px; color: #9aa0ac; margin-top: 4px; }

    .rp-input, .rp-select {
        width: 100%;
        padding: 10px 13px;
        border: 1px solid #dde1ea;
        border-radius: 8px;
        font-size: 14px;
        color: #2f3340;
    }
    .rp-input:focus, .rp-select:focus {
        outline: none;
        border-color: var(--secondary);
        box-shadow: 0 0 0 3px rgba(123,44,191,.12);
    }

    .input-prefix { position: relative; }
    .input-prefix .pfx {
        position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
        color: #9aa0ac; font-size: 14px;
    }
    .input-prefix .rp-input { padding-left: 28px; }

    .rp-toggle {
        display: flex; align-items: center; gap: 12px;
        background: #faf7fc; border: 1px solid #ece3f3;
        border-radius: 10px; padding: 14px 16px;
    }
    .switch { position: relative; display: inline-block; width: 46px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider {
        position: absolute; cursor: pointer; inset: 0;
        background: #cdd2dc; border-radius: 24px; transition: .25s;
    }
    .slider:before {
        content: ""; position: absolute;
        height: 18px; width: 18px; left: 3px; bottom: 3px;
        background: #fff; border-radius: 50%; transition: .25s;
    }
    .switch input:checked + .slider { background: var(--secondary); }
    .switch input:checked + .slider:before { transform: translateX(22px); }

    .rp-actions {
        display: flex; gap: 12px; margin-top: 26px;
    }
    .btn-grad {
        background: linear-gradient(90deg,var(--primary),var(--secondary));
        color: #fff; border: none;
        padding: 11px 26px; border-radius: 8px;
        font-weight: 700; cursor: pointer; font-size: 14px;
    }
    .btn-cancel {
        background: #fff; border: 1px solid #dde1ea;
        color: #5b5f6a; padding: 11px 22px; border-radius: 8px;
        font-weight: 600; text-decoration: none; font-size: 14px;
        display: inline-flex; align-items: center;
    }

    .text-danger { color: #d63031; font-size: 12px; margin-top: 4px; display: block; }

    .rp-preview {
        background: linear-gradient(120deg, var(--primary), var(--secondary));
        color: #fff; border-radius: 12px;
        padding: 18px 20px; margin-bottom: 22px;
        font-size: 14px; line-height: 1.6;
        max-width: 820px;
    }
    .rp-preview b { font-weight: 700; }
</style>

<div class="rp-wrap">

    <div class="rp-header">
        <div>
            <h2 class="rp-title"><i class="fas fa-sliders"></i> Referral Settings</h2>
            <div class="rp-sub">Configure the rewards for referrers and new users</div>
        </div>
        <a class="btn-ghost" asp-controller="Referral" asp-action="Leaderboard">
            <i class="fas fa-trophy"></i> Leaderboard
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="rp-preview" id="rpPreview">
        <i class="fas fa-eye"></i> <b>Preview:</b>
        <span id="previewText"></span>
    </div>

    <div class="rp-card">
        <form asp-controller="Referral" asp-action="Policy" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PolicyID" />

            <div class="rp-section-title">Referrer Reward</div>
            <div class="rp-section-desc">What an existing user earns when their referral completes a first purchase.</div>

            <div class="rp-field">
                <label asp-for="ReferrerPoints">Reward Points per Successful Referral</label>
                <input asp-for="ReferrerPoints" type="number" min="0" class="rp-input" id="refPoints" />
                <span asp-validation-for="ReferrerPoints" class="text-danger"></span>
                <div class="hint">Points credited to the referrer after the new user's first paid course.</div>
            </div>

            <div class="rp-divider"></div>

            <div class="rp-section-title">New User Reward</div>
            <div class="rp-section-desc">The welcome coupon automatically issued to a user who signs up with a referral code.</div>

            <div class="rp-row">
                <div class="rp-field">
                    <label asp-for="RefereeDiscountType">Discount Type</label>
                    <select asp-for="RefereeDiscountType" class="rp-select" id="discType">
                        <option value="FLAT">Flat Amount (&#8377;)</option>
                        <option value="PERCENT">Percentage (%)</option>
                    </select>
                    <span asp-validation-for="RefereeDiscountType" class="text-danger"></span>
                </div>

                <div class="rp-field">
                    <label asp-for="RefereeDiscountValue" id="discValLabel">Discount Value</label>
                    <div class="input-prefix">
                        <span class="pfx" id="discPfx">&#8377;</span>
                        <input asp-for="RefereeDiscountValue" type="number" step="0.01" min="0"
                               class="rp-input" id="discVal" />
                    </div>
                    <span asp-validation-for="RefereeDiscountValue" class="text-danger"></span>
                </div>
            </div>

            <div class="rp-row">
                <div class="rp-field" id="maxDiscWrap">
                    <label asp-for="RefereeMaxDiscount">Maximum Discount Cap (&#8377;)</label>
                    <div class="input-prefix">
                        <span class="pfx">&#8377;</span>
                        <input asp-for="RefereeMaxDiscount" type="number" step="0.01" min="0"
                               class="rp-input" id="maxDisc" placeholder="Leave blank for no cap" />
                    </div>
                    <span asp-validation-for="RefereeMaxDiscount" class="text-danger"></span>
                    <div class="hint">Only applies to percentage discounts.</div>
                </div>

                <div class="rp-field">
                    <label asp-for="RefereeCouponValidityDays">Welcome Coupon Validity (days)</label>
                    <input asp-for="RefereeCouponValidityDays" type="number" min="1" max="365"
                           class="rp-input" id="validDays" />
                    <span asp-validation-for="RefereeCouponValidityDays" class="text-danger"></span>
                    <div class="hint">How long the new user has to redeem the welcome coupon.</div>
                </div>
            </div>

            <div class="rp-divider"></div>

            <div class="rp-field">
                <div class="rp-toggle">
                    <label class="switch">
                        <input asp-for="IsActive" type="checkbox" id="isActive" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <div style="font-weight:600;color:#3b3f4a;">Referral Program Active</div>
                        <div class="hint">When off, new sign-ups will not generate referral rewards or welcome coupons.</div>
                    </div>
                </div>
            </div>

            <div class="rp-actions">
                <button type="submit" class="btn-grad"><i class="fas fa-save"></i> Save Settings</button>
                <a class="btn-cancel" asp-controller="Referral" asp-action="Leaderboard">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function refreshUI() {
            var type      = document.getElementById('discType').value;
            var isPercent = type === 'PERCENT';

            document.getElementById('discPfx').innerHTML = isPercent ? '%' : '&#8377;';
            document.getElementById('discValLabel').innerText =
                isPercent ? 'Discount Percentage' : 'Discount Amount';
            document.getElementById('maxDiscWrap').style.display = isPercent ? '' : 'none';

            var points  = document.getElementById('refPoints').value || '0';
            var val     = document.getElementById('discVal').value || '0';
            var days    = document.getElementById('validDays').value || '0';
            var active  = document.getElementById('isActive').checked;
            var rewardTxt = isPercent ? (val + '% off') : ('\u20B9' + val + ' off');

            var txt = active
                ? 'New users get ' + rewardTxt + ' their first course (coupon valid ' + days +
                  ' days). The referrer earns ' + points + ' reward points once the new user makes a paid purchase.'
                : 'The referral program is currently turned OFF — no rewards will be issued.';
            document.getElementById('previewText').innerText = txt;
        }

        ['discType','discVal','refPoints','validDays','isActive'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) {
                el.addEventListener('change', refreshUI);
                el.addEventListener('keyup', refreshUI);
            }
        });
        document.addEventListener('DOMContentLoaded', refreshUI);
    </script>
}
