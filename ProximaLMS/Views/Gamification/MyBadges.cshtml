@{
    ViewData["Title"] = "My Achievements";
    Layout = "_Layout";
    var badges = ViewBag.Badges as Newtonsoft.Json.Linq.JArray ?? new Newtonsoft.Json.Linq.JArray();
    var earned = badges.Where(b => !string.IsNullOrEmpty(b["earnedAt"]?.ToString() ?? b["EarnedAt"]?.ToString())).ToList();
    var locked = badges.Where(b => string.IsNullOrEmpty(b["earnedAt"]?.ToString() ?? b["EarnedAt"]?.ToString())).ToList();
}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{--g1:#4C1864;--g2:#7B2CBF;--g3:#9D4EDD;--ink:#1a1523;--sub:#4b5563;--muted:#94a3b8;--border:#ede9fe;--bg:#f8f5ff;--card:#fff;--sh:0 2px 12px rgba(76,24,100,.07);--sh-md:0 8px 28px rgba(76,24,100,.13);}
*{box-sizing:border-box;}
.pg{display:flex;flex-direction:column;gap:22px;font-family:'Plus Jakarta Sans',system-ui,sans-serif;padding-bottom:40px;}

/* HERO */
.pg-hero{background:linear-gradient(135deg,#1e0438 0%,#4C1864 35%,#7B2CBF 70%,#C026D3 100%);border-radius:24px;padding:32px 36px;color:#fff;position:relative;overflow:hidden;box-shadow:0 14px 50px rgba(76,24,100,.28);}
.pg-hero::before{content:'';position:absolute;width:320px;height:320px;border-radius:50%;background:rgba(255,255,255,.05);top:-120px;right:-80px;pointer-events:none;}
.pg-hero::after{content:'🏆';position:absolute;bottom:-20px;right:40px;font-size:130px;opacity:.08;line-height:1;pointer-events:none;}
.pg-hero-inner{position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px;}
.pg-hero-left h1{margin:0 0 6px;font-size:1.9rem;font-weight:900;letter-spacing:-.4px;}
.pg-hero-left p{margin:0;font-size:.9rem;opacity:.82;}
.pg-hero-pills{display:flex;gap:12px;flex-wrap:wrap;}
.pg-pill{background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.22);backdrop-filter:blur(8px);border-radius:16px;padding:12px 18px;text-align:center;min-width:90px;}
.pg-pill-val{font-size:1.6rem;font-weight:900;line-height:1;}
.pg-pill-lbl{font-size:.72rem;font-weight:600;opacity:.8;margin-top:3px;}

/* SECTION LABEL */
.sec-label{display:flex;align-items:center;gap:10px;font-size:.82rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--sub);}
.sec-label::after{content:'';flex:1;height:1px;background:var(--border);}
.sec-label i{color:var(--g2);}

/* BADGE GRID */
.bdg-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:14px;}
.bdg-chip{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px 16px 20px;text-align:center;box-shadow:var(--sh);transition:transform .2s,box-shadow .2s;position:relative;overflow:hidden;}
.bdg-chip::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(123,44,191,.04),transparent);pointer-events:none;}
.bdg-chip:hover{transform:translateY(-3px);box-shadow:var(--sh-md);}
.bdg-chip.locked{opacity:.45;filter:grayscale(.8);}
.bdg-chip.locked:hover{transform:none;box-shadow:var(--sh);}
.bdg-earned-ribbon{position:absolute;top:10px;right:-20px;background:linear-gradient(90deg,#16a34a,#22c55e);color:#fff;font-size:.6rem;font-weight:800;padding:3px 28px 3px 10px;transform:rotate(30deg);letter-spacing:.05em;}
.bdg-ico{font-size:46px;margin-bottom:10px;line-height:1;display:block;}
.bdg-name{font-size:.83rem;font-weight:800;color:var(--ink);margin-bottom:4px;}
.bdg-desc{font-size:.72rem;color:var(--muted);line-height:1.35;}
.bdg-date{font-size:.68rem;font-weight:700;color:#16a34a;margin-top:8px;background:#dcfce7;padding:2px 10px;border-radius:20px;display:inline-block;}
.bdg-lock-ico{font-size:.75rem;color:var(--muted);margin-top:8px;}

/* EMPTY */
.pg-empty{background:var(--card);border:1px dashed #d8b4fe;border-radius:20px;padding:52px 24px;text-align:center;color:var(--muted);}
.pg-empty-ico{font-size:56px;margin-bottom:14px;}
.pg-empty h3{font-size:1.15rem;font-weight:800;color:var(--ink);margin:0 0 8px;}
.pg-empty p{font-size:.85rem;margin:0 0 18px;}
.pg-empty-cta{display:inline-flex;align-items:center;gap:8px;padding:11px 22px;background:linear-gradient(135deg,var(--g1),var(--g2));color:#fff;border-radius:12px;font-weight:700;font-size:.85rem;text-decoration:none;box-shadow:0 6px 18px rgba(76,24,100,.28);}
.pg-empty-cta:hover{color:#fff;box-shadow:0 10px 26px rgba(76,24,100,.38);}
</style>

<div class="pg">

    <!-- HERO -->
    <div class="pg-hero">
        <div class="pg-hero-inner">
            <div class="pg-hero-left">
                <h1><i class="fa-solid fa-medal me-2"></i>My Achievements</h1>
                <p>Badges you've unlocked through learning milestones and streaks</p>
            </div>
            <div class="pg-hero-pills">
                <div class="pg-pill">
                    <div class="pg-pill-val">@badges.Count</div>
                    <div class="pg-pill-lbl">Total</div>
                </div>
                <div class="pg-pill">
                    <div class="pg-pill-val">@earned.Count</div>
                    <div class="pg-pill-lbl">Earned</div>
                </div>
                <div class="pg-pill">
                    <div class="pg-pill-val">@locked.Count</div>
                    <div class="pg-pill-lbl">Locked</div>
                </div>
            </div>
        </div>
    </div>

    @if (!badges.Any())
    {
        <div class="pg-empty">
            <div class="pg-empty-ico">🏅</div>
            <h3>No badges yet</h3>
            <p>Complete courses, pass exams, and maintain your streak to unlock badges!</p>
            <a asp-controller="Courses" asp-action="Browse" class="pg-empty-cta">
                <i class="fa-solid fa-compass"></i> Start Learning
            </a>
        </div>
    }
    else
    {
        @if (earned.Any())
        {
            <div class="sec-label"><i class="fa-solid fa-circle-check"></i>Earned (@earned.Count)</div>
            <div class="bdg-grid">
                @foreach (var b in earned)
                {
                    var icon = b["icon"]?.ToString() ?? b["Icon"]?.ToString() ?? "🎖️";
                    var name = b["name"]?.ToString() ?? b["Name"]?.ToString() ?? "Badge";
                    var desc = b["description"]?.ToString() ?? b["Description"]?.ToString() ?? "";
                    var earnedAt = b["earnedAt"]?.ToString() ?? b["EarnedAt"]?.ToString() ?? "";
                    DateTime.TryParse(earnedAt, out var earnedDate);
                    <div class="bdg-chip">
                        <div class="bdg-earned-ribbon">EARNED</div>
                        <span class="bdg-ico">@icon</span>
                        <div class="bdg-name">@name</div>
                        @if (!string.IsNullOrEmpty(desc)) { <div class="bdg-desc">@desc</div> }
                        @if (earnedDate != default) { <div class="bdg-date">@earnedDate.ToString("dd MMM yyyy")</div> }
                    </div>
                }
            </div>
        }

        @if (locked.Any())
        {
            <div class="sec-label"><i class="fa-solid fa-lock"></i>Locked (@locked.Count)</div>
            <div class="bdg-grid">
                @foreach (var b in locked)
                {
                    var icon = b["icon"]?.ToString() ?? b["Icon"]?.ToString() ?? "🎖️";
                    var name = b["name"]?.ToString() ?? b["Name"]?.ToString() ?? "Badge";
                    var desc = b["description"]?.ToString() ?? b["Description"]?.ToString() ?? "";
                    <div class="bdg-chip locked">
                        <span class="bdg-ico">@icon</span>
                        <div class="bdg-name">@name</div>
                        @if (!string.IsNullOrEmpty(desc)) { <div class="bdg-desc">@desc</div> }
                        <div class="bdg-lock-ico"><i class="fa-solid fa-lock"></i> Not yet earned</div>
                    </div>
                }
            </div>
        }
    }
</div>
