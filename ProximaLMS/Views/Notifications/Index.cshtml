@using Newtonsoft.Json.Linq
@{
    ViewData["Title"] = "Notifications";
    Layout = "_Layout";
    var items = ViewBag.Items as JArray ?? new JArray();
    var uid = (string)ViewBag.UserId;
    var unreadCount = items.Count(n => ((int?)n["IsRead"] ?? 0) == 0);
}
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{--g1:#4C1864;--g2:#7B2CBF;--g3:#9D4EDD;--ink:#1a1523;--sub:#4b5563;--muted:#94a3b8;--border:#ede9fe;--bg:#f8f5ff;--card:#fff;--sh:0 2px 12px rgba(76,24,100,.07);--sh-md:0 8px 28px rgba(76,24,100,.13);}
*{box-sizing:border-box;}
.nf-pg{display:flex;flex-direction:column;gap:22px;font-family:'Plus Jakarta Sans',system-ui,sans-serif;padding-bottom:40px;}

/* HERO */
.nf-hero{background:linear-gradient(135deg,#1e1b4b 0%,#4C1864 35%,#7B2CBF 70%,#F97316 140%);border-radius:24px;padding:28px 32px;color:#fff;position:relative;overflow:hidden;box-shadow:0 14px 50px rgba(76,24,100,.28);}
.nf-hero::before{content:'🔔';position:absolute;right:38px;bottom:-10px;font-size:120px;opacity:.1;line-height:1;pointer-events:none;}
.nf-hero::after{content:'';position:absolute;width:220px;height:220px;border-radius:50%;background:rgba(249,115,22,.1);top:-70px;right:-40px;pointer-events:none;}
.nf-hero-inner{position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;}
.nf-hero-left h1{margin:0 0 6px;font-size:1.85rem;font-weight:900;}
.nf-hero-left p{margin:0;font-size:.9rem;opacity:.82;}
.nf-hero-right{display:flex;align-items:center;gap:12px;}
.nf-unread-badge{background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.28);border-radius:14px;padding:10px 18px;text-align:center;}
.nf-unread-badge-val{font-size:1.5rem;font-weight:900;line-height:1;}
.nf-unread-badge-lbl{font-size:.7rem;font-weight:600;opacity:.8;margin-top:2px;}
.nf-readall{display:inline-flex;align-items:center;gap:7px;padding:10px 18px;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.28);border-radius:12px;font-size:.82rem;font-weight:700;color:#fff;cursor:pointer;transition:background .15s;}
.nf-readall:hover{background:rgba(255,255,255,.28);}

/* FILTER TABS */
.nf-tabs{display:flex;gap:8px;flex-wrap:wrap;}
.nf-tab{padding:8px 18px;border-radius:20px;font-size:.8rem;font-weight:700;border:1px solid var(--border);background:var(--card);color:var(--sub);cursor:pointer;transition:.15s;}
.nf-tab:hover,.nf-tab.active{background:var(--g2);color:#fff;border-color:var(--g2);}

/* CARD */
.nf-card{background:var(--card);border:1px solid var(--border);border-radius:22px;overflow:hidden;box-shadow:var(--sh);}
.nf-card-head{padding:14px 22px;border-bottom:1px solid #f5f3ff;display:flex;align-items:center;justify-content:space-between;}
.nf-card-title{font-size:.88rem;font-weight:800;color:var(--ink);display:flex;align-items:center;gap:8px;}
.nf-card-title i{color:var(--g2);}

/* NOTIFICATION ITEM */
.nf-item{display:flex;align-items:flex-start;gap:14px;padding:16px 22px;border-bottom:1px solid #faf7ff;text-decoration:none;color:inherit;transition:background .15s;position:relative;}
.nf-item:last-child{border-bottom:none;}
.nf-item:hover{background:#faf5ff;}
.nf-item.unread{background:linear-gradient(90deg,#f8f4ff,var(--card));}
.nf-item.unread::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--g2);border-radius:0 3px 3px 0;}

.nf-ico-wrap{width:44px;height:44px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:17px;}
.nf-ico-course{background:#ede9fe;color:var(--g2);}
.nf-ico-payment{background:#dcfce7;color:#16a34a;}
.nf-ico-badge{background:#fef3c7;color:#d97706;}
.nf-ico-exam{background:#dbeafe;color:#2563eb;}
.nf-ico-default{background:#f3f4f6;color:#6b7280;}

.nf-body{flex:1;min-width:0;}
.nf-title{font-size:.9rem;font-weight:700;color:var(--ink);line-height:1.3;}
.nf-item.unread .nf-title{font-weight:800;}
.nf-text{font-size:.8rem;color:var(--sub);margin-top:4px;line-height:1.45;}
.nf-time{font-size:.7rem;color:var(--muted);margin-top:6px;font-weight:600;}
.nf-dot{width:8px;height:8px;border-radius:50%;background:var(--g2);flex-shrink:0;margin-top:6px;}

/* EMPTY */
.nf-empty{padding:60px 24px;text-align:center;color:var(--muted);}
.nf-empty-ico{font-size:56px;margin-bottom:14px;}
.nf-empty h3{font-size:1.1rem;font-weight:800;color:var(--ink);margin:0 0 8px;}
.nf-empty p{font-size:.84rem;margin:0;}
</style>

<div class="nf-pg">

    <!-- HERO -->
    <div class="nf-hero">
        <div class="nf-hero-inner">
            <div class="nf-hero-left">
                <h1><i class="fa-solid fa-bell me-2"></i>Notifications</h1>
                <p>Stay up to date with your learning activity</p>
            </div>
            <div class="nf-hero-right">
                @if (unreadCount > 0)
                {
                    <div class="nf-unread-badge">
                        <div class="nf-unread-badge-val">@unreadCount</div>
                        <div class="nf-unread-badge-lbl">Unread</div>
                    </div>
                }
                <button class="nf-readall" id="readAllBtn">
                    <i class="fa-solid fa-check-double"></i>Mark all read
                </button>
            </div>
        </div>
    </div>

    @if (items.Count == 0)
    {
        <div class="nf-card">
            <div class="nf-empty">
                <div class="nf-empty-ico">🔕</div>
                <h3>You're all caught up!</h3>
                <p>No notifications right now. We'll let you know when something new happens.</p>
            </div>
        </div>
    }
    else
    {
        <div class="nf-card">
            <div class="nf-card-head">
                <div class="nf-card-title"><i class="fa-solid fa-list"></i>All Notifications</div>
                <span style="font-size:.75rem;color:var(--muted);font-weight:600;">@items.Count total</span>
            </div>
            @foreach (var n in items)
            {
                var unread = ((int?)n["IsRead"] ?? 0) == 0;
                var link   = (string?)n["LinkUrl"];
                var icon   = (string?)n["Icon"] ?? "fa-solid fa-bell";
                var when   = (DateTime?)n["CreatedDate"];
                var title  = (string?)n["Title"] ?? "";
                var body   = (string?)n["Body"] ?? "";

                // pick icon background by icon class hint
                var icoClass = icon.Contains("graduation") || icon.Contains("book") ? "nf-ico-course"
                             : icon.Contains("credit") || icon.Contains("receipt") || icon.Contains("money") ? "nf-ico-payment"
                             : icon.Contains("award") || icon.Contains("medal") || icon.Contains("trophy") ? "nf-ico-badge"
                             : icon.Contains("file-pen") || icon.Contains("clipboard") ? "nf-ico-exam"
                             : "nf-ico-default";

                <a class="nf-item @(unread ? "unread" : "")"
                   href="@(string.IsNullOrEmpty(link) ? "javascript:void(0)" : link)">
                    <div class="nf-ico-wrap @icoClass"><i class="@icon"></i></div>
                    <div class="nf-body">
                        <div class="nf-title">@title</div>
                        @if (!string.IsNullOrEmpty(body)) { <div class="nf-text">@body</div> }
                        @if (when.HasValue) { <div class="nf-time"><i class="fa-regular fa-clock me-1"></i>@when.Value.ToString("dd MMM yyyy, h:mm tt")</div> }
                    </div>
                    @if (unread) { <div class="nf-dot"></div> }
                </a>
            }
        </div>
    }
</div>

@section Scripts {
<script>
document.getElementById('readAllBtn')?.addEventListener('click', function() {
    this.disabled = true;
    this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Marking…';
    fetch(('@((ViewBag.ApiBaseUrl as string) ?? "")'.replace(/\/+$/, '')) + '/api/Notification/read-all/@uid', { method: 'POST' })
        .then(() => location.reload())
        .catch(() => location.reload());
});
</script>
}
