@model IEnumerable<ProximaLMS.Controllers.RoleViewModel>
@{
    ViewData["Title"] = "Role Management";
    Layout = "_Layout";
    int idx = 0;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap');

    :root {
        --ink:      #1a1035;
        --ink2:     #4b4369;
        --grape:    #4C1864;
        --violet:   #7B2CBF;
        --lavender: #ede9f8;
        --mint:     #d1fae5;
        --mint-dk:  #059669;
        --rose:     #fee2e2;
        --rose-dk:  #dc2626;
        --amber:    #fef3c7;
        --amber-dk: #d97706;
        --sky:      #dbeafe;
        --sky-dk:   #1d4ed8;
        --surface:  #ffffff;
        --bg:       #f5f3ff;
        --border:   #ede9f8;
        --shadow:   0 1px 3px rgba(76,24,100,.08), 0 8px 24px rgba(76,24,100,.06);
        --shadow-lg:0 4px 6px rgba(76,24,100,.06), 0 20px 40px rgba(76,24,100,.12);
    }

    * { box-sizing: border-box; }

    body {
        background: var(--bg);
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--ink);
    }

    .container-fluid { padding: 0 !important; }

    /* ══════════════════════════════════════
       TOP HERO STRIP
    ══════════════════════════════════════ */
    .rm-hero {
        background: linear-gradient(135deg, var(--grape) 0%, #2d0f4e 60%, var(--violet) 100%);
        padding: 32px 32px 80px;
        position: relative;
        overflow: hidden;
    }

    .rm-hero::before {
        content: '';
        position: absolute;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(123,44,191,.4) 0%, transparent 70%);
        top: -100px; right: -80px;
        border-radius: 50%;
    }

    .rm-hero::after {
        content: '';
        position: absolute;
        width: 250px; height: 250px;
        background: radial-gradient(circle, rgba(255,255,255,.06) 0%, transparent 70%);
        bottom: 0; left: 200px;
        border-radius: 50%;
    }

    .rm-hero-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        z-index: 2;
    }

    .rm-hero-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(255,255,255,.5);
        margin-bottom: 6px;
    }

    .rm-hero-title {
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        margin: 0 0 6px;
        line-height: 1.2;
    }

    .rm-hero-sub {
        font-size: 14px;
        color: rgba(255,255,255,.55);
        margin: 0;
    }

    .btn-new-role {
        background: #fff;
        color: var(--grape);
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 14px;
        font-weight: 700;
        padding: 12px 24px;
        border-radius: 12px;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,.25);
        transition: transform .2s, box-shadow .2s;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .btn-new-role:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 32px rgba(0,0,0,.3);
        color: var(--grape);
    }

    /* ══════════════════════════════════════
       STAT CARDS (float up over hero)
    ══════════════════════════════════════ */
    .stats-band {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        padding: 0 32px;
        margin-top: -48px;
        position: relative;
        z-index: 10;
    }

    @@media (max-width: 900px) {
        .stats-band { grid-template-columns: repeat(2, 1fr); }
    }

    .stat-card {
        background: var(--surface);
        border-radius: 16px;
        padding: 20px 22px;
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: 16px;
        border: 1px solid var(--border);
        transition: transform .2s;
    }

    .stat-card:hover { transform: translateY(-2px); }

    .stat-icon-wrap {
        width: 48px; height: 48px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

    .si-purple { background: var(--lavender); color: var(--grape); }
    .si-green  { background: var(--mint);     color: var(--mint-dk); }
    .si-amber  { background: var(--amber);    color: var(--amber-dk); }
    .si-blue   { background: var(--sky);      color: var(--sky-dk); }

    .stat-num {
        font-size: 28px;
        font-weight: 800;
        color: var(--ink);
        line-height: 1;
    }

    .stat-lbl {
        font-size: 12px;
        font-weight: 600;
        color: var(--ink2);
        margin-top: 3px;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    /* ══════════════════════════════════════
       CONTENT AREA
    ══════════════════════════════════════ */
    .rm-body {
        padding: 28px 32px 40px;
    }

    /* ══════════════════════════════════════
       TOOLBAR
    ══════════════════════════════════════ */
    .rm-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .rm-toolbar-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .search-wrap {
        position: relative;
    }

    .search-wrap i {
        position: absolute;
        left: 13px; top: 50%;
        transform: translateY(-50%);
        color: #aaa;
        font-size: 13px;
        pointer-events: none;
    }

    .rm-search {
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 9px 14px 9px 36px;
        width: 260px;
        font-size: 13px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: var(--surface);
        color: var(--ink);
        outline: none;
        transition: border-color .2s, box-shadow .2s;
    }

    .rm-search:focus {
        border-color: var(--violet);
        box-shadow: 0 0 0 3px rgba(123,44,191,.1);
    }

    .rm-count-tag {
        font-size: 13px;
        color: var(--ink2);
        background: var(--lavender);
        padding: 6px 14px;
        border-radius: 8px;
        font-weight: 600;
    }

    /* ══════════════════════════════════════
       ROLE CARDS GRID
    ══════════════════════════════════════ */
    .roles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 18px;
    }

    @@media (max-width: 750px) {
        .roles-grid { grid-template-columns: 1fr; }
    }

    .role-card {
        background: var(--surface);
        border-radius: 18px;
        border: 1.5px solid var(--border);
        box-shadow: var(--shadow);
        overflow: hidden;
        transition: transform .25s, box-shadow .25s;
        display: flex;
        flex-direction: column;
    }

    .role-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
        border-color: rgba(123,44,191,.25);
    }

    /* Card Top Strip */
    .role-card-top {
        background: linear-gradient(135deg, var(--grape), var(--violet));
        padding: 18px 20px 14px;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        position: relative;
    }

    .role-card-top.system-role {
        background: linear-gradient(135deg, #1e3a5f, #2563eb);
    }

    .role-card-top::after {
        content: '';
        position: absolute;
        width: 120px; height: 120px;
        background: radial-gradient(circle, rgba(255,255,255,.12) 0%, transparent 70%);
        top: -30px; right: -20px;
        border-radius: 50%;
    }

    .role-badge {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 700;
        background: rgba(255,255,255,.18);
        color: #fff;
        padding: 4px 10px;
        border-radius: 6px;
        letter-spacing: .5px;
        border: 1px solid rgba(255,255,255,.2);
        position: relative;
        z-index: 1;
    }

    .role-status-pill {
        font-size: 11px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 20px;
        position: relative;
        z-index: 1;
    }

    .pill-active   { background: rgba(16,185,129,.25); color: #6ee7b7; border: 1px solid rgba(110,231,183,.3); }
    .pill-inactive { background: rgba(239,68,68,.25);  color: #fca5a5; border: 1px solid rgba(252,165,165,.3); }

    /* Card Body */
    .role-card-body {
        padding: 16px 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .role-name {
        font-size: 17px;
        font-weight: 800;
        color: var(--ink);
        margin: 0;
        line-height: 1.3;
    }

    .role-desc {
        font-size: 13px;
        color: var(--ink2);
        line-height: 1.5;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Meta Row */
    .role-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 600;
        padding: 5px 10px;
        border-radius: 8px;
    }

    .chip-users { background: var(--lavender); color: var(--grape); }
    .chip-perms { background: var(--sky);      color: var(--sky-dk); }
    .chip-date  { background: #f3f4f6;         color: #6b7280; }
    .chip-system{ background: #fef3c7;         color: #92400e; }

    /* Toggle Row */
    .role-toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 0 0;
        border-top: 1px solid var(--border);
    }

    .toggle-label-text {
        font-size: 13px;
        font-weight: 600;
        color: var(--ink2);
    }

    /* Toggle Switch */
    .tgl-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .tgl-switch {
        position: relative;
        width: 44px; height: 24px;
        display: inline-block;
    }

    .tgl-switch input { opacity: 0; width: 0; height: 0; }

    .tgl-track {
        position: absolute; inset: 0;
        background: #d1d5db;
        border-radius: 24px;
        cursor: pointer;
        transition: .3s;
    }

    .tgl-track::before {
        content: '';
        position: absolute;
        width: 18px; height: 18px;
        left: 3px; bottom: 3px;
        background: #fff;
        border-radius: 50%;
        transition: .3s;
        box-shadow: 0 1px 4px rgba(0,0,0,.2);
    }

    input:checked + .tgl-track { background: #10b981; }
    input:checked + .tgl-track::before { transform: translateX(20px); }

    .tgl-text {
        font-size: 12px;
        font-weight: 700;
        min-width: 50px;
    }

    .tgl-text.on  { color: #059669; }
    .tgl-text.off { color: #ef4444; }

    /* Card Footer Actions */
    .role-card-footer {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        border-top: 1px solid var(--border);
    }

    .card-action {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        padding: 12px 8px;
        border: none;
        background: transparent;
        font-size: 11px;
        font-weight: 700;
        font-family: 'Plus Jakarta Sans', sans-serif;
        cursor: pointer;
        text-decoration: none;
        transition: background .15s;
        color: var(--ink2);
        border-right: 1px solid var(--border);
    }

    .card-action:last-child { border-right: none; }

    .card-action i { font-size: 15px; }

    .ca-edit:hover   { background: #eff6ff; color: #1d4ed8; }
    .ca-perm:hover   { background: #f0fdf4; color: #059669; }
    .ca-users:hover  { background: #fef3c7; color: #92400e; }
    .ca-delete:hover { background: #fff1f2; color: #dc2626; }

    .ca-edit   i { color: #3b82f6; }
    .ca-perm   i { color: #10b981; }
    .ca-users  i { color: #f59e0b; }
    .ca-delete i { color: #ef4444; }

    /* ══════════════════════════════════════
       EMPTY STATE
    ══════════════════════════════════════ */
    .rm-empty {
        background: var(--surface);
        border-radius: 18px;
        border: 2px dashed var(--border);
        padding: 80px 40px;
        text-align: center;
    }

    .rm-empty-icon {
        width: 80px; height: 80px;
        background: var(--lavender);
        border-radius: 24px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px;
        font-size: 32px;
        color: var(--violet);
    }

    .rm-empty h4 {
        font-size: 20px;
        font-weight: 800;
        color: var(--ink);
        margin-bottom: 8px;
    }

    .rm-empty p {
        font-size: 14px;
        color: var(--ink2);
        margin-bottom: 24px;
    }

    /* ══════════════════════════════════════
       ALERTS
    ══════════════════════════════════════ */
    .rm-alert {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 18px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .rm-alert.success { background: var(--mint);  color: var(--mint-dk); border: 1px solid #a7f3d0; }
    .rm-alert.error   { background: var(--rose);  color: var(--rose-dk); border: 1px solid #fecaca; }
</style>

<div class="container-fluid">

    <!-- ── HERO STRIP ── -->
    <div class="rm-hero">
        <div class="rm-hero-inner">
            <div>
                <div class="rm-hero-label">Administration</div>
                <h1 class="rm-hero-title">
                    <i class="fas fa-shield-halved me-2" style="opacity:.7;"></i>Role Management
                </h1>
                <p class="rm-hero-sub">Define roles, assign screen-level permissions, and manage user access.</p>
            </div>
            <a asp-action="Create" class="btn-new-role">
                <i class="fas fa-plus"></i> New Role
            </a>
        </div>
    </div>

    <!-- ── FLOATING STAT CARDS ── -->
    <div class="stats-band">
        <div class="stat-card">
            <div class="stat-icon-wrap si-purple"><i class="fas fa-shield-halved"></i></div>
            <div>
                <div class="stat-num">@Model.Count()</div>
                <div class="stat-lbl">Total Roles</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon-wrap si-green"><i class="fas fa-circle-check"></i></div>
            <div>
                <div class="stat-num">@Model.Count(r => r.IsActive)</div>
                <div class="stat-lbl">Active</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon-wrap si-amber"><i class="fas fa-users"></i></div>
            <div>
                <div class="stat-num">@Model.Sum(r => r.UserCount)</div>
                <div class="stat-lbl">Users Assigned</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon-wrap si-blue"><i class="fas fa-key"></i></div>
            <div>
                <div class="stat-num">@Model.Sum(r => r.PermissionCount)</div>
                <div class="stat-lbl">Permissions Set</div>
            </div>
        </div>
    </div>

    <!-- ── BODY ── -->
    <div class="rm-body">

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="rm-alert success">
                <i class="fas fa-circle-check"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="rm-alert error">
                <i class="fas fa-circle-exclamation"></i> @TempData["Error"]
            </div>
        }

        <!-- Toolbar -->
        <div class="rm-toolbar">
            <div class="rm-toolbar-left">
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" id="roleSearch" class="rm-search"
                           placeholder="Search by name or code…" />
                </div>
                <span class="rm-count-tag">
                    <span id="visibleCount">@Model.Count()</span> of @Model.Count() roles
                </span>
            </div>
        </div>

        <!-- Grid -->
        @if (Model != null && Model.Any())
        {
            <div class="roles-grid" id="rolesGrid">
                @foreach (var role in Model)
                {
                    idx++;
                    <div class="role-card role-item"
                         data-name="@role.RoleName.ToLower()"
                         data-code="@role.RoleCode.ToLower()">

                        <!-- TOP STRIP -->
                        <div class="role-card-top @(role.IsSystem ? "system-role" : "")">
                            <span class="role-badge">@role.RoleCode</span>
                            <span class="role-status-pill @(role.IsActive ? "pill-active" : "pill-inactive")">
                                <i class="fas fa-@(role.IsActive ? "circle" : "circle-xmark") me-1" style="font-size:9px;"></i>
                                @(role.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>

                        <!-- BODY -->
                        <div class="role-card-body">

                            <div>
                                <h3 class="role-name">@role.RoleName</h3>
                                <p class="role-desc">
                                    @(string.IsNullOrEmpty(role.Description) ? "No description provided." : role.Description)
                                </p>
                            </div>

                            <!-- META CHIPS -->
                            <div class="role-meta">
                                <span class="meta-chip chip-users">
                                    <i class="fas fa-users"></i> @role.UserCount users
                                </span>
                                <span class="meta-chip chip-perms">
                                    <i class="fas fa-key"></i> @role.PermissionCount perms
                                </span>
                                @if (role.IsSystem)
                                {
                                    <span class="meta-chip chip-system">
                                        <i class="fas fa-lock"></i> System
                                    </span>
                                }
                            </div>

                            <!-- CREATED INFO -->
                            <div style="display:flex; align-items:center; gap:6px; font-size:12px; color:#9ca3af;">
                                <i class="fas fa-clock" style="font-size:11px;"></i>
                                Created by <strong style="color:var(--ink2); margin:0 2px;">@role.CreatedBy</strong>
                                on @role.CreatedDate
                            </div>

                            <!-- TOGGLE -->
                            <div class="role-toggle-row">
                                <span class="toggle-label-text">
                                    <i class="fas fa-power-off me-1" style="font-size:12px;"></i>
                                    Role Status
                                </span>
                                <div class="tgl-wrap">
                                    <label class="tgl-switch">
                                        <input type="checkbox"
                                               id="toggle_@role.RoleID"
                                               @(role.IsActive ? "checked" : "")
                                               onchange="toggleRoleStatus(@role.RoleID, this.checked)" />
                                        <span class="tgl-track"></span>
                                    </label>
                                    <span class="tgl-text @(role.IsActive ? "on" : "off")"
                                          id="tglText_@role.RoleID">
                                        @(role.IsActive ? "Enabled" : "Disabled")
                                    </span>
                                </div>
                            </div>

                        </div>

                        <!-- FOOTER ACTIONS -->
                        <div class="role-card-footer">
                            <a asp-action="Create" asp-route-id="@role.RoleID"
                               class="card-action ca-edit">
                                <i class="fas fa-pen-to-square"></i>
                                Edit
                            </a>
                            <a asp-action="Permissions" asp-route-id="@role.RoleID"
                               class="card-action ca-perm">
                                <i class="fas fa-key"></i>
                                Perms
                            </a>
                            <a asp-action="AssignUsers" asp-route-id="@role.RoleID"
                               class="card-action ca-users">
                                <i class="fas fa-user-plus"></i>
                                Users
                            </a>
                            <button class="card-action ca-delete"
                                    onclick="deleteRole(@role.RoleID, '@Html.Raw(role.RoleName.Replace("'","\\\'"))')">
                                <i class="fas fa-trash-can"></i>
                                Delete
                            </button>
                        </div>

                    </div>
                }
            </div>
        }
        else
        {
            <div class="rm-empty">
                <div class="rm-empty-icon"><i class="fas fa-shield-halved"></i></div>
                <h4>No Roles Yet</h4>
                <p>Create your first role to start managing access control.</p>
                <a asp-action="Create" class="btn-new-role"
                   style="display:inline-flex; box-shadow:none; background:linear-gradient(135deg,var(--grape),var(--violet)); color:#fff;">
                    <i class="fas fa-plus"></i> Create First Role
                </a>
            </div>
        }

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

    // ── SEARCH ───────────────────────────────────────────
    document.getElementById('roleSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        const items = document.querySelectorAll('.role-item');
        let visible = 0;
        items.forEach(el => {
            const match = !q
                || el.dataset.name.includes(q)
                || el.dataset.code.includes(q);
            el.style.display = match ? '' : 'none';
            if (match) visible++;
        });
        document.getElementById('visibleCount').textContent = visible;
    });

    // ── TOGGLE STATUS ─────────────────────────────────────
    async function toggleRoleStatus(roleId, isActive) {
        const toggle  = document.getElementById(`toggle_${roleId}`);
        const tglText = document.getElementById(`tglText_${roleId}`);

        const result = await Swal.fire({
            title: isActive ? 'Activate Role?' : 'Deactivate Role?',
            text:  isActive
                ? 'Users with this role will gain access immediately.'
                : 'Users with this role will lose access immediately.',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#4C1864',
            confirmButtonText: 'Yes, Proceed',
            cancelButtonText: 'Cancel',
            borderRadius: '16px'
        });

        if (!result.isConfirmed) {
            toggle.checked = !isActive;
            return;
        }

        try {
            const resp = await fetch('/Role/ToggleStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roleID: roleId, isActive })
            });
            const data = await resp.json();

            if (data.success) {
                tglText.textContent = isActive ? 'Enabled' : 'Disabled';
                tglText.className   = `tgl-text ${isActive ? 'on' : 'off'}`;
                Swal.fire({
                    icon: 'success', title: 'Updated!',
                    timer: 1500, showConfirmButton: false
                });
            } else {
                toggle.checked = !isActive;
                Swal.fire({ icon: 'error', title: 'Failed', text: data.message });
            }
        } catch (e) {
            toggle.checked = !isActive;
            Swal.fire({ icon: 'error', title: 'Error', text: e.message });
        }
    }

    // ── DELETE ROLE ───────────────────────────────────────
    async function deleteRole(roleId, roleName) {
        const result = await Swal.fire({
            title: `Delete "${roleName}"?`,
            html: `<p style="color:#6b7280;font-size:14px;">
                      This action <strong style="color:#dc2626;">cannot be undone</strong>.<br>
                      All permissions linked to this role will be removed.
                   </p>`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor:  '#6b7280',
            confirmButtonText: '<i class="fas fa-trash-can me-1"></i> Yes, Delete',
            cancelButtonText:  'Cancel'
        });

        if (!result.isConfirmed) return;

        try {
            const resp = await fetch('/Role/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roleID: roleId })
            });
            const data = await resp.json();

            if (data.success) {
                await Swal.fire({
                    icon: 'success', title: 'Deleted!',
                    timer: 1500, showConfirmButton: false
                });
                location.reload();
            } else {
                Swal.fire({ icon: 'error', title: 'Cannot Delete', text: data.message });
            }
        } catch (e) {
            Swal.fire({ icon: 'error', title: 'Error', text: e.message });
        }
    }

    // ── TEMPDATA TOASTS ───────────────────────────────────
    @if (TempData["Success"] != null)
    {
        <text>
        Swal.fire({ icon: 'success', title: 'Success',
            text: '@Html.Raw(TempData["Success"]?.ToString()?.Replace("'", "\\'"))',
            timer: 2500, showConfirmButton: false, toast: true,
            position: 'top-end' });
        </text>
    }
    @if (TempData["Error"] != null)
    {
        <text>
        Swal.fire({ icon: 'error', title: 'Error',
            text: '@Html.Raw(TempData["Error"]?.ToString()?.Replace("'", "\\'"))' });
        </text>
    }
</script>
