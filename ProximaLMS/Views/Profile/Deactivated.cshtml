@*
    ProximaLMS/Views/Profile/Deactivated.cshtml
    Standalone landing page shown right after a user deactivates.
*@
@{
    Layout = null;
    ViewData["Title"] = "Account deactivated";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · ProximaLMS</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f3fa;
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            margin: 0; padding: 20px;
            color: #1f1d2b;
        }

        .da-card {
            background: #fff;
            border-radius: 20px;
            padding: 44px 38px;
            max-width: 460px;
            text-align: center;
            box-shadow: 0 14px 40px rgba(31, 29, 43, 0.08);
        }

        .da-icon {
            width: 88px; height: 88px;
            margin: 0 auto 22px;
            background: linear-gradient(135deg, #4C1864, #7B2CBF);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff;
            font-size: 36px;
        }

        h1 { font-size: 22px; font-weight: 800; margin: 0 0 8px; }
        p  { color: #6b7280; font-size: 14px; line-height: 1.6; margin: 0 0 12px; }

        .da-info {
            background: #f5f3fa;
            border-radius: 12px;
            padding: 14px 16px;
            font-size: 13px;
            color: #4b5563;
            text-align: left;
            margin: 18px 0 22px;
        }

        .da-info ul { margin: 6px 0 0 18px; padding: 0; }
        .da-info li { margin-bottom: 4px; }

        .da-btn {
            display: inline-block;
            background: linear-gradient(135deg, #4C1864, #7B2CBF);
            color: #fff;
            text-decoration: none;
            padding: 11px 26px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            transition: transform .1s, box-shadow .15s;
        }
        .da-btn:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 8px 22px rgba(76, 24, 100, .3);
        }
    </style>
</head>
<body>

<div class="da-card">
    <div class="da-icon"><i class="fa-solid fa-user-slash"></i></div>

    <h1>Your account is deactivated</h1>
    <p>You've been signed out of every device. Thanks for being part of ProximaLMS.</p>

    <div class="da-info">
        <strong>What this means:</strong>
        <ul>
            <li>You can't sign in until an administrator reactivates your account.</li>
            <li>Your enrollments, progress, certificates and purchases are kept.</li>
            <li>To reactivate, email <a href="mailto:support@proximalms.com">support@proximalms.com</a>.</li>
        </ul>
    </div>

    <a href="/" class="da-btn">Back to home</a>
</div>

</body>
</html>
