@*  /Views/Settings/Tags.cshtml
    FIX: TagController returns a bare array [], not { data: [] }.
         unwrapArray() handles both shapes so the list never silently
         comes back empty. *@
@model ProximaLMS.Models.SettingsPageVM
@{ Layout = "_Layout"; ViewData["Title"] = Model.Title; }

<div class="as-wrap">
    <div class="as-head">
        <h1><span class="ico"><i class="fa-solid fa-tags"></i></span> Tags</h1>
        <div class="as-crumb">
            <a asp-action="Index">Settings</a> &rsaquo; Tags
        </div>
    </div>

    <div class="as-card">
        <div class="as-card-head">
            <div class="as-card-title">Course tags</div>
            <button class="as-btn" id="btnAdd"><i class="fa-solid fa-plus"></i> Add tag</button>
        </div>
        <div class="as-card-body">
            <table class="as-table">
                <thead>
                    <tr>
                        <th style="width:50%">Name</th>
                        <th>Color</th>
                        <th style="width:110px">Status</th>
                        <th style="width:120px;text-align:right">Actions</th>
                    </tr>
                </thead>
                <tbody id="tblBody"><tr><td colspan="4" class="as-empty">Loading…</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<div class="as-overlay d-none" id="modal">
    <div class="as-dialog">
        <div class="as-dialog-head">
            <h3 id="dlgTitle">Add tag</h3>
            <button class="as-x" onclick="closeDlg()">&times;</button>
        </div>
        <div class="as-dialog-body">
            <input type="hidden" id="fId" value="0" />
            <div class="row g-3">
                <div class="col-12">
                    <label class="as-label">Tag name <span class="req">*</span></label>
                    <input id="fName" class="as-input" placeholder="e.g. trending, free, certificate" />
                </div>
                <div class="col-md-6">
                    <label class="as-label">Color (optional)</label>
                    <input id="fColor" type="color" class="as-input" value="#7B2CBF" style="height:42px;padding:4px;" />
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <label class="as-switch">
                        <input id="fActive" type="checkbox" checked />
                        <span></span> Active
                    </label>
                </div>
            </div>
        </div>
        <div class="as-dialog-foot">
            <button class="as-btn-ghost" onclick="closeDlg()">Cancel</button>
            <button class="as-btn" id="btnSave"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function () {
    const tbl = document.getElementById('tblBody');
    let rows = [];

    // ── Handles both bare [] and { data:[], success:true } shapes ──
    function unwrapArray(d) {
        if (Array.isArray(d)) return d;
        if (d && typeof d === 'object') {
            if (Array.isArray(d.data))   return d.data;
            if (Array.isArray(d.result)) return d.result;
        }
        return [];
    }

    async function load() {
        tbl.innerHTML = '<tr><td colspan="4" class="as-empty">Loading…</td></tr>';
        try {
            const r = await fetch('@Url.Action("TagList","Settings")');
            const d = await r.json();
            rows = unwrapArray(d);
            render();
        } catch {
            tbl.innerHTML = '<tr><td colspan="4" class="as-empty">Could not load.</td></tr>';
        }
    }

    function esc(s) { return (s ?? '').toString().replace(/[<>&"]/g, c => ({ '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;' }[c])); }

    function render() {
        if (!rows.length) {
            tbl.innerHTML = '<tr><td colspan="4" class="as-empty">No tags yet. Add one to get started.</td></tr>';
            return;
        }
        tbl.innerHTML = rows.map(r => `
            <tr>
                <td><strong>${esc(r.TagName)}</strong></td>
                <td>${r.ColorHex ? `<span class="as-swatch" style="background:${esc(r.ColorHex)}"></span><code class="as-code">${esc(r.ColorHex)}</code>` : '<span style="color:#9aa0ac">—</span>'}</td>
                <td>${r.IsActive ? '<span class="as-pill ok">Active</span>' : '<span class="as-pill off">Inactive</span>'}</td>
                <td class="as-actions">
                    <button class="as-icon-btn" title="Toggle status" onclick="toggleRow(${r.TagID})"><i class="fa-solid ${r.IsActive ? 'fa-eye-slash' : 'fa-eye'}"></i></button>
                    <button class="as-icon-btn" title="Edit" onclick="editRow(${r.TagID})"><i class="fa-solid fa-pen"></i></button>
                    <button class="as-icon-btn danger" title="Delete" onclick="delRow(${r.TagID}, '${esc(r.TagName).replace(/'/g,"\\'")}')"><i class="fa-solid fa-trash"></i></button>
                </td>
            </tr>`).join('');
    }

    window.editRow = id => openDlg(rows.find(x => x.TagID === id));

    window.toggleRow = async (id) => {
        const row = rows.find(x => x.TagID === id);
        const r = await fetch('@Url.Action("TagToggle","Settings")', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ TagID: id, IsActive: !row?.IsActive })
        });
        const d = await r.json();
        if (d.success) load();
        else Swal.fire({ icon: 'error', title: 'Failed', text: d.message || '' });
    };

    window.delRow = async (id, name) => {
        const res = await Swal.fire({
            icon: 'warning', title: 'Delete tag?',
            text: `"${name}" will be removed and detached from any courses using it.`,
            showCancelButton: true, confirmButtonText: 'Delete', confirmButtonColor: '#dc2626'
        });
        if (!res.isConfirmed) return;
        const r = await fetch('@Url.Action("TagDelete","Settings")', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ TagID: id })
        });
        const d = await r.json();
        if (d.success) { Swal.fire({ icon: 'success', title: 'Deleted', timer: 1200, showConfirmButton: false }); load(); }
        else Swal.fire({ icon: 'error', title: 'Failed', text: d.message || '' });
    };

    function openDlg(row) {
        document.getElementById('dlgTitle').textContent = row ? 'Edit tag' : 'Add tag';
        document.getElementById('fId').value     = row?.TagID   || 0;
        document.getElementById('fName').value   = row?.TagName || '';
        document.getElementById('fColor').value  = row?.ColorHex || '#7B2CBF';
        document.getElementById('fActive').checked = row ? !!row.IsActive : true;
        document.getElementById('modal').classList.remove('d-none');
    }
    window.closeDlg = () => document.getElementById('modal').classList.add('d-none');

    document.getElementById('btnAdd').addEventListener('click', () => openDlg(null));
    document.getElementById('btnSave').addEventListener('click', async function () {
        const name = document.getElementById('fName').value.trim();
        if (!name) return Swal.fire({ icon: 'warning', title: 'Tag name required' });

        const body = {
            TagID:    +document.getElementById('fId').value,
            TagName:  name,
            ColorHex: document.getElementById('fColor').value,
            IsActive: document.getElementById('fActive').checked
        };
        this.disabled = true;
        const r = await fetch('@Url.Action("TagSave","Settings")', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body)
        });
        const d = await r.json();
        this.disabled = false;
        if (d.success) {
            closeDlg();
            Swal.fire({ icon: 'success', title: 'Saved', timer: 1200, showConfirmButton: false });
            load();
        } else Swal.fire({ icon: 'error', title: 'Failed', text: d.message || '' });
    });

    load();
})();
</script>
