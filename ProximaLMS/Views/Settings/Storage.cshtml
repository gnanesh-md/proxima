@*  /Views/Settings/Storage.cshtml
    FIX: SystemSettingsController returns camelCase JSON properties
         (settingKey, settingValue). All field accesses updated from
         PascalCase to camelCase to match. *@
@model ProximaLMS.Models.SettingsPageVM
@{ Layout = "_Layout"; ViewData["Title"] = Model.Title; }

<div class="as-wrap">
    <div class="as-head">
        <h1><span class="ico"><i class="fa-solid fa-hard-drive"></i></span> Storage</h1>
        <div class="as-crumb">
            <a asp-action="Index">Settings</a> &rsaquo; Storage
        </div>
    </div>

    <div class="as-card">
        <div class="as-card-head">
            <div class="as-card-title">
                <i class="fa-solid fa-folder-open" style="color:var(--as-primary);margin-right:6px"></i>
                File storage configuration
            </div>
            <button class="as-btn" id="btnSave">
                <i class="fa-solid fa-floppy-disk"></i> Save changes
            </button>
        </div>

        <div class="as-card-body" id="loadingMsg">
            <div class="as-empty">Loading…</div>
        </div>

        <div class="as-card-body d-none" id="formBody">

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="as-label">Storage type</label>
                    <select id="storageType" class="as-select" disabled>
                        <option value="LOCAL">Local filesystem</option>
                    </select>
                    <div class="as-hint">
                        <i class="fa-solid fa-info-circle"></i>
                        Only local storage is supported in this version.
                    </div>
                </div>

                <div class="col-md-8">
                    <label class="as-label">Base upload path</label>
                    <input id="basePath" class="as-input" placeholder="wwwroot/uploads" />
                    <div class="as-hint">Relative paths resolve against the web project's root.</div>
                </div>

                <div class="col-md-4">
                    <label class="as-label">Max file size (MB)</label>
                    <input id="maxSize" type="number" class="as-input" min="1" max="500" value="50" />
                </div>

                <div class="col-md-4">
                    <label class="as-label">Max image size (MB)</label>
                    <input id="maxImage" type="number" class="as-input" min="1" max="50" value="5" />
                </div>

                <div class="col-md-4">
                    <label class="as-label">Max video size (MB)</label>
                    <input id="maxVideo" type="number" class="as-input" min="1" max="2048" value="500" />
                </div>

                <div class="col-12">
                    <label class="as-label">Allowed image extensions</label>
                    <input id="extImg" class="as-input" placeholder="jpg,jpeg,png,webp,gif" />
                </div>

                <div class="col-12">
                    <label class="as-label">Allowed video extensions</label>
                    <input id="extVid" class="as-input" placeholder="mp4,webm,mov" />
                </div>

                <div class="col-12">
                    <label class="as-label">Allowed document extensions</label>
                    <input id="extDoc" class="as-input" placeholder="pdf,docx,xlsx,pptx" />
                </div>

                <div class="col-md-6">
                    <div class="d-flex align-items-center" style="gap:10px;height:42px;">
                        <label class="as-switch m-0">
                            <input id="autoOrient" type="checkbox" checked />
                            <span class="slider"></span>
                        </label>
                        <span style="font-size:13px;color:var(--as-ink);">
                            Auto-orient uploaded images (read EXIF)
                        </span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="d-flex align-items-center" style="gap:10px;height:42px;">
                        <label class="as-switch m-0">
                            <input id="stripMeta" type="checkbox" checked />
                            <span class="slider"></span>
                        </label>
                        <span style="font-size:13px;color:var(--as-ink);">
                            Strip metadata from uploaded images
                        </span>
                    </div>
                </div>
            </div>

            <div style="background:var(--as-bg);border-radius:12px;padding:18px;
                        margin-top:24px;display:flex;align-items:center;gap:18px;">
                <div style="width:48px;height:48px;border-radius:12px;
                            background:linear-gradient(135deg,var(--as-primary),var(--as-primary-2));
                            color:#fff;display:flex;align-items:center;justify-content:center;
                            font-size:20px;">
                    <i class="fa-solid fa-database"></i>
                </div>
                <div style="flex:1;">
                    <div style="font-weight:700;font-size:14px;">Limits at a glance</div>
                    <div style="font-size:12.5px;color:var(--as-ink2);margin-top:4px;">
                        Images &le; <span id="lblImg">5</span> MB &middot;
                        Videos &le; <span id="lblVid">500</span> MB &middot;
                        Other files &le; <span id="lblAll">50</span> MB
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function () {
    async function load() {
        try {
            const r = await fetch('@Url.Action("StorageLoad","Settings")');
            const d = await r.json();
            const map = {};
            // API returns camelCase: settingKey, settingValue
            (d.data || []).forEach(s => { map[s.settingKey] = s; });
            populate(map);
        } catch {
            document.getElementById('loadingMsg').innerHTML =
                '<div class="as-empty">Could not load.</div>';
        }
    }

    function populate(m) {
        // Use camelCase settingValue to match API response
        function val(k, def = '') { return m[k]?.settingValue ?? def; }

        document.getElementById('storageType').value = val('STORAGE_TYPE', 'LOCAL');
        document.getElementById('basePath').value    = val('STORAGE_BASE_PATH', 'wwwroot/uploads');
        document.getElementById('maxSize').value     = val('STORAGE_MAX_FILE_MB', '50');
        document.getElementById('maxImage').value    = val('STORAGE_MAX_IMAGE_MB', '5');
        document.getElementById('maxVideo').value    = val('STORAGE_MAX_VIDEO_MB', '500');
        document.getElementById('extImg').value      = val('STORAGE_EXT_IMAGE', 'jpg,jpeg,png,webp,gif');
        document.getElementById('extVid').value      = val('STORAGE_EXT_VIDEO', 'mp4,webm,mov');
        document.getElementById('extDoc').value      = val('STORAGE_EXT_DOC',   'pdf,docx,xlsx,pptx');
        document.getElementById('autoOrient').checked = (val('STORAGE_AUTO_ORIENT', '1') === '1');
        document.getElementById('stripMeta').checked  = (val('STORAGE_STRIP_META',  '1') === '1');

        updateLabels();
        document.getElementById('loadingMsg').classList.add('d-none');
        document.getElementById('formBody').classList.remove('d-none');
    }

    function updateLabels() {
        document.getElementById('lblImg').textContent = document.getElementById('maxImage').value || '5';
        document.getElementById('lblVid').textContent = document.getElementById('maxVideo').value || '500';
        document.getElementById('lblAll').textContent = document.getElementById('maxSize').value  || '50';
    }
    ['maxImage', 'maxVideo', 'maxSize'].forEach(id =>
        document.getElementById(id).addEventListener('input', updateLabels));

    document.getElementById('btnSave').addEventListener('click', async function () {
        const settings = [
            { SettingKey: 'STORAGE_TYPE',         SettingValue: document.getElementById('storageType').value },
            { SettingKey: 'STORAGE_BASE_PATH',    SettingValue: document.getElementById('basePath').value.trim() },
            { SettingKey: 'STORAGE_MAX_FILE_MB',  SettingValue: document.getElementById('maxSize').value },
            { SettingKey: 'STORAGE_MAX_IMAGE_MB', SettingValue: document.getElementById('maxImage').value },
            { SettingKey: 'STORAGE_MAX_VIDEO_MB', SettingValue: document.getElementById('maxVideo').value },
            { SettingKey: 'STORAGE_EXT_IMAGE',    SettingValue: document.getElementById('extImg').value.trim() },
            { SettingKey: 'STORAGE_EXT_VIDEO',    SettingValue: document.getElementById('extVid').value.trim() },
            { SettingKey: 'STORAGE_EXT_DOC',      SettingValue: document.getElementById('extDoc').value.trim() },
            { SettingKey: 'STORAGE_AUTO_ORIENT',  SettingValue: document.getElementById('autoOrient').checked ? '1' : '0' },
            { SettingKey: 'STORAGE_STRIP_META',   SettingValue: document.getElementById('stripMeta').checked  ? '1' : '0' }
        ];

        this.disabled = true;
        const r = await fetch('@Url.Action("StorageSave","Settings")', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ Group: 'STORAGE', Settings: settings })
        });
        const d = await r.json();
        this.disabled = false;
        if (d.success) Swal.fire({ icon: 'success', title: 'Saved', timer: 1200, showConfirmButton: false });
        else Swal.fire({ icon: 'error', title: 'Failed', text: d.message || '' });
    });

    load();
})();
</script>
