  // To (re)populate them on a new machine, run from the API project:
  //   dotnet user-secrets set "ConnectionStrings:ConnectionString" "<conn>"
  //   dotnet user-secrets set "Jwt:Key"                "<base64-key>"
  //   dotnet user-secrets set "EmailSettings:SenderEmail" "<email>"
  //   dotnet user-secrets set "EmailSettings:Username"  "<email>"
  //   dotnet user-secrets set "EmailSettings:Password"  "<app-password>"
  //   dotnet user-secrets set "SmsSettings:Username"    "<user>"
  //   dotnet user-secrets set "SmsSettings:Password"    "<pass>"
  //   dotnet user-secrets set "Razorpay:KeySecret"      "<secret>"
  //   dotnet user-secrets set "Razorpay:WebhookSecret"  "<webhook-secret>"
